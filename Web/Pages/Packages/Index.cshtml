@page
@model PRN222_FINAL.Web.Pages.Packages.IndexModel
@{
    ViewData["Title"] = "Packages";
    ViewData["UseRblShell"] = true;
    ViewData["ActiveNav"] = "billing";
    ViewData["ShellTitle"] = "Packages";
}

<section class="container-fluid py-4">
    <div class="d-flex align-items-center justify-content-between mb-4">
        <div>
            <h1 class="h3 mb-1">Packages</h1>
            <p class="text-muted mb-0">Choose a package for RAG chatbot, document upload and storage limits.</p>
        </div>
        <a class="btn btn-outline-primary" asp-page="/Subscriptions/Current">Current subscription</a>
    </div>

    @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
    {
        <div class="alert alert-danger">@Model.ErrorMessage</div>
    }

    <div class="row g-3">
        @foreach (var package in Model.Packages)
        {
            <div class="col-12 col-md-4">
                <article class="card h-100">
                    <div class="card-body d-flex flex-column">
                        <div class="d-flex align-items-start justify-content-between gap-3">
                            <div>
                                <h2 class="h5 mb-1">@package.Name</h2>
                                <span class="badge text-bg-light">@package.Code</span>
                            </div>
                            <strong class="fs-5">@package.PriceVnd.ToString("N0") VND</strong>
                        </div>
                        <p class="text-muted mt-3">@package.Description</p>
                        <ul class="list-unstyled small mb-4">
                            <li>Chat/month: @package.MonthlyChatLimit.ToString("N0")</li>
                            <li>Uploads/month: @package.MonthlyDocumentUploadLimit.ToString("N0")</li>
                            <li>Storage: @package.StorageLimitMb.ToString("N0") MB</li>
                            <li>Duration: @package.DurationDays days</li>
                        </ul>
                        <form class="mt-auto" method="get" asp-page="/Payments/Checkout">
                            <input type="hidden" name="packageId" value="@package.Id" />
                            <button type="submit" class="btn btn-primary w-100">Choose package</button>
                        </form>
                    </div>
                </article>
            </div>
        }
    </div>
</section>
