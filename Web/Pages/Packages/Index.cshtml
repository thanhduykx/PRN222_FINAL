@page
@using PRN222_FINAL.BLL.Models
@model PRN222_FINAL.Web.Pages.Packages.IndexModel
@{
    ViewData["Title"] = "Gói dịch vụ";
    ViewData["UseRblShell"] = true;
    ViewData["ActiveNav"] = "billing";
    ViewData["ShellTitle"] = "Gói dịch vụ";
    ViewData["ShellTitleI18n"] = "packages.shellTitle";
}

<section class="ops-page package-membership">
    <header class="package-membership__hero">
        <div class="package-membership__symbols" aria-hidden="true">
            <span class="is-blue"><span class="material-symbols-outlined">school</span></span>
            <span class="is-teal"><span class="material-symbols-outlined">workspace_premium</span></span>
            <span class="is-violet"><span class="material-symbols-outlined">diamond</span></span>
        </div>
        <h1 data-i18n="packages.title">Chọn gói học tập phù hợp</h1>
        <p data-i18n="packages.desc">Nâng cấp số lượt hỏi đáp để học hiệu quả hơn cùng tài liệu môn học.</p>
        <a class="package-membership__current-link" asp-page="/Subscriptions/Current">
            <span class="material-symbols-outlined" aria-hidden="true">receipt_long</span>
            <span data-i18n="packages.viewCurrent">Xem gói hiện tại</span>
        </a>
    </header>

    @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
    {
        <div class="rbl-alert is-error" role="alert">@Model.ErrorMessage</div>
    }

    <div class="package-membership__grid">
        @foreach (var package in Model.Packages)
        {
            var isPremiumPackage = package.IsLifetime
                || package.Code.Contains("ANNUAL", StringComparison.OrdinalIgnoreCase)
                || package.Code.Contains("PRO", StringComparison.OrdinalIgnoreCase);
            var tone = (isPremiumPackage, package.IsFree) switch
            {
                (true, _) => "is-violet",
                (_, true) => "is-blue",
                _ => "is-teal"
            };
            var packageIcon = (isPremiumPackage, package.IsFree) switch
            {
                (true, _) => "diamond",
                (_, true) => "school",
                _ => "workspace_premium"
            };
            var packageI18nSuffix = package.Code.ToUpperInvariant() switch
            {
                "FREE" => "free",
                "STUDENT" => "student",
                "PRO" => "pro",
                "ANNUAL" => "annual",
                _ => string.Empty
            };
            var packageNameI18n = string.IsNullOrWhiteSpace(packageI18nSuffix) ? null : $"packages.name.{packageI18nSuffix}";
            var packageDescriptionI18n = string.IsNullOrWhiteSpace(packageI18nSuffix) ? null : $"packages.desc.{packageI18nSuffix}";
            <article class="package-membership__card @tone @(package.IsCurrentPackage ? "is-current" : "")">
                <div class="package-membership__badges">
                    @if (package.DiscountPercent > 0)
                    {
                        <span class="package-membership__discount"><span data-i18n="packages.discount">Giảm</span> @package.DiscountPercent%</span>
                    }
                    @if (package.IsCurrentPackage)
                    {
                        <span class="package-membership__featured" data-i18n="packages.inUseBadge">Đang sử dụng</span>
                    }
                    else if (package.IsStudent)
                    {
                        <span class="package-membership__featured" data-i18n="packages.studentRecommended">Khuyên dùng cho sinh viên</span>
                    }
                </div>

                <div class="package-membership__icon" aria-hidden="true">
                    <span class="material-symbols-outlined">@packageIcon</span>
                </div>
                <span class="package-membership__code">@package.Code</span>
                <h2 data-i18n="@packageNameI18n">@package.Name</h2>
                <div class="package-membership__price">
                    <strong>@if (package.IsFree) { <span data-i18n="packages.free">Miễn phí</span> } else { @($"{package.PriceVnd:N0}đ") }</strong>
                    <span>@if (package.IsFree) { <span data-i18n="packages.startNow">bắt đầu ngay</span> } else if (package.IsLifetime) { <span data-i18n="packages.oneTimePayment">thanh toán một lần</span> } else { <span data-i18n="packages.for">cho</span> @package.DurationDays <span data-i18n="packages.days">ngày</span> }</span>
                </div>
                <p class="package-membership__description" data-i18n="@packageDescriptionI18n">@package.Description</p>

                <ul class="package-membership__benefits">
                    <li><span class="material-symbols-outlined" aria-hidden="true">check_circle</span><span><strong>@package.MonthlyChatLimit.ToString("N0")</strong> <span data-i18n="packages.questionsPerMonth">câu hỏi mỗi tháng</span></span></li>
                    <li><span class="material-symbols-outlined" aria-hidden="true">check_circle</span><span data-i18n="packages.answerBasedOnDocs">Trả lời dựa trên tài liệu môn học</span></li>
                    <li><span class="material-symbols-outlined" aria-hidden="true">check_circle</span><span data-i18n="packages.saveHistory">Lưu lịch sử và nguồn tham khảo</span></li>
                    @if (package.HasPremiumBenefits)
                    {
                        <li><span class="material-symbols-outlined" aria-hidden="true">verified_user</span><span data-i18n="packages.profileEffect">Sở hữu hiệu ứng hồ sơ đặc biệt</span></li>
                        <li><span class="material-symbols-outlined" aria-hidden="true">support_agent</span><span data-i18n="packages.prioritySupport">Hỗ trợ ưu tiên, phản hồi nhanh hơn</span></li>
                    }
                    <li><span class="material-symbols-outlined" aria-hidden="true">check_circle</span><span><span data-i18n="packages.duration">Thời hạn:</span> <strong>@if (package.IsLifetime) { <span data-i18n="packages.lifetime">Vĩnh viễn</span> } else { @package.DurationDays <span data-i18n="packages.days">ngày</span> }</strong></span></li>
                </ul>

                <div class="package-membership__actions">
                    @if (package.IsCurrentPackage)
                    {
                        <a class="package-membership__button is-secondary" asp-page="/Subscriptions/Current">
                            <span class="material-symbols-outlined" aria-hidden="true">verified</span>
                            <span data-i18n="packages.viewCurrent">Xem gói hiện tại</span>
                        </a>
                    }
                    else if (package.IsDowngrade)
                    {
                        <button type="button" class="package-membership__button is-disabled" disabled aria-disabled="true">
                            <span class="material-symbols-outlined" aria-hidden="true">lock</span>
                            <span data-i18n="packages.cannotDowngrade">Không thể hạ gói</span>
                        </button>
                        @if (Model.CurrentSubscription?.IsLifetime == true)
                        {
                            <small class="package-membership__downgrade-note" data-i18n="packages.lifetimeNoDowngrade">Gói trọn đời không hỗ trợ hạ gói.</small>
                        }
                        else
                        {
                            <small class="package-membership__downgrade-note"><span data-i18n="packages.downgradeAfter">Bạn có thể chọn gói thấp hơn sau</span> <strong>@Model.CurrentSubscription?.ValidUntilLabel</strong>.</small>
                        }
                    }
                    else if (package.IsFree)
                    {
                        <form method="post" asp-page-handler="Checkout" data-checkout-form>
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="packageId" value="@package.Id" />
                            <input type="hidden" name="provider" value="@PaymentProvider.MoMo" />
                            <button type="submit" class="package-membership__button">
                                <span class="material-symbols-outlined" aria-hidden="true">auto_awesome</span>
                                <span data-i18n="packages.activateNow">Kích hoạt ngay</span>
                            </button>
                        </form>
                    }
                    else
                    {
                        <form method="post" asp-page-handler="Checkout" data-checkout-form>
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="packageId" value="@package.Id" />
                            <input type="hidden" name="provider" value="@PaymentProvider.PayOS" />
                            <button type="submit" class="package-membership__button">
                                <span class="material-symbols-outlined" aria-hidden="true">auto_awesome</span>
                                <span data-i18n="packages.selectPackage">Chọn gói này</span>
                            </button>
                        </form>
                    }
                </div>
            </article>
        }
    </div>
</section>
