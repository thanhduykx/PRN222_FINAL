@page
@using PRN222_FINAL.BLL.Models
@model PRN222_FINAL.Web.Pages.Packages.IndexModel
@{
    ViewData["Title"] = "Gói dịch vụ";
    ViewData["UseRblShell"] = true;
    ViewData["ActiveNav"] = "billing";
    ViewData["ShellTitle"] = "Gói dịch vụ";
}

<section class="ops-page package-membership">
    <header class="package-membership__hero">
        <div class="package-membership__symbols" aria-hidden="true">
            <span class="is-blue"><span class="material-symbols-outlined">school</span></span>
            <span class="is-teal"><span class="material-symbols-outlined">workspace_premium</span></span>
            <span class="is-violet"><span class="material-symbols-outlined">diamond</span></span>
        </div>
        <h1>Chọn gói học tập phù hợp</h1>
        <p>Nâng cấp số lượt hỏi đáp để học hiệu quả hơn cùng tài liệu môn học.</p>
        <a class="package-membership__current-link" asp-page="/Subscriptions/Current">
            <span class="material-symbols-outlined" aria-hidden="true">receipt_long</span>
            Xem gói hiện tại
        </a>
    </header>

    @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
    {
        <div class="rbl-alert is-error" role="alert">@Model.ErrorMessage</div>
    }

    @if (Model.CurrentSubscription is not null)
    {
        <section class="package-membership__active" aria-label="Gói đang sử dụng">
            <span class="material-symbols-outlined" aria-hidden="true">verified</span>
            <div>
                <span>Gói đang sử dụng</span>
                <strong>@Model.CurrentSubscription.PackageName</strong>
            </div>
            <p>Có hiệu lực đến @Model.CurrentSubscription.ValidUntilLabel</p>
            <span class="package-membership__active-badge">Đang hoạt động</span>
        </section>
    }

    <div class="package-membership__grid">
        @foreach (var package in Model.Packages)
        {
            var tone = package.IsLifetime || package.Code.Contains("ANNUAL", StringComparison.OrdinalIgnoreCase)
                ? "is-violet"
                : package.IsFree
                    ? "is-blue"
                    : package.Code.Contains("PRO", StringComparison.OrdinalIgnoreCase)
                        ? "is-violet"
                        : "is-teal";
            <article class="package-membership__card @tone @(package.IsCurrentPackage ? "is-current" : "")">
                <div class="package-membership__badges">
                    @if (package.DiscountPercent > 0)
                    {
                        <span class="package-membership__discount">Giảm @package.DiscountPercent%</span>
                    }
                    @if (package.IsCurrentPackage)
                    {
                        <span class="package-membership__featured">Đang sử dụng</span>
                    }
                    else if (package.IsStudent)
                    {
                        <span class="package-membership__featured">Phổ biến</span>
                    }
                </div>

                <div class="package-membership__icon" aria-hidden="true">
                    <span class="material-symbols-outlined">@(package.IsLifetime || package.Code.Contains("ANNUAL", StringComparison.OrdinalIgnoreCase) ? "diamond" : package.IsFree ? "school" : "workspace_premium")</span>
                </div>
                <span class="package-membership__code">@package.Code</span>
                <h2>@package.Name</h2>
                <div class="package-membership__price">
                    <strong>@(package.IsFree ? "Miễn phí" : $"{package.PriceVnd:N0}đ")</strong>
                    <span>@(package.IsFree ? "bắt đầu ngay" : package.IsLifetime ? "thanh toán một lần" : $"cho {package.DurationLabel}")</span>
                </div>
                <p class="package-membership__description">@package.Description</p>

                <ul class="package-membership__benefits">
                    <li><span class="material-symbols-outlined" aria-hidden="true">check_circle</span><span><strong>@package.MonthlyChatLimit.ToString("N0")</strong> câu hỏi mỗi tháng</span></li>
                    <li><span class="material-symbols-outlined" aria-hidden="true">check_circle</span><span>Trả lời dựa trên tài liệu môn học</span></li>
                    <li><span class="material-symbols-outlined" aria-hidden="true">check_circle</span><span>Lưu lịch sử và nguồn tham khảo</span></li>
                    @if (package.IsStudent)
                    {
                        <li><span class="material-symbols-outlined" aria-hidden="true">verified_user</span><span>Sở hữu hiệu ứng hồ sơ đặc biệt</span></li>
                        <li><span class="material-symbols-outlined" aria-hidden="true">support_agent</span><span>Hỗ trợ ưu tiên, phản hồi nhanh hơn</span></li>
                    }
                    <li><span class="material-symbols-outlined" aria-hidden="true">check_circle</span><span>Thời hạn: <strong>@package.DurationLabel</strong></span></li>
                </ul>

                <div class="package-membership__actions">
                    @if (package.IsCurrentPackage)
                    {
                        <a class="package-membership__button is-secondary" asp-page="/Subscriptions/Current">
                            <span class="material-symbols-outlined" aria-hidden="true">verified</span>
                            Xem gói hiện tại
                        </a>
                    }
                    else if (package.IsFree)
                    {
                        <form method="post" asp-page-handler="Checkout">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="packageId" value="@package.Id" />
                            <input type="hidden" name="provider" value="@PaymentProvider.MoMo" />
                            <button type="submit" class="package-membership__button">
                                <span class="material-symbols-outlined" aria-hidden="true">auto_awesome</span>
                                Kích hoạt ngay
                            </button>
                        </form>
                    }
                    else
                    {
                        var paymentPanelId = $"payment-options-{package.Id:N}";
                        <button type="button" class="package-membership__button" data-payment-toggle="@paymentPanelId" aria-controls="@paymentPanelId" aria-expanded="false">
                            <span class="material-symbols-outlined" aria-hidden="true">auto_awesome</span>
                            Chọn gói này
                        </button>
                        <div id="@paymentPanelId" class="package-membership__payment-options" hidden>
                            <p>Chọn phương thức thanh toán</p>
                            <form method="post" asp-page-handler="Checkout">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="packageId" value="@package.Id" />
                                <input type="hidden" name="provider" value="@PaymentProvider.MoMo" />
                                <button type="submit" class="package-membership__payment-option is-momo">
                                    <img src="~/img/payments/momo.svg" alt="" />
                                    <span><strong>Ví MoMo</strong><small>Thanh toán qua ứng dụng MoMo</small></span>
                                    <span class="material-symbols-outlined" aria-hidden="true">chevron_right</span>
                                </button>
                            </form>
                            <form method="post" asp-page-handler="Checkout">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="packageId" value="@package.Id" />
                                <input type="hidden" name="provider" value="@PaymentProvider.PayOS" />
                                <button type="submit" class="package-membership__payment-option is-payos">
                                    <img src="~/img/payments/payos.svg" alt="" />
                                    <span><strong>PayOS</strong><small>Quét mã QR bằng ứng dụng ngân hàng</small></span>
                                    <span class="material-symbols-outlined" aria-hidden="true">chevron_right</span>
                                </button>
                            </form>
                        </div>
                    }
                </div>
            </article>
        }
    </div>
</section>
