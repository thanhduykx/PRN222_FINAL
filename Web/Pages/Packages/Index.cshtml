@page
@using PRN222_FINAL.Models
@model PRN222_FINAL.Web.Pages.Packages.IndexModel
@{
    ViewData["Title"] = "Gói dịch vụ";
    ViewData["UseRblShell"] = true;
    ViewData["ActiveNav"] = "billing";
    ViewData["ShellTitle"] = "Gói dịch vụ";
}

<section class="ops-page package-cinema">
    <div class="ops-page-header package-cinema-hero">
        <div>
            <span class="ops-eyebrow">Billing</span>
            <h1>Gói dịch vụ</h1>
            <p>Chọn gói sử dụng cho chatbot RAG theo môn học. Giá luôn lấy từ server, không tin dữ liệu từ trình duyệt.</p>
        </div>
        <div class="ops-panel-actions">
            <a class="ops-button ops-button--secondary" asp-page="/Subscriptions/Current">
                <span class="material-symbols-outlined" aria-hidden="true">receipt_long</span>
                Gói hiện tại
            </a>
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
    {
        <div class="rbl-alert is-error">@Model.ErrorMessage</div>
    }

    @if (Model.CurrentSubscription is not null)
    {
        <section class="ops-panel mb-4">
            <div class="ops-panel-head">
                <div>
                    <h2>Đang sử dụng: @Model.CurrentSubscription.PackageName</h2>
                    <p class="ops-muted mb-0">Có hiệu lực đến @Model.CurrentSubscription.ValidUntilLabel.</p>
                </div>
                <span class="rbl-status is-success">@Model.CurrentSubscription.Status</span>
            </div>
        </section>
    }

    <div class="row g-3 package-plan-grid">
        @foreach (var package in Model.Packages)
        {
            <div class="col-12 col-md-4 package-plan-column">
                <article class="ops-command-card h-100 package-plan-card @(package.IsCurrentPackage ? "is-current" : "") @(package.IsLifetime ? "is-lifetime" : "")">
                    <span class="package-plan-card__accent" aria-hidden="true"></span>
                    <div class="card-body d-flex flex-column">
                        <div class="d-flex align-items-start justify-content-between gap-3">
                            <div>
                                <span class="ops-eyebrow">@package.Code</span>
                                <h2 class="h5 mb-1">@package.Name</h2>
                            </div>
                            @if (package.IsCurrentPackage)
                            {
                                <span class="rbl-status is-success">Đang dùng</span>
                            }
                            else
                            {
                                <strong class="fs-5">@(package.IsFree ? "Miễn phí" : $"{package.PriceVnd:N0} VND")</strong>
                            }
                        </div>
                        <p class="ops-muted mt-3">@package.Description</p>
                        <div class="package-plan-meter" aria-hidden="true">
                            <span></span>
                        </div>
                        <ul class="list-unstyled small mb-4 ops-stack">
                            <li><strong>@package.MonthlyChatLimit.ToString("N0")</strong> lượt chat/tháng</li>
                            <li><strong>@package.DurationLabel</strong> thời hạn sử dụng</li>
                        </ul>
                        @if (package.IsCurrentPackage)
                        {
                            <a class="ops-button ops-button--secondary mt-auto" asp-page="/Subscriptions/Current">
                                <span class="material-symbols-outlined" aria-hidden="true">verified</span>
                                Xem gói hiện tại
                            </a>
                        }
                        else
                        {
                            <div class="mt-auto d-grid gap-2">
                                <form method="post" asp-page-handler="Checkout">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="packageId" value="@package.Id" />
                                    <input type="hidden" name="provider" value="@PaymentProvider.MoMo" />
                                    <button type="submit" class="ops-button ops-button--primary w-100">
                                        <span class="material-symbols-outlined" aria-hidden="true">account_balance_wallet</span>
                                        @(package.IsFree ? "Kích hoạt miễn phí" : "Thanh toán MoMo")
                                    </button>
                                </form>
                                @if (!package.IsFree)
                                {
                                    <form method="post" asp-page-handler="Checkout">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="packageId" value="@package.Id" />
                                        <input type="hidden" name="provider" value="@PaymentProvider.PayOS" />
                                        <button type="submit" class="ops-button ops-button--secondary w-100">
                                            <span class="material-symbols-outlined" aria-hidden="true">qr_code_2</span>
                                            Thanh toán PayOS
                                        </button>
                                    </form>
                                    <a class="ops-mini-button text-center" asp-page="/Payments/Checkout" asp-route-packageId="@package.Id">Xem checkout chi tiết</a>
                                }
                            </div>
                        }
                    </div>
                </article>
            </div>
        }
    </div>
</section>
