    @if (isCreateSubject)
    {
        @* === CREATE SUBJECT: Thêm môn === *@
        <section class="ops-panel">
            <div class="ops-panel-head">
                <div>
                    <span class="ops-eyebrow" data-i18n="admin.navCreateSubject">Create subject</span>
                    <h2 data-i18n="admin.navCreateSubject">Thêm môn</h2>
                </div>
            </div>
            <form asp-page-handler="CreateSubject" method="post" class="ops-stacked-form">
                @Html.AntiForgeryToken()
                <label class="ops-field">
                    <span data-i18n="admin.subjectCode">Subject code</span>
                    <input name="Code" maxlength="32" placeholder="VD: IOT102" data-i18n-placeholder="admin.subjectCodePlaceholder" autocomplete="off" />
                </label>
                <label class="ops-field">
                    <span data-i18n="admin.description">Description</span>
                    <input name="Description" maxlength="1000" placeholder="Optional" data-i18n-placeholder="admin.optional" autocomplete="off" />
                </label>
                <div style="margin-top: 1rem;">
                    <button type="submit" class="ops-button ops-button--primary">
                        <span data-i18n="admin.navCreateSubject">Create subject</span>
                    </button>
                </div>
            </form>

            <div class="ops-panel-head" style="border-top: 1px solid var(--admin-border); margin-top: 1rem;">
                <div>
                    <span class="ops-eyebrow" data-i18n="admin.overview">Overview</span>
                    <h2 data-i18n="admin.subjectList">Subject List / Danh sách môn học</h2>
                </div>
                <span class="ops-panel-note">@Model.SubjectOptions.Count <span data-i18n="admin.subjectsUnit">subjects</span></span>
            </div>

            @if (Model.SubjectOptions.Count == 0)
            {
                <div class="ops-empty">
                    <strong data-i18n="admin.noSubjects">No subjects found.</strong>
                    <p data-i18n="admin.createSubjectPrompt">Create a subject above.</p>
                </div>
            }
            else
            {
                <div class="ops-table-wrap">
                    <table class="ops-table">
                        <caption class="visually-hidden" data-i18n="admin.subjectTableCaption">Danh sách môn học và người phụ trách</caption>
                        <thead>
                            <tr>
                                <th data-i18n="admin.thSubject">SUBJECT</th>
                                <th data-i18n="admin.thLeader">LEADER</th>
                                <th data-i18n="admin.thStatus">STATUS</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var subject in Model.SubjectOptions)
                            {
                                <tr class="@(subject.IsActive ? "" : "ops-muted-row")" style="@(!subject.IsActive ? "opacity: 0.6;" : "")">
                                    <td data-label="SUBJECT" data-i18n-data-label="admin.thSubject">
                                        <strong style="color: var(--admin-text-main); font-size: 0.95rem;">@subject.DisplayName</strong>
                                    </td>
                                    <td data-label="LEADER" data-i18n-data-label="admin.thLeader">
                                        @if (string.IsNullOrWhiteSpace(subject.OwnerName))
                                        {
                                            <span style="color: var(--admin-text-muted); font-size: 0.875rem;" data-i18n="admin.noneLeader">None</span>
                                        }
                                        else
                                        {
                                            <div class="ops-user-identity">
                                                <strong>@subject.OwnerName</strong>
                                                <small>@subject.OwnerEmail</small>
                                            </div>
                                        }
                                    </td>
                                    <td data-label="STATUS" data-i18n-data-label="admin.thStatus">
                                        @if (subject.IsActive)
                                        {
                                            <span class="ops-chip" style="background-color: #ecfdf5; color: #065f46;" data-i18n="admin.active">Active</span>
                                        }
                                        else
                                        {
                                            <span class="ops-chip" style="background-color: #fef2f2; color: #991b1b;" data-i18n="admin.inactive">Inactive</span>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </section>
    }
</section>
