                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="UserId" value="@student.Id" />
                                                <select name="SubjectId" required disabled="@(availableSubjects.Count == 0)" aria-label="Đăng ký môn cho @DisplayName(student)" style="padding: 0.35rem 0.5rem; border: 1px solid var(--admin-border); border-radius: 6px; font-size: 0.75rem;">
                                                    @if (availableSubjects.Count == 0)
                                                    {
                                                        <option value="" data-i18n="admin.noSubjectsAvailable">Không có môn nào</option>
                                                    }
                                                    else
                                                    {
                                                        <option value="" data-i18n="admin.selectSubjectAssign">Chọn môn để đăng ký</option>
                                                    }
                                                    @foreach (var subject in availableSubjects)
                                                    {
                                                        <option value="@subject.Id">@subject.DisplayName</option>
