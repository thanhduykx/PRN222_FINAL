@page "{section?}"
@model PRN222_FINAL.Web.Pages.Admin.IndexModel
@{
    ViewData["Title"] = "Users";
    ViewData["UseRblShell"] = true;
    ViewData["ActiveNav"] = "admin";
    ViewData["ShellTitle"] = "Users";
    ViewData["ShellTitleI18n"] = "admin.usersTitle";

    var section = Model.CurrentSection;
    var isDirectory = section == IndexModel.AdminSection.Directory;
    var isCreateAccount = section == IndexModel.AdminSection.CreateAccount;
    var isBulkImport = section == IndexModel.AdminSection.BulkImport;
    var isCreateSubject = section == IndexModel.AdminSection.CreateSubject;
    var isLecturerTable = section == IndexModel.AdminSection.LecturerTable;
    var showStudentTable = false;
    var isStudentTable = showStudentTable && section == IndexModel.AdminSection.StudentTable;

    var users = Model.Users
        .OrderBy(user => user.Role)
        .ThenBy(user => user.FullName)
        .ThenBy(user => user.Email)
        .ToList();
    var hasActiveFilters = !string.IsNullOrWhiteSpace(Model.Query)
        || !string.IsNullOrWhiteSpace(Model.RoleFilter);
    var unassignedSubjects = Model.SubjectOptions
        .Where(subject => !subject.OwnerUserId.HasValue)
        .OrderBy(subject => subject.DisplayName)
        .ToList();

    string DisplayName(PRN222_FINAL.Web.Models.AdminUserRowViewModel user)
    {
        return string.IsNullOrWhiteSpace(user.FullName) ? user.Email : user.FullName;
    }

    string Initials(PRN222_FINAL.Web.Models.AdminUserRowViewModel user)
    {
        var source = DisplayName(user).Trim();
        if (string.IsNullOrWhiteSpace(source)) return "U";
        var parts = source.Split(' ', StringSplitOptions.RemoveEmptyEntries);
        if (parts.Length >= 2) return $"{parts[0][0]}{parts[^1][0]}".ToUpperInvariant();
        return source[..1].ToUpperInvariant();
    }
}

<style>
    /* BỘ CSS HIỆN ĐẠI HÓA GIAO DIỆN ADMIN */
    :root {
        --admin-primary: #4F46E5;
        --admin-primary-hover: #4338ca;
        --admin-surface: #ffffff;
        --admin-bg: #f3f4f6;
        --admin-text-main: #111827;
        --admin-text-muted: #6b7280;
        --admin-border: #e5e7eb;
        --radius-xl: 16px;
        --radius-lg: 12px;
        --radius-md: 8px;
        --shadow-sm: 0 1px 2px 0 rgba(0, 0, 0, 0.05);
        --shadow-md: 0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -1px rgba(0, 0, 0, 0.06);
    }

    .ops-admin-page {
        font-family: 'Inter', system-ui, sans-serif;
        background-color: var(--admin-bg);
        padding: 2rem;
        min-height: 100vh;
        color: var(--admin-text-main);
    }

    /* KPI Grid Cards */
    .ops-admin-kpis {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
        gap: 1.5rem;
        margin-bottom: 2rem;
    }

    .ops-kpi {
        background: var(--admin-surface);
        padding: 1.5rem;
        border-radius: var(--radius-lg);
        box-shadow: var(--shadow-sm);
        border: 1px solid var(--admin-border);
        display: flex;
        flex-direction: column;
        transition: transform 0.2s, box-shadow 0.2s;
    }

        .ops-kpi:hover {
            transform: translateY(-2px);
            box-shadow: var(--shadow-md);
        }

        .ops-kpi span {
            font-size: 0.875rem;
            font-weight: 600;
            color: var(--admin-text-muted);
            text-transform: uppercase;
            letter-spacing: 0.05em;
            margin-bottom: 0.5rem;
        }

        .ops-kpi strong {
            font-size: 2.25rem;
            font-weight: 800;
            color: var(--admin-text-main);
            line-height: 1;
            margin-bottom: 0.5rem;
        }

        .ops-kpi small {
            font-size: 0.875rem;
            color: #9ca3af;
        }

    /* Panels / Cards */
    .ops-panel {
        background: var(--admin-surface);
        border-radius: var(--radius-lg);
        box-shadow: var(--shadow-sm);
        border: 1px solid var(--admin-border);
        margin-bottom: 2rem;
        overflow: hidden;
    }

    .ops-panel-head {
        padding: 1.5rem 1.5rem 1rem;
        border-bottom: 1px solid var(--admin-border);
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
    }

    .ops-eyebrow {
        color: var(--admin-primary);
        font-size: 0.875rem;
        font-weight: 600;
        text-transform: uppercase;
        margin-bottom: 0.25rem;
        display: block;
    }

    .ops-panel-head h2 {
        font-size: 1.5rem;
        font-weight: 700;
        margin: 0;
        color: var(--admin-text-main);
    }

    .ops-panel-note {
        background: #f3f4f6;
        padding: 0.25rem 0.75rem;
        border-radius: 9999px;
        font-size: 0.875rem;
        font-weight: 500;
        color: var(--admin-text-muted);
    }

    /* Filter Bar */
    .ops-filter-bar {
        padding: 1rem 1.5rem;
        background: #f9fafb;
        border-bottom: 1px solid var(--admin-border);
        display: flex;
        gap: 1rem;
        align-items: flex-end;
        flex-wrap: wrap;
    }

    .ops-field {
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
        flex: 1;
        min-width: 200px;
    }

        .ops-field span {
            font-size: 0.875rem;
            font-weight: 500;
            color: var(--admin-text-main);
        }

        .ops-field input, .ops-field select {
            padding: 0.625rem 1rem;
            border: 1px solid #d1d5db;
            border-radius: var(--radius-md);
            font-size: 0.875rem;
            transition: all 0.2s;
            box-shadow: inset 0 1px 2px rgba(0, 0, 0, 0.05);
        }

            .ops-field input:focus, .ops-field select:focus {
                border-color: var(--admin-primary);
                outline: none;
                box-shadow: 0 0 0 3px rgba(79, 70, 229, 0.15);
            }

    /* Tables */
    .ops-table-wrap {
        overflow-x: auto;
    }

    .ops-table {
        width: 100%;
        border-collapse: collapse;
        text-align: left;
    }

        .ops-table th {
            background-color: #f9fafb;
            padding: 1rem 1.5rem;
            font-size: 0.75rem;
            font-weight: 600;
            color: var(--admin-text-muted);
            text-transform: uppercase;
            letter-spacing: 0.05em;
            border-bottom: 1px solid var(--admin-border);
        }

        .ops-table td {
            padding: 1rem 1.5rem;
            border-bottom: 1px solid var(--admin-border);
            vertical-align: middle;
        }

        .ops-table tbody tr:hover {
            background-color: #f9fafb;
        }

        .ops-table tbody tr:last-child td {
            border-bottom: none;
        }

    /* Avatars & Users */
    .ops-user-cell {
        display: flex;
        align-items: center;
        gap: 1rem;
    }

    .ops-avatar {
        width: 40px;
        height: 40px;
        border-radius: 50%;
        background: #e0e7ff;
        color: var(--admin-primary);
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 700;
        font-size: 0.875rem;
        flex-shrink: 0;
    }

    .ops-user-identity strong {
        display: block;
        font-weight: 600;
        color: var(--admin-text-main);
        font-size: 0.95rem;
    }

    .ops-user-identity small {
        color: var(--admin-text-muted);
        font-size: 0.875rem;
    }

    /* Chips & Badges */
    .ops-role-badge {
        display: inline-flex;
        padding: 0.25rem 0.75rem;
        border-radius: 9999px;
        font-size: 0.75rem;
        font-weight: 600;
        background: #f3f4f6;
        color: #374151;
        text-transform: uppercase;
        letter-spacing: 0.05em;
    }

    .ops-chip-list {
        display: flex;
        flex-wrap: wrap;
        gap: 0.5rem;
    }

    .ops-chip {
        display: inline-flex;
        align-items: center;
        background: #e0e7ff;
        color: var(--admin-primary);
        padding: 0.35rem 0.75rem;
        border-radius: var(--radius-md);
        font-size: 0.875rem;
        font-weight: 500;
    }

    .ops-chip--muted {
        background: #f3f4f6;
        color: var(--admin-text-muted);
    }

    /* Buttons */
    .ops-button {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 0.5rem;
        padding: 0.625rem 1.25rem;
        font-size: 0.875rem;
        font-weight: 500;
        border-radius: var(--radius-md);
        border: none;
        cursor: pointer;
        transition: all 0.2s;
    }

    .ops-button--primary {
        background: var(--admin-primary);
        color: white;
        box-shadow: var(--shadow-sm);
    }

        .ops-button--primary:hover {
            background: var(--admin-primary-hover);
            transform: translateY(-1px);
        }

    .ops-button--secondary {
        background: white;
        color: var(--admin-text-main);
        border: 1px solid #d1d5db;
        box-shadow: var(--shadow-sm);
    }

        .ops-button--secondary:hover {
            background: #f9fafb;
            border-color: #9ca3af;
        }

    .ops-button--ghost {
        background: transparent;
        color: var(--admin-text-muted);
    }

        .ops-button--ghost:hover {
            background: #f3f4f6;
            color: var(--admin-text-main);
        }

    .ops-mini-button {
        padding: 0.35rem 0.75rem;
        font-size: 0.75rem;
        border-radius: 6px;
        font-weight: 600;
        cursor: pointer;
        border: 1px solid transparent;
        transition: all 0.2s;
    }

    .ops-mini-button--danger {
        background: #fef2f2;
        color: #dc2626;
        border-color: #fecaca;
    }

        .ops-mini-button--danger:hover:not(:disabled) {
            background: #fee2e2;
            border-color: #f87171;
        }

    .ops-mini-button:disabled {
        opacity: 0.5;
        cursor: not-allowed;
    }

    /* Forms in panels */
    .ops-stacked-form {
        padding: 1.5rem;
        display: flex;
        flex-direction: column;
        gap: 1.5rem;
        max-width: 600px;
    }

    .ops-subject-picker {
        border: 1px solid var(--admin-border);
        padding: 1rem;
        border-radius: var(--radius-md);
        background: #f9fafb;
    }

        .ops-subject-picker legend {
            font-weight: 600;
            color: var(--admin-text-main);
            padding: 0 0.5rem;
        }

    .ops-subject-options {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
        gap: 0.75rem;
        margin-top: 0.5rem;
    }

    .ops-subject-option {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        font-size: 0.875rem;
        cursor: pointer;
    }

    /* Empty States */
    .ops-empty {
        padding: 4rem 2rem;
        text-align: center;
        color: var(--admin-text-muted);
    }

        .ops-empty strong {
            display: block;
            font-size: 1.125rem;
            color: var(--admin-text-main);
            margin-bottom: 0.5rem;
        }

    /* Alerts */
    .rbl-alert {
        padding: 1rem;
        border-radius: var(--radius-md);
        margin-bottom: 1.5rem;
        font-weight: 500;
        font-size: 0.875rem;
    }

        .rbl-alert.is-success {
            background: #ecfdf5;
            color: #065f46;
            border: 1px solid #a7f3d0;
        }

        .rbl-alert.is-error {
            background: #fef2f2;
            color: #991b1b;
            border: 1px solid #fecaca;
        }
</style>

<section class="ops-page ops-admin-page">
    @if (TempData["Success"] is string success)
    {
        <div class="rbl-alert is-success">@success</div>
    }
    @if (TempData["Error"] is string error)
    {
        <div class="rbl-alert is-error">@error</div>
    }

    @if (isDirectory)
    {
        @* === DIRECTORY: Bảng người dùng / User table === *@
        <section class="ops-kpi-grid ops-admin-kpis" aria-label="User metrics">
            <article class="ops-kpi">
                <span data-i18n="admin.totalUsers">Total users</span>
                <strong>@Model.TotalUserCount</strong>
                <small>@users.Count <span data-i18n="admin.usersShown">shown</span></small>
            </article>
            <article class="ops-kpi">
                <span data-i18n="admin.admins">Admins</span>
                <strong>@Model.AdminUserCount</strong>
                <small data-i18n="admin.fullSystemAccess">Full system access</small>
            </article>
            <article class="ops-kpi">
                <span data-i18n="admin.lecturers">Lecturers</span>
                <strong>@Model.LecturerUserCount</strong>
                <small data-i18n="admin.manageSubjects">Manage assigned subjects</small>
            </article>
            <article class="ops-kpi">
                <span data-i18n="admin.students">Students</span>
                <strong>@Model.StudentUserCount</strong>
                <small data-i18n="admin.readChatAccess">Read and chat access</small>
            </article>
            <article class="ops-kpi">
                <span data-i18n="admin.subjects">Subjects</span>
                <strong>@Model.SubjectCount</strong>
                <small>@Model.AssignedSubjectCount <span data-i18n="admin.subjectsAssigned">assigned</span></small>
            </article>
        </section>

        <section class="ops-panel">
            <div class="ops-panel-head">
                <div>
                    <span class="ops-eyebrow" data-i18n="admin.directory">Directory</span>
                    <h2>Bảng người dùng / User table</h2>
                </div>
                <span class="ops-panel-note">@users.Count/@Model.TotalUserCount <span data-i18n="admin.usersUnit">users</span></span>
            </div>

            <form asp-page="/Admin/Index" method="get" class="ops-filter-bar ops-admin-filter" asp-route-section="directory">
                <label class="ops-field ops-field--search">
                    <span data-i18n="admin.searchDirectory">Search / Tìm kiếm</span>
                    <input name="q" value="@Model.Query" placeholder="Name, email, provider, subject..." data-i18n-placeholder="admin.searchDirectoryPlaceholder" />
                </label>
                <label class="ops-field">
                    <span data-i18n="admin.roleFilter">Role / Vai trò</span>
                    <select name="roleFilter">
                        @if (string.IsNullOrWhiteSpace(Model.RoleFilter))
                        {
                            <option value="" selected data-i18n="admin.allRoles">All roles</option>
                        }
                        else
                        {
                            <option value="" data-i18n="admin.allRoles">All roles</option>
                        }
                        @foreach (var role in Model.Roles)
                        {
                            if (role.Equals(Model.RoleFilter, StringComparison.OrdinalIgnoreCase))
                            {
                                <option value="@role" selected>@role</option>
                            }
                            else
                            {
                                <option value="@role">@role</option>
                            }
                        }
                    </select>
                </label>
                <div style="display: flex; gap: 0.5rem; align-items: flex-end; padding-bottom: 2px;">
                    <button type="submit" class="ops-button ops-button--secondary" data-i18n="admin.filter">Filter</button>
                    @if (hasActiveFilters)
                    {
                        <a class="ops-button ops-button--ghost" asp-page="/Admin/Index" asp-route-section="directory" data-i18n="admin.clear">Clear</a>
                    }
                </div>
            </form>

            @if (users.Count == 0)
            {
                <div class="ops-empty">
                    <strong data-i18n="admin.noMatchingUsers">No matching users.</strong>
                    <p data-i18n="admin.noMatchingUsersHint">Clear filters or create a new account from the command panel.</p>
                </div>
            }
            else
            {
                <div class="ops-table-wrap">
                    <table class="ops-table ops-user-table">
                        <thead>
                            <tr>
                                <th data-i18n="admin.thUser">User</th>
                                <th data-i18n="admin.thCreated">Created</th>
                                <th data-i18n="admin.thRole">Role / Vai trò</th>
                                <th data-i18n="admin.thSubjects">Subjects</th>
                                <th data-i18n="admin.thActions" style="text-align: right;">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var user in users)
                            {
                                <tr>
                                    <td data-label="User">
                                        <div class="ops-user-cell">
                                            <span class="ops-avatar">@Initials(user)</span>
                                            <div class="ops-user-identity">
                                                <strong>@DisplayName(user)</strong>
                                                <small>@user.Email</small>
                                            </div>
                                        </div>
                                    </td>
                                    <td data-label="Created">
                                        <span style="color: var(--admin-text-muted); font-size: 0.875rem;">@user.CreatedAt.LocalDateTime.ToString("yyyy-MM-dd HH:mm")</span>
                                    </td>
                                    <td data-label="Role / Vai trò">
                                        <span class="ops-role-badge">@user.Role</span>
                                    </td>
                                    <td data-label="Subjects">
                                        @if (user.Role == PRN222_FINAL.Web.Security.AppRoles.Lecturer)
                                        {
                                            <div class="ops-subject-cell">
                                                <div class="ops-chip-list">
                                                    @if (user.AssignedSubjectDetails.Count == 0)
                                                    {
                                                        <span class="ops-chip ops-chip--muted" data-i18n="admin.unassignedSubject">Chưa đăng ký môn</span>
                                                    }
                                                    else
                                                    {
                                                        foreach (var subject in user.AssignedSubjectDetails)
                                                        {
                                                            <span class="ops-chip" title="Đã assign - không thể gỡ">
                                                                <span>@subject.DisplayName</span>
                                                            </span>
                                                        }
                                                    }
                                                </div>
                                            </div>
                                        }
                                        else if (user.Role == PRN222_FINAL.Web.Security.AppRoles.Student)
                                        {
                                            <span class="ops-chip" data-i18n="admin.allIndexedDocs">All indexed documents</span>
                                        }
                                        else
                                        {
                                            <span class="ops-chip ops-chip--muted" data-i18n="admin.notApplicable">Not applicable</span>
                                        }
                                    </td>
                                    <td data-label="Actions" style="text-align: right;">
                                        @{
                                            var deleteDisabled = user.IsLastAdmin
                                            || user.IsCurrentUser
                                            || (user.Role != PRN222_FINAL.Web.Security.AppRoles.Student && user.Role != PRN222_FINAL.Web.Security.AppRoles.Lecturer);
                                            var deleteTitle = user.IsCurrentUser
                                            ? "Cannot delete your own active account"
                                            : user.IsLastAdmin
                                            ? "Cannot delete the last admin"
                                            : "Delete user";
                                        }
                                        <form asp-page-handler="DeleteUser" method="post" class="ops-danger-form" data-confirm="Xóa người dùng này? Thao tác này không thể hoàn tác." style="display: inline-block;">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="UserId" value="@user.Id" />
                                            <button type="submit"
                                                    class="ops-mini-button ops-mini-button--danger"
                                                    disabled="@deleteDisabled"
                                                    title="@deleteTitle">
                                                <span data-i18n="admin.delete">Delete</span>
                                            </button>
                                        </form>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </section>
    }

    @if (isCreateAccount)
    {
        @* === CREATE ACCOUNT: Thêm user === *@
        <section class="ops-panel">
            <div class="ops-panel-head">
                <div>
                    <span class="ops-eyebrow" data-i18n="admin.navCreateAccount">Create account</span>
                    <h2 data-i18n="admin.createAccountHeading">Thêm user</h2>
                </div>
            </div>
            <form asp-page-handler="CreateUser" method="post" class="ops-stacked-form" data-admin-create-user-form data-admin-user-role-subject-form>
                @Html.AntiForgeryToken()
                <label class="ops-field">
                    <span data-i18n="admin.fullName">Full name</span>
                    <input name="FullName" maxlength="120" autocomplete="name" placeholder="Ví dụ: Nguyễn Văn A" />
                </label>
                <label class="ops-field">
                    <span data-i18n="admin.email">Email</span>
                    <input name="Email" type="email" autocomplete="email" placeholder="example@domain.com" />
                </label>
                <label class="ops-field">
                    <span data-i18n="admin.password">Password</span>
                    <input name="Password" type="password" minlength="8" autocomplete="new-password" placeholder="Tối thiểu 8 ký tự" />
                </label>
                <label class="ops-field">
                    <span data-i18n="admin.role">Role</span>
                    <select name="Role" data-admin-role-select>
                        @foreach (var role in Model.Roles)
                        {
                            if (role.Equals(PRN222_FINAL.Web.Security.AppRoles.Student, StringComparison.OrdinalIgnoreCase))
                            {
                                <option value="@role" data-i18n="admin.role@(role)" selected>@role</option>
                            }
                            else
                            {
                                <option value="@role" data-i18n="admin.role@(role)">@role</option>
                            }
                        }
                    </select>
                </label>
                <fieldset class="ops-field ops-subject-picker" data-lecturer-subject-picker>
                    <legend data-i18n="admin.subjectsForLecturer">Subjects for lecturer</legend>
                    @if (unassignedSubjects.Count == 0)
                    {
                        <span class="ops-muted" data-i18n="admin.noUnassignedSubjects" style="color: var(--admin-text-muted); font-size: 0.875rem;">No unassigned subjects</span>
                    }
                    else
                    {
                        <div class="ops-subject-options">
                            @foreach (var subject in unassignedSubjects)
                            {
                                <label class="ops-subject-option">
                                    <input type="checkbox" name="SubjectIds" value="@subject.Id" style="width: auto; box-shadow: none;" />
                                    <span>@subject.DisplayName</span>
                                </label>
                            }
                        </div>
                    }
                </fieldset>
                <div style="margin-top: 1rem;">
                    <button type="submit" class="ops-button ops-button--primary">
                        <span data-i18n="admin.createUserBtn">Create user</span>
                    </button>
                </div>
            </form>
        </section>
    }

    @if (isBulkImport)
    {
        @* === IMPORT EXCEL: Import users from Excel === *@
        <section class="ops-panel">
            <div class="ops-panel-head">
                <div>
                    <span class="ops-eyebrow" data-i18n="admin.importExcelEyebrow">Excel</span>
                    <h2 data-i18n="admin.importExcelTitle">Import from Excel</h2>
                </div>
            </div>
            <form asp-page-handler="ImportUsers" method="post" enctype="multipart/form-data" class="ops-stacked-form" data-admin-user-role-subject-form data-confirm-en="Create these users in bulk and send welcome emails?" data-confirm-vi="Tạo người dùng hàng loạt và gửi email chào mừng?">
                @Html.AntiForgeryToken()
                <input type="hidden" name="Role" value="@PRN222_FINAL.Web.Security.AppRoles.Student" />
                <label class="ops-field">
                    <span data-i18n="admin.excelFile">Excel file</span>
                    <input name="ExcelFile" type="file" accept=".xlsx" required style="padding: 0.5rem;" />
                    <small data-i18n="admin.excelImportHint">The system automatically extracts the full name and email columns.</small>
                </label>
                <div style="margin-top: 1rem;">
                    <button type="submit" class="ops-button ops-button--primary">
                        <span data-i18n="admin.importUsers">Import users</span>
                    </button>
                </div>
                <small style="color: var(--admin-text-muted);" data-i18n="admin.importWelcomeNote">Welcome emails will include each user's role and subject access.</small>
            </form>
        </section>
    }

    @if (isLecturerTable)
    {
        @* === LECTURER TABLE: Danh sách giảng viên === *@
        <section class="ops-panel">
            <div class="ops-panel-head">
                <div>
                    <span class="ops-eyebrow" data-i18n="admin.lecturerManagement">Lecturer management</span>
                    <h2 data-i18n="admin.lecturerTableHeading">Lecturer Table / Bảng giảng viên</h2>
                </div>
                <span class="ops-panel-note">@Model.LecturerUserCount <span data-i18n="admin.lecturersUnit">lecturers</span></span>
            </div>

            @{
                var lecturers = users.Where(u => u.Role == PRN222_FINAL.Web.Security.AppRoles.Lecturer).ToList();
            }
            @if (lecturers.Count == 0)
            {
                <div class="ops-empty">
                    <strong data-i18n="admin.noLecturersFound">No lecturers found.</strong>
                    <p data-i18n="admin.createLecturerHint">Create a lecturer account first.</p>
                </div>
            }
            else
            {
                <div class="ops-table-wrap">
                    <table class="ops-table" style="min-width: 600px;">
                        <thead>
                            <tr>
                                <th style="width: 260px;" data-i18n="admin.thName">NAME</th>
                                <th data-i18n="admin.thSubjects">SUBJECTS</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var lecturer in lecturers)
                            {
                                var assignedSubjectIds = lecturer.AssignedSubjectDetails
                                .Select(subject => subject.Id)
                                .ToHashSet();
                                var availableSubjects = Model.SubjectOptions
                                .Where(subject => !subject.OwnerUserId.HasValue && !assignedSubjectIds.Contains(subject.Id))
                                .ToList();

                                <tr>
                                    <td data-label="NAME" style="width: 260px;">
                                        <div class="ops-user-cell" style="min-width: 0;">
                                            <span class="ops-avatar">@Initials(lecturer)</span>
                                            <div class="ops-user-identity">
                                                <strong>@DisplayName(lecturer)</strong>
                                                <small>@lecturer.Email</small>
                                            </div>
                                        </div>
                                    </td>
                                    <td data-label="Subjects">
                                        <div class="ops-subject-cell" style="display: flex; gap: 1rem; align-items: flex-start; flex-wrap: wrap;">
                                            <div class="ops-chip-list">
                                                @if (lecturer.AssignedSubjectDetails.Count == 0)
                                                {
                                                    <span class="ops-chip ops-chip--muted" data-i18n="admin.unassignedSubject">Chưa đăng ký môn</span>
                                                }
                                                else
                                                {
                                                    foreach (var subject in lecturer.AssignedSubjectDetails)
                                                    {
                                                        <div class="ops-chip" style="display: inline-flex; align-items: center; padding-right: 6px;" title="Đã assign - click X để gỡ">
                                                            <span>@subject.DisplayName@(subject.IsLeader? Html.Raw("<span data-i18n=\"admin.subjectLeaderSuffix\"> (Trưởng bộ môn)</span>") : Html.Raw(""))</span>

                                                            <form asp-page-handler="UnregisterLecturerSubject" method="post" class="ops-inline-form" style="margin: 0; padding: 0; display: flex; align-items: center;" data-confirm="Gỡ môn @subject.DisplayName khỏi @DisplayName(lecturer)?">
                                                                @Html.AntiForgeryToken()
                                                                <input type="hidden" name="UserId" value="@lecturer.Id" />
                                                                <input type="hidden" name="SubjectId" value="@subject.Id" />
                                                                <button type="submit" title="Gỡ môn" style="background: none; border: none; cursor: pointer; font-weight: bold; margin-left: 6px; color: inherit; opacity: 0.7; display: flex; align-items: center; padding: 0; font-size: 14px;">
                                                                    &times;
                                                                </button>
                                                            </form>
                                                        </div>
                                                    }
                                                }
                                            </div>
                                            <form asp-page-handler="RegisterLecturerSubject" method="post" class="ops-assign-form" style="display: flex; gap: 0.5rem;" data-confirm="Đăng ký môn đã chọn cho @DisplayName(lecturer)?">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="UserId" value="@lecturer.Id" />
                                                <select name="SubjectId" required disabled="@(availableSubjects.Count == 0)" aria-label="Đăng ký môn cho @DisplayName(lecturer)" style="padding: 0.35rem 0.5rem; border: 1px solid var(--admin-border); border-radius: 6px; font-size: 0.75rem;">
                                                    @if (availableSubjects.Count == 0)
                                                    {
                                                        <option value="" data-i18n="admin.noSubjectsAvailable">Không có môn nào</option>
                                                    }
                                                    else
                                                    {
                                                        <option value="" data-i18n="admin.selectSubjectAssign">Chọn môn để đăng ký</option>
                                                    }
                                                    @foreach (var subject in availableSubjects)
                                                    {
                                                        <option value="@subject.Id">@subject.DisplayName</option>
                                                    }
                                                </select>
                                                <button type="submit" class="ops-button ops-button--secondary" style="padding: 0.35rem 0.75rem; font-size: 0.75rem;" disabled="@(availableSubjects.Count == 0)" data-i18n="admin.assignButton">Đăng ký</button>
                                            </form>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </section>
    }

