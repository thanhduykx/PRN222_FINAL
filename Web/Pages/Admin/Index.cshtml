@page "{section?}"
@model PRN222_FINAL.Web.Pages.Admin.IndexModel
@{
    ViewData["Title"] = "Users";
    ViewData["UseRblShell"] = true;
    ViewData["ActiveNav"] = "admin";
    ViewData["ShellTitle"] = "Users";
    ViewData["ShellTitleI18n"] = "admin.shellTitleUsers";
    ViewData["ShellTitleI18n"] = "admin.usersTitle";

    var section = Model.CurrentSection;
    var isDirectory = section == IndexModel.AdminSection.Directory;
    var isCreateAccount = section == IndexModel.AdminSection.CreateAccount;
    var isBulkImport = section == IndexModel.AdminSection.BulkImport;
    var isCreateSubject = section == IndexModel.AdminSection.CreateSubject;
    var isLecturerTable = section == IndexModel.AdminSection.LecturerTable;
    var showStudentTable = false;
    var isStudentTable = showStudentTable && section == IndexModel.AdminSection.StudentTable;

    var users = Model.Users
        .OrderBy(user => user.Role)
        .ThenBy(user => user.FullName)
        .ThenBy(user => user.Email)
        .ToList();
    var hasActiveFilters = !string.IsNullOrWhiteSpace(Model.Query)
        || !string.IsNullOrWhiteSpace(Model.RoleFilter);
    var unassignedSubjects = Model.SubjectOptions
        .Where(subject => !subject.OwnerUserId.HasValue)
        .OrderBy(subject => subject.DisplayName)
        .ToList();
    var deletionEligibleUsers = users.Count(user =>
        user.MeetsInactivePeriod
        && !user.HasAssignedSubjects
        && !user.IsLastAdmin
        && !user.IsCurrentUser);

    string DisplayName(PRN222_FINAL.Web.Models.AdminUserRowViewModel user)
    {
        return string.IsNullOrWhiteSpace(user.FullName) ? user.Email : user.FullName;
    }

    string Initials(PRN222_FINAL.Web.Models.AdminUserRowViewModel user)
    {
        var source = DisplayName(user).Trim();
        if (string.IsNullOrWhiteSpace(source)) return "U";
        var parts = source.Split(' ', StringSplitOptions.RemoveEmptyEntries);
        if (parts.Length >= 2) return $"{parts[0][0]}{parts[^1][0]}".ToUpperInvariant();
        return source[..1].ToUpperInvariant();
    }

    string AdminTabClass(IndexModel.AdminSection tab) => section == tab ? "ops-tab is-active" : "ops-tab";
    string RoleLabel(string role) => role switch
    {
        PRN222_FINAL.BLL.Security.AppRoles.Admin => "Quản trị viên",
        PRN222_FINAL.BLL.Security.AppRoles.Lecturer => "Giảng viên",
        PRN222_FINAL.BLL.Security.AppRoles.Student => "Sinh viên",
        _ => role
    };
}

<style>
    /* BỘ CSS HIỆN ĐẠI HÓA GIAO DIỆN ADMIN */
    :root {
        --admin-primary: #4F46E5;
        --admin-primary-hover: #4338ca;
        --admin-surface: #ffffff;
        --admin-bg: #f3f4f6;
        --admin-text-main: #111827;
        --admin-text-muted: #6b7280;
        --admin-border: #e5e7eb;
        --radius-xl: 16px;
        --radius-lg: 12px;
        --radius-md: 8px;
        --shadow-sm: 0 1px 2px 0 rgba(0, 0, 0, 0.05);
        --shadow-md: 0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -1px rgba(0, 0, 0, 0.06);
    }

    /* Keep legacy admin presentation from overriding shared components outside this page. */
    @@scope (.ops-admin-page) {
    .ops-admin-page {
        font-family: 'Inter', system-ui, sans-serif;
        background-color: var(--admin-bg);
        padding: 2rem;
        min-height: 100vh;
        color: var(--admin-text-main);
    }

    /* KPI Grid Cards */
    .ops-admin-kpis {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
        gap: 1.5rem;
        margin-bottom: 2rem;
    }

    .ops-kpi {
        background: var(--admin-surface);
        padding: 1.5rem;
        border-radius: var(--radius-lg);
        box-shadow: var(--shadow-sm);
        border: 1px solid var(--admin-border);
        display: flex;
        flex-direction: column;
        transition: transform 0.2s, box-shadow 0.2s;
    }

        .ops-kpi:hover {
            transform: translateY(-2px);
            box-shadow: var(--shadow-md);
        }

        .ops-kpi span {
            font-size: 0.875rem;
            font-weight: 600;
            color: var(--admin-text-muted);
            text-transform: uppercase;
            letter-spacing: 0.05em;
            margin-bottom: 0.5rem;
        }

        .ops-kpi strong {
            font-size: 2.25rem;
            font-weight: 800;
            color: var(--admin-text-main);
            line-height: 1;
            margin-bottom: 0.5rem;
        }

        .ops-kpi small {
            font-size: 0.875rem;
            color: #9ca3af;
        }

    /* Panels / Cards */
    .ops-panel {
        background: var(--admin-surface);
        border-radius: var(--radius-lg);
        box-shadow: var(--shadow-sm);
        border: 1px solid var(--admin-border);
        margin-bottom: 2rem;
        overflow: hidden;
    }

    .ops-panel-head {
        padding: 1.5rem 1.5rem 1rem;
        border-bottom: 1px solid var(--admin-border);
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
    }

    .ops-eyebrow {
        color: var(--admin-primary);
        font-size: 0.875rem;
        font-weight: 600;
        text-transform: uppercase;
        margin-bottom: 0.25rem;
        display: block;
    }

    .ops-panel-head h2 {
        font-size: 1.5rem;
        font-weight: 700;
        margin: 0;
        color: var(--admin-text-main);
    }

    .ops-panel-note {
        background: #f3f4f6;
        padding: 0.25rem 0.75rem;
        border-radius: 9999px;
        font-size: 0.875rem;
        font-weight: 500;
        color: var(--admin-text-muted);
    }

    /* Filter Bar */
    .ops-filter-bar {
        padding: 1rem 1.5rem;
        background: #f9fafb;
        border-bottom: 1px solid var(--admin-border);
        display: flex;
        gap: 1rem;
        align-items: flex-end;
        flex-wrap: wrap;
    }

    .ops-field {
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
        flex: 1;
        min-width: 200px;
    }

        .ops-field span {
            font-size: 0.875rem;
            font-weight: 500;
            color: var(--admin-text-main);
        }

        .ops-field input, .ops-field select {
            padding: 0.625rem 1rem;
            border: 1px solid #d1d5db;
            border-radius: var(--radius-md);
            font-size: 0.875rem;
            transition: all 0.2s;
            box-shadow: inset 0 1px 2px rgba(0, 0, 0, 0.05);
        }

            .ops-field input:focus, .ops-field select:focus {
                border-color: var(--admin-primary);
                outline: none;
                box-shadow: 0 0 0 3px rgba(79, 70, 229, 0.15);
            }

    /* Tables */
    .ops-table-wrap {
        overflow-x: auto;
    }

    .ops-table {
        width: 100%;
        border-collapse: collapse;
        text-align: left;
    }

        .ops-table th {
            background-color: #f9fafb;
            padding: 1rem 1.5rem;
            font-size: 0.75rem;
            font-weight: 600;
            color: var(--admin-text-muted);
            text-transform: uppercase;
            letter-spacing: 0.05em;
            border-bottom: 1px solid var(--admin-border);
        }

        .ops-table td {
            padding: 1rem 1.5rem;
            border-bottom: 1px solid var(--admin-border);
            vertical-align: middle;
        }

        .ops-table tbody tr:hover {
            background-color: #f9fafb;
        }

        .ops-table tbody tr:last-child td {
            border-bottom: none;
        }

    /* Avatars & Users */
    .ops-user-cell {
        display: flex;
        align-items: center;
        gap: 1rem;
    }

    .ops-avatar {
        width: 40px;
        height: 40px;
        border-radius: 50%;
        background: #e0e7ff;
        color: var(--admin-primary);
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 700;
        font-size: 0.875rem;
        flex-shrink: 0;
    }

    .ops-user-identity strong {
        display: block;
        font-weight: 600;
        color: var(--admin-text-main);
        font-size: 0.95rem;
    }

    .ops-user-identity small {
        color: var(--admin-text-muted);
        font-size: 0.875rem;
    }

    /* Chips & Badges */
    .ops-role-badge {
        display: inline-flex;
        padding: 0.25rem 0.75rem;
        border-radius: 9999px;
        font-size: 0.75rem;
        font-weight: 600;
        background: #f3f4f6;
        color: #374151;
        text-transform: uppercase;
        letter-spacing: 0.05em;
    }

    .ops-chip-list {
        display: flex;
        flex-wrap: wrap;
        gap: 0.5rem;
    }

    .ops-chip {
        display: inline-flex;
        align-items: center;
        background: #e0e7ff;
        color: var(--admin-primary);
        padding: 0.35rem 0.75rem;
        border-radius: var(--radius-md);
        font-size: 0.875rem;
        font-weight: 500;
    }

    .ops-chip--muted {
        background: #f3f4f6;
        color: var(--admin-text-muted);
    }

    /* Buttons */
    .ops-button {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 0.5rem;
        padding: 0.625rem 1.25rem;
        font-size: 0.875rem;
        font-weight: 500;
        border-radius: var(--radius-md);
        border: none;
        cursor: pointer;
        transition: all 0.2s;
    }

    .ops-button--primary {
        background: var(--admin-primary);
        color: white;
        box-shadow: var(--shadow-sm);
    }

        .ops-button--primary:hover {
            background: var(--admin-primary-hover);
            transform: translateY(-1px);
        }

    .ops-button--secondary {
        background: white;
        color: var(--admin-text-main);
        border: 1px solid #d1d5db;
        box-shadow: var(--shadow-sm);
    }

        .ops-button--secondary:hover {
            background: #f9fafb;
            border-color: #9ca3af;
        }

    .ops-button--ghost {
        background: transparent;
        color: var(--admin-text-muted);
    }

        .ops-button--ghost:hover {
            background: #f3f4f6;
            color: var(--admin-text-main);
        }

    .ops-mini-button {
        padding: 0.35rem 0.75rem;
        font-size: 0.75rem;
        border-radius: 6px;
        font-weight: 600;
        cursor: pointer;
        border: 1px solid transparent;
        transition: all 0.2s;
    }

    .ops-mini-button--danger {
        background: #fef2f2;
        color: #dc2626;
        border-color: #fecaca;
    }

        .ops-mini-button--danger:hover:not(:disabled) {
            background: #fee2e2;
            border-color: #f87171;
        }

    .ops-mini-button:disabled {
        opacity: 0.5;
        cursor: not-allowed;
    }

    /* Forms in panels */
    .ops-stacked-form {
        padding: 1.5rem;
        display: flex;
        flex-direction: column;
        gap: 1.5rem;
        max-width: 600px;
    }

    .ops-subject-picker {
        border: 1px solid var(--admin-border);
        padding: 1rem;
        border-radius: var(--radius-md);
        background: #f9fafb;
    }

        .ops-subject-picker legend {
            font-weight: 600;
            color: var(--admin-text-main);
            padding: 0 0.5rem;
        }

    .ops-subject-options {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
        gap: 0.75rem;
        margin-top: 0.5rem;
    }

    .ops-subject-option {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        font-size: 0.875rem;
        cursor: pointer;
    }

    /* Empty States */
    .ops-empty {
        padding: 4rem 2rem;
        text-align: center;
        color: var(--admin-text-muted);
    }

        .ops-empty strong {
            display: block;
            font-size: 1.125rem;
            color: var(--admin-text-main);
            margin-bottom: 0.5rem;
        }

    /* Alerts */
    .rbl-alert {
        padding: 1rem;
        border-radius: var(--radius-md);
        margin-bottom: 1.5rem;
        font-weight: 500;
        font-size: 0.875rem;
    }

        .rbl-alert.is-success {
            background: #ecfdf5;
            color: #065f46;
            border: 1px solid #a7f3d0;
        }

    .rbl-alert.is-error {
            background: #fef2f2;
            color: #991b1b;
            border: 1px solid #fecaca;
        }

    /* Bridge legacy page styles to the shared semantic design system. */
    .ops-admin-page {
        min-height: auto;
        padding: 0;
        background: transparent;
        color: var(--ds-text);
        font-family: var(--app-font-sans);
    }

    .ops-admin-kpis {
        grid-template-columns: repeat(4, minmax(0, 1fr));
        gap: var(--ds-space-3);
        margin-bottom: var(--ds-space-4);
    }

    .ops-admin-kpis .ops-kpi {
        min-height: 112px;
        padding: 1rem 1.1rem;
        border-radius: var(--ds-radius-md);
        box-shadow: var(--ds-shadow-card);
    }

    .ops-admin-kpis .ops-kpi span {
        margin-bottom: .35rem;
        color: var(--ds-text-muted);
        font-size: .72rem;
        letter-spacing: .04em;
    }

    .ops-admin-kpis .ops-kpi strong {
        margin-bottom: .3rem;
        font-size: 1.65rem;
    }

    .ops-admin-page > .ops-panel {
        margin-bottom: var(--ds-space-4);
        border-radius: var(--ds-radius-md);
    }

    .ops-admin-page .ops-panel-head {
        align-items: center;
        padding: 1rem 1.15rem;
    }

    .ops-admin-page .ops-panel-head h2 {
        font-size: 1.05rem;
    }

    .ops-admin-filter {
        display: grid;
        grid-template-columns: minmax(260px, 1fr) minmax(170px, .35fr) auto;
        align-items: end;
        gap: .75rem;
        padding: .85rem 1.15rem;
    }

    .ops-admin-filter .ops-field {
        min-width: 0;
        margin: 0;
    }

    .ops-user-table th,
    .ops-user-table td {
        padding: .8rem 1rem;
    }

    .ops-user-table tbody tr {
        transition: background-color .15s ease;
    }

    .ops-user-table .ops-avatar {
        width: 36px;
        height: 36px;
    }

    @@media (max-width: 1100px) {
        .ops-admin-kpis { grid-template-columns: repeat(2, minmax(0, 1fr)); }
        .ops-admin-filter { grid-template-columns: 1fr 1fr; }
        .ops-admin-filter > div { grid-column: 1 / -1; }
    }

    @@media (max-width: 640px) {
        .ops-admin-kpis { grid-template-columns: 1fr; }
    }
    }
</style>

<section class="ops-page ops-admin-page">
    @if (TempData["Success"] is string success)
    {
        <div class="rbl-alert is-success">@success</div>
    }
    @if (TempData["Error"] is string error)
    {
        <div class="rbl-alert is-error">@error</div>
    }
    @if (!string.IsNullOrWhiteSpace(Model.LoadErrorMessage))
    {
        <div class="rbl-alert is-error" role="alert">
            <span class="material-symbols-outlined" aria-hidden="true">cloud_off</span>
            @Model.LoadErrorMessage
        </div>
    }

    <header class="ops-page-header ops-admin-heading">
        <div>
            <span class="ops-eyebrow" data-i18n="admin.eyebrow">Quản trị hệ thống</span>
            <h1 data-i18n="admin.usersAndAssignment">Người dùng &amp; phân công</h1>
            <p data-i18n="admin.usersDesc">Quản lý tài khoản, vai trò và phân công môn học tại một nơi.</p>
        </div>
        <a class="ops-button ops-button--primary" asp-page="/Admin/Index" asp-route-section="create-account">
            <span class="material-symbols-outlined" aria-hidden="true">person_add</span>
            <span data-i18n="admin.addAccount">Thêm tài khoản</span>
        </a>
    </header>

    <nav class="ops-tabs ops-admin-tabs" aria-label="Quản trị người dùng và môn học" data-i18n-aria-label="admin.tabsAria">
        <a class="@AdminTabClass(IndexModel.AdminSection.Directory)" asp-page="/Admin/Index" asp-route-section="directory" aria-current="@(isDirectory ? "page" : null)"><span data-i18n="admin.tabList">Danh sách</span></a>
        <a class="@AdminTabClass(IndexModel.AdminSection.LecturerTable)" asp-page="/Admin/Index" asp-route-section="lecturer-table" aria-current="@(isLecturerTable ? "page" : null)"><span data-i18n="admin.tabLecturers">Phân công giảng viên</span></a>
        <a class="@AdminTabClass(IndexModel.AdminSection.CreateAccount)" asp-page="/Admin/Index" asp-route-section="create-account" aria-current="@(isCreateAccount ? "page" : null)"><span data-i18n="admin.tabCreateAccount">Thêm tài khoản</span></a>
        <a class="@AdminTabClass(IndexModel.AdminSection.BulkImport)" asp-page="/Admin/Index" asp-route-section="bulk-import" aria-current="@(isBulkImport ? "page" : null)"><span data-i18n="admin.tabImportExcel">Nhập Excel</span></a>
        <a class="@AdminTabClass(IndexModel.AdminSection.CreateSubject)" asp-page="/Admin/Index" asp-route-section="create-subject" aria-current="@(isCreateSubject ? "page" : null)"><span data-i18n="admin.tabSubjects">Môn học</span></a>
    </nav>

    @if (isDirectory)
    {
        @* === DIRECTORY: Bảng người dùng / User table === *@
        <section class="ops-kpi-grid ops-admin-kpis" aria-label="User metrics">
            <article class="ops-kpi">
                <span data-i18n="admin.kpiTotalUsers">Tổng người dùng</span>
                <strong>@Model.TotalUserCount</strong>
                <small><span data-i18n="admin.showing">Đang hiển thị</span> @users.Count</small>
            </article>
            <article class="ops-kpi">
                <span data-i18n="admin.kpiLecturers">Giảng viên</span>
                <strong>@Model.LecturerUserCount</strong>
                <small data-i18n="admin.kpiLecturersDesc">Quản lý môn được phân công</small>
            </article>
            <article class="ops-kpi">
                <span data-i18n="admin.kpiStudents">Sinh viên</span>
                <strong>@Model.StudentUserCount</strong>
                <small data-i18n="admin.kpiStudentsDesc">Được sử dụng trợ lý học tập</small>
            </article>
            <article class="ops-kpi">
                <span data-i18n="admin.kpiDeletable">Có thể xóa</span>
                <strong>@deletionEligibleUsers</strong>
                <small data-i18n="admin.kpiDeletableDesc">Không phụ trách môn và ngưng hoạt động trên 3 tháng</small>
            </article>
        </section>

        <section class="ops-panel">
            <div class="ops-panel-head">
                <div>
                    <span class="ops-eyebrow" data-i18n="admin.userListEyebrow">Danh sách tài khoản</span>
                    <h2 data-i18n="admin.userListTitle">Người dùng trong hệ thống</h2>
                </div>
                <span class="ops-panel-note">@users.Count/@Model.TotalUserCount <span data-i18n="admin.usersUnit">users</span></span>
            </div>

            <form asp-page="/Admin/Index" method="get" class="ops-filter-bar ops-admin-filter" asp-route-section="directory">
                <label class="ops-field ops-field--search">
                    <span data-i18n="admin.search">Tìm kiếm</span>
                    <input name="q" value="@Model.Query" placeholder="Tên, email hoặc môn học..." data-i18n-placeholder="admin.searchPlaceholder" />
                </label>
                <label class="ops-field">
                    <span data-i18n="admin.role">Vai trò</span>
                    <select name="roleFilter">
                        @if (string.IsNullOrWhiteSpace(Model.RoleFilter))
                        {
                            <option value="" selected data-i18n="admin.allRoles">Tất cả vai trò</option>
                        }
                        else
                        {
                            <option value="" data-i18n="admin.allRoles">Tất cả vai trò</option>
                        }
                        @foreach (var role in Model.Roles)
                        {
                            if (role.Equals(Model.RoleFilter, StringComparison.OrdinalIgnoreCase))
                            {
                                <option value="@role" selected data-i18n="admin.role.@role.ToLowerInvariant()">@RoleLabel(role)</option>
                            }
                            else
                            {
                                <option value="@role" data-i18n="admin.role.@role.ToLowerInvariant()">@RoleLabel(role)</option>
                            }
                        }
                    </select>
                </label>
                <div style="display: flex; gap: 0.5rem; align-items: flex-end; padding-bottom: 2px;">
                    <button type="submit" class="ops-button ops-button--secondary" data-i18n="admin.apply">Áp dụng</button>
                    @if (hasActiveFilters)
                    {
                        <a class="ops-button ops-button--ghost" asp-page="/Admin/Index" asp-route-section="directory" data-i18n="admin.clearFilters">Xóa bộ lọc</a>
                    }
                </div>
            </form>

            @if (users.Count == 0)
            {
                <div class="ops-empty">
                    <strong data-i18n="admin.noMatchingUsers">No matching users.</strong>
                    <p data-i18n="admin.noMatchingUsersHint">Clear filters or create a new account from the command panel.</p>
                </div>
            }
            else
            {
                <div class="ops-table-wrap">
                    <table class="ops-table ops-user-table">
                        <caption class="visually-hidden" data-i18n="admin.tableCaption">Danh sách người dùng theo bộ lọc hiện tại</caption>
                        <thead>
                            <tr>
                                <th scope="col" data-i18n="admin.thUser">Người dùng</th>
                                <th scope="col" data-i18n="admin.thLastActive">Hoạt động gần nhất</th>
                                <th scope="col" data-i18n="admin.thRole">Vai trò</th>
                                <th scope="col" data-i18n="admin.thSubjects">Môn học</th>
                                <th scope="col" style="text-align: right;" data-i18n="admin.thActions">Thao tác</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var user in users)
                            {
                                <tr>
                                    <td data-label="User" data-i18n-data-label="admin.thUser">
                                        <div class="ops-user-cell">
                                            <span class="ops-avatar">@Initials(user)</span>
                                            <div class="ops-user-identity">
                                                <strong>@DisplayName(user)</strong>
                                                <small>@user.Email</small>
                                                @if (user.IsSuspended)
                                                {
                                                    <small style="color:#b91c1c;font-weight:700;">Đã khóa</small>
                                                }
                                            </div>
                                        </div>
                                    </td>
                                    <td data-label="Last active" data-i18n-data-label="admin.thLastActive">
                                        <span style="color: var(--admin-text-muted); font-size: 0.875rem;" title='Ngày tạo: @user.CreatedAt.LocalDateTime.ToString("yyyy-MM-dd HH:mm")'>
                                            @((user.LastActiveAt ?? user.CreatedAt).LocalDateTime.ToString("yyyy-MM-dd HH:mm"))
                                        </span>
                                    </td>
                                    <td data-label="Role" data-i18n-data-label="admin.thRole">
                                        <span class="ops-role-badge" data-i18n="admin.role.@user.Role.ToLowerInvariant()">@RoleLabel(user.Role)</span>
                                    </td>
                                    <td data-label="Subjects" data-i18n-data-label="admin.thSubjects">
                                        @if (user.Role == PRN222_FINAL.BLL.Security.AppRoles.Lecturer)
                                        {
                                            <div class="ops-subject-cell">
                                                <div class="ops-chip-list">
                                                    @if (user.AssignedSubjectDetails.Count == 0)
                                                    {
                                                        <span class="ops-chip ops-chip--muted" data-i18n="admin.unassignedSubject">Chưa đăng ký môn</span>
                                                    }
                                                    else
                                                    {
                                                        foreach (var subject in user.AssignedSubjectDetails)
                                                        {
                                                            <span class="ops-chip" title="Đã assign - không thể gỡ" data-i18n-title="admin.assignedTooltip">
                                                                <span>@subject.DisplayName</span>
                                                            </span>
                                                        }
                                                    }
                                                </div>
                                            </div>
                                        }
                                        else if (user.Role == PRN222_FINAL.BLL.Security.AppRoles.Student)
                                        {
                                            <span class="ops-chip" data-i18n="admin.studentAllowed">Được dùng trợ lý học tập</span>
                                        }
                                        else
                                        {
                                            <span class="ops-chip ops-chip--muted" data-i18n="admin.notApplicable">Không áp dụng</span>
                                        }
                                    </td>
                                    <td data-label="Actions" style="text-align: right;" data-i18n-data-label="admin.thActions">
                                        @{
                                            var deleteDisabled = user.IsLastAdmin
                                            || user.IsCurrentUser
                                            || user.HasAssignedSubjects
                                            || !user.MeetsInactivePeriod
                                            || (user.Role != PRN222_FINAL.BLL.Security.AppRoles.Student && user.Role != PRN222_FINAL.BLL.Security.AppRoles.Lecturer);
                                            
                                            var deleteTitleI18n = user.IsCurrentUser ? "admin.delErrSelf"
                                            : user.IsLastAdmin ? "admin.delErrLastAdmin"
                                            : user.HasAssignedSubjects ? "admin.delErrAssigned"
                                            : !user.MeetsInactivePeriod ? "admin.delErrActive"
                                            : "admin.delOk";
                                        }
                                        <form asp-page-handler="SetSuspended" method="post" style="display:inline-block;margin-right:.35rem;">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="UserId" value="@user.Id" />
                                            <input type="hidden" name="Suspend" value="@(!user.IsSuspended ? "true" : "false")" />
                                            <button type="submit"
                                                    class="ops-mini-button"
                                                    disabled="@(user.IsCurrentUser && !user.IsSuspended)">
                                                @(user.IsSuspended ? "Mở khóa" : "Khóa")
                                            </button>
                                        </form>
                                        <form asp-page-handler="DeleteUser" method="post" class="ops-danger-form" data-confirm-i18n="admin.deleteConfirm" style="display: inline-block;">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="UserId" value="@user.Id" />
                                            <button type="submit"
                                                    class="ops-mini-button ops-mini-button--danger"
                                                    disabled="@deleteDisabled"
                                                    data-i18n-title="@deleteTitleI18n">
                                                <span data-i18n="admin.delete">Xóa</span>
                                            </button>
                                        </form>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </section>
    }

    @if (isCreateAccount)
    {
        @* === CREATE ACCOUNT: Thêm user === *@
        <section class="ops-panel">
            <div class="ops-panel-head">
                <div>
                    <span class="ops-eyebrow" data-i18n="admin.navCreateAccount">Create account</span>
                    <h2 data-i18n="admin.createAccountHeading">Thêm user</h2>
                </div>
            </div>
            <form asp-page-handler="CreateUser" method="post" class="ops-stacked-form" data-admin-create-user-form data-admin-user-role-subject-form>
                @Html.AntiForgeryToken()
                <label class="ops-field">
                    <span data-i18n="admin.fullName">Full name</span>
                    <input name="FullName" maxlength="120" autocomplete="name" placeholder="Ví dụ: Nguyễn Văn A" data-i18n-placeholder="admin.namePlaceholder" />
                </label>
                <label class="ops-field">
                    <span data-i18n="admin.email">Email</span>
                    <input name="Email" type="email" autocomplete="email" placeholder="example@domain.com" data-i18n-placeholder="admin.emailPlaceholder" />
                </label>
                <p class="ops-panel-note">Người dùng sẽ nhận liên kết đặt mật khẩu dùng một lần qua email.</p>
                <label class="ops-field">
                    <span data-i18n="admin.role">Role</span>
                    <select name="Role" data-admin-role-select>
                        @foreach (var role in Model.Roles)
                        {
                            if (role.Equals(PRN222_FINAL.BLL.Security.AppRoles.Student, StringComparison.OrdinalIgnoreCase))
                            {
                                <option value="@role" data-i18n="admin.role@(role)" selected>@role</option>
                            }
                            else
                            {
                                <option value="@role" data-i18n="admin.role@(role)">@role</option>
                            }
                        }
                    </select>
                </label>
                <fieldset class="ops-field ops-subject-picker" data-lecturer-subject-picker>
                    <legend data-i18n="admin.subjectsForLecturer">Subjects for lecturer</legend>
                    @if (unassignedSubjects.Count == 0)
                    {
                        <span class="ops-muted" data-i18n="admin.noUnassignedSubjects" style="color: var(--admin-text-muted); font-size: 0.875rem;">No unassigned subjects</span>
                    }
                    else
                    {
                        <div class="ops-subject-options">
                            @foreach (var subject in unassignedSubjects)
                            {
                                <label class="ops-subject-option">
                                    <input type="checkbox" name="SubjectIds" value="@subject.Id" style="width: auto; box-shadow: none;" />
                                    <span>@subject.DisplayName</span>
                                </label>
                            }
                        </div>
                    }
                </fieldset>
                <div style="margin-top: 1rem;">
                    <button type="submit" class="ops-button ops-button--primary">
                        <span data-i18n="admin.createUserBtn">Create user</span>
                    </button>
                </div>
            </form>
        </section>
    }

    @if (isBulkImport)
    {
        @* === IMPORT EXCEL: Import users from Excel === *@
        <section class="ops-panel">
            <div class="ops-panel-head">
                <div>
                    <span class="ops-eyebrow" data-i18n="admin.importExcelEyebrow">Excel</span>
                    <h2 data-i18n="admin.importExcelTitle">Import from Excel</h2>
                </div>
            </div>
            <form asp-page-handler="ImportUsers" method="post" enctype="multipart/form-data" class="ops-stacked-form" data-admin-user-role-subject-form data-confirm-i18n="admin.bulkImportConfirm">
                @Html.AntiForgeryToken()
                <input type="hidden" name="Role" value="@PRN222_FINAL.BLL.Security.AppRoles.Student" />
                <label class="ops-field">
                    <span data-i18n="admin.excelFile">Excel file</span>
                    <input name="ExcelFile" type="file" accept=".xlsx" required style="padding: 0.5rem;" />
                    <small data-i18n="admin.excelImportHint">The system automatically extracts the full name and email columns.</small>
                </label>
                <div style="margin-top: 1rem;">
                    <button type="submit" class="ops-button ops-button--primary">
                        <span data-i18n="admin.importUsers">Import users</span>
                    </button>
                </div>
                <small style="color: var(--admin-text-muted);" data-i18n="admin.importWelcomeNote">Welcome emails will include each user's role and subject access.</small>
            </form>
        </section>
    }

    @if (isLecturerTable)
    {
        @* === LECTURER TABLE: Danh sách giảng viên === *@
        <section class="ops-panel">
            <div class="ops-panel-head">
                <div>
                    <span class="ops-eyebrow" data-i18n="admin.lecturerManagement">Lecturer management</span>
                    <h2 data-i18n="admin.lecturerTableHeading">Lecturer Table / Bảng giảng viên</h2>
                </div>
                <span class="ops-panel-note">@Model.LecturerUserCount <span data-i18n="admin.lecturersUnit">lecturers</span></span>
            </div>

            @{
                var lecturers = users.Where(u => u.Role == PRN222_FINAL.BLL.Security.AppRoles.Lecturer).ToList();
            }
            @if (lecturers.Count == 0)
            {
                <div class="ops-empty">
                    <strong data-i18n="admin.noLecturersFound">No lecturers found.</strong>
                    <p data-i18n="admin.createLecturerHint">Create a lecturer account first.</p>
                </div>
            }
            else
            {
                <div class="ops-table-wrap">
                    <table class="ops-table" style="min-width: 600px;">
                        <caption class="visually-hidden" data-i18n="admin.lecturerTableCaption">Phân công môn học cho giảng viên</caption>
                        <thead>
                            <tr>
                                <th style="width: 260px;" data-i18n="admin.thName">NAME</th>
                                <th data-i18n="admin.thSubjects">SUBJECTS</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var lecturer in lecturers)
                            {
                                var assignedSubjectIds = lecturer.AssignedSubjectDetails
                                .Select(subject => subject.Id)
                                .ToHashSet();
                                var availableSubjects = Model.SubjectOptions
                                .Where(subject => !subject.OwnerUserId.HasValue && !assignedSubjectIds.Contains(subject.Id))
                                .ToList();

                                <tr>
                                    <td data-label="NAME" style="width: 260px;" data-i18n-data-label="admin.thName">
                                        <div class="ops-user-cell" style="min-width: 0;">
                                            <span class="ops-avatar">@Initials(lecturer)</span>
                                            <div class="ops-user-identity">
                                                <strong>@DisplayName(lecturer)</strong>
                                                <small>@lecturer.Email</small>
                                            </div>
                                        </div>
                                    </td>
                                    <td data-label="Subjects" data-i18n-data-label="admin.thSubjects">
                                        <div class="ops-subject-cell ops-subject-assignment">
                                            <div class="ops-chip-list">
                                                @if (lecturer.AssignedSubjectDetails.Count == 0)
                                                {
                                                    <span class="ops-chip ops-chip--muted" data-i18n="admin.unassignedSubject">Chưa đăng ký môn</span>
                                                }
                                                else
                                                {
                                                    foreach (var subject in lecturer.AssignedSubjectDetails)
                                                    {
                                                        <div class="ops-chip ops-chip--removable" title="Đã assign - click X để gỡ" data-i18n-title="admin.assignedClickToRemove">
                                                            <span>@subject.DisplayName@(subject.IsLeader? Html.Raw("<span data-i18n=\"admin.subjectLeaderSuffix\"> (Trưởng bộ môn)</span>") : Html.Raw(""))</span>

                                                            <form asp-page-handler="UnregisterLecturerSubject" method="post" class="ops-inline-form" data-confirm-en="Unassign @subject.DisplayName from @DisplayName(lecturer)?" data-confirm-vi="Gỡ môn @subject.DisplayName khỏi @DisplayName(lecturer)?">
                                                                @Html.AntiForgeryToken()
                                                                <input type="hidden" name="UserId" value="@lecturer.Id" />
                                                                <input type="hidden" name="SubjectId" value="@subject.Id" />
                                                                <button type="submit" class="ops-inline-remove-button" title="Gỡ môn" data-i18n-title="admin.unassignButton" aria-label="Gỡ môn @subject.DisplayName">
                                                                    &times;
                                                                </button>
                                                            </form>
                                                        </div>
                                                    }
                                                }
                                            </div>
                                            <form asp-page-handler="RegisterLecturerSubject" method="post" class="ops-assign-form" data-confirm-en="Assign selected subject to @DisplayName(lecturer)?" data-confirm-vi="Đăng ký môn đã chọn cho @DisplayName(lecturer)?">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="UserId" value="@lecturer.Id" />
                                                <select name="SubjectId" required disabled="@(availableSubjects.Count == 0)" aria-label="Đăng ký môn cho @DisplayName(lecturer)">
                                                    @if (availableSubjects.Count == 0)
                                                    {
                                                        <option value="" data-i18n="admin.noSubjectsAvailable">Không có môn nào</option>
                                                    }
                                                    else
                                                    {
                                                        <option value="" data-i18n="admin.selectSubjectAssign">Chọn môn để đăng ký</option>
                                                    }
                                                    @foreach (var subject in availableSubjects)
                                                    {
                                                        <option value="@subject.Id">@subject.DisplayName</option>
                                                    }
                                                </select>
                                                <button type="submit" class="ops-button ops-button--secondary" disabled="@(availableSubjects.Count == 0)" data-i18n="admin.assignButton">Đăng ký</button>
                                            </form>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </section>
    }

