@page
@model PRN222_FINAL.Web.Pages.Admin.AiSettingsModel
@{
    ViewData["Title"] = "Thiết lập trợ lý học tập";
    ViewData["UseRblShell"] = true;
    ViewData["ActiveNav"] = "assistant-settings";
    ViewData["ShellTitle"] = "Thiết lập trợ lý học tập";
}

<style>
    /* 1. BIẾN MÀU SẮC & UI (Modern Theme) */
    :root {
        --primary: #4F46E5;
        --primary-hover: #4338ca;
        --surface: #ffffff;
        --bg-color: #f9fafb;
        --text-main: #111827;
        --text-muted: #6b7280;
        --border: #e5e7eb;
        --radius-lg: 12px;
        --radius-md: 8px;
        --shadow-sm: 0 1px 2px 0 rgba(0, 0, 0, 0.05);
        --shadow-md: 0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -1px rgba(0, 0, 0, 0.06);
    }

    .ai-settings-page {
        font-family: 'Inter', system-ui, sans-serif;
        background-color: var(--bg-color);
        padding: 2rem;
        max-width: 1000px;
        margin: 0 auto;
        border-radius: var(--radius-lg);
    }

    /* 2. TYPOGRAPHY & HEADER */
    .ops-page-heading {
        margin-bottom: 2rem;
    }

    .ops-eyebrow {
        color: var(--primary);
        font-weight: 600;
        font-size: 0.875rem;
        text-transform: uppercase;
        letter-spacing: 0.05em;
    }

    .ops-page-heading h1 {
        font-size: 1.875rem;
        font-weight: 700;
        color: var(--text-main);
        margin: 0.5rem 0;
    }

    .ops-page-heading p {
        color: var(--text-muted);
        font-size: 1rem;
    }

    /* 3. LAYOUT DẠNG GRID & CARD */
    .ai-settings-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 1.5rem;
    }

    .ai-settings-card {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: var(--radius-lg);
        padding: 1.5rem;
        box-shadow: var(--shadow-sm);
        transition: box-shadow 0.2s;
    }

        .ai-settings-card:hover {
            box-shadow: var(--shadow-md);
        }

    .ai-settings-card--wide {
        grid-column: 1 / -1;
    }
    /* Chiếm trọn 2 cột */

    .ops-panel-head h2 {
        font-size: 1.25rem;
        font-weight: 600;
        color: var(--text-main);
        margin-bottom: 0.25rem;
    }

    .ops-panel-head p {
        color: var(--text-muted);
        font-size: 0.875rem;
        margin-bottom: 1.5rem;
    }

    /* 4. FORM CONTROLS (Input, Slider) */
    .ops-field {
        display: flex;
        flex-direction: column;
        margin-bottom: 1.25rem;
    }

        .ops-field > span:first-child {
            font-weight: 500;
            font-size: 0.875rem;
            color: var(--text-main);
            margin-bottom: 0.5rem;
        }

    .modern-input {
        padding: 0.625rem 0.75rem;
        border: 1px solid var(--border);
        border-radius: var(--radius-md);
        font-size: 0.875rem;
        outline: none;
        transition: border-color 0.2s, box-shadow 0.2s;
    }

        .modern-input:focus {
            border-color: var(--primary);
            box-shadow: 0 0 0 3px rgba(79, 70, 229, 0.1);
        }

    small {
        color: var(--text-muted);
        font-size: 0.75rem;
        margin-top: 0.375rem;
    }

    .text-danger {
        color: #dc2626;
        font-size: 0.75rem;
        margin-top: 0.25rem;
    }

    /* UI Thanh trượt (Range + Number sync) */
    .range-group {
        display: flex;
        align-items: center;
        gap: 1rem;
    }

        .range-group input[type="range"] {
            flex-grow: 1;
            accent-color: var(--primary);
        }

        .range-group input[type="number"] {
            width: 80px;
            text-align: center;
        }

    /* 5. VISUALIZER (Biểu đồ chia đoạn) */
    .chunk-visualizer {
        background: #f3f4f6;
        border: 1px dashed #d1d5db;
        border-radius: var(--radius-md);
        height: 80px;
        margin: 1.5rem 0;
        position: relative;
        overflow: hidden;
        display: flex;
        align-items: center;
        padding: 0 1rem;
    }

    .chunk-box {
        position: absolute;
        height: 40px;
        background-color: rgba(79, 70, 229, 0.2);
        border: 2px solid var(--primary);
        border-radius: 4px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 0.75rem;
        color: var(--primary);
        font-weight: 600;
        transition: all 0.3s ease;
    }

    .chunk-overlap {
        position: absolute;
        height: 40px;
        background: repeating-linear-gradient(45deg, rgba(79, 70, 229, 0.3), rgba(79, 70, 229, 0.3) 5px, transparent 5px, transparent 10px);
        transition: all 0.3s ease;
    }

    /* 6. ALERTS & BUTTONS */
    .rbl-alert {
        padding: 1rem;
        border-radius: var(--radius-md);
        margin-bottom: 1.5rem;
        font-size: 0.875rem;
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }

    .is-success {
        background-color: #ecfdf5;
        color: #065f46;
        border: 1px solid #a7f3d0;
    }

    .is-info {
        background-color: #eff6ff;
        color: #1e40af;
        border: 1px solid #bfdbfe;
    }

    .is-error {
        background-color: #fef2f2;
        color: #991b1b;
        border: 1px solid #fecaca;
    }

    .ai-settings-actions {
        grid-column: 1 / -1;
        display: flex;
        justify-content: flex-end;
        margin-top: 1rem;
    }

    .ops-button--primary {
        background-color: var(--primary);
        color: white;
        padding: 0.75rem 1.5rem;
        border: none;
        border-radius: var(--radius-md);
        font-weight: 600;
        font-size: 0.875rem;
        display: flex;
        align-items: center;
        gap: 0.5rem;
        cursor: pointer;
        transition: background-color 0.2s;
    }

        .ops-button--primary:hover {
            background-color: var(--primary-hover);
        }
</style>

<section class="ops-page ai-settings-page">
    <header class="ops-page-heading">
        <div>
            <span class="ops-eyebrow">Cách trợ lý đọc và trả lời</span>
            <h1>Thiết lập trợ lý</h1>
            <p>Chọn cách trợ lý đọc tài liệu và tạo câu trả lời cho người học.</p>
        </div>
    </header>

    @if (TempData["Success"] is string success)
    {
        <div class="rbl-alert is-success" role="status">
            <span class="material-symbols-outlined" aria-hidden="true">check_circle</span>
            @success
        </div>
    }
    <div asp-validation-summary="ModelOnly" class="rbl-alert is-error" role="alert"></div>

    <form method="post" class="ai-settings-grid">

        <section class="ops-panel ai-settings-card">
            <div class="ops-panel-head">
                <h2>Tạo câu trả lời</h2>
                <p>Chọn dịch vụ và bộ máy dùng để hiểu câu hỏi, sau đó viết câu trả lời.</p>
            </div>
            <label class="ops-field">
                <span>Dịch vụ AI</span>
                <select asp-for="Input.AnswerProvider" class="modern-input" data-chat-provider>
                    @foreach (var provider in Model.AnswerProviderOptions)
                    {
                        <option value="@provider" data-configured="@Model.IsProviderConfigured(provider).ToString().ToLowerInvariant()">@provider</option>
                    }
                </select>
                <small>Khóa kết nối được bảo vệ trong cấu hình máy chủ, không hiển thị trên trang.</small>
                <span asp-validation-for="Input.AnswerProvider" class="text-danger"></span>
            </label>
            <label class="ops-field">
                <span>Bộ máy trả lời</span>
                <select asp-for="Input.AnswerModel" class="modern-input" data-chat-model>
                    @foreach (var providerModels in Model.AnswerModelsByProvider)
                    {
                        foreach (var modelName in providerModels.Value)
                        {
                            <option value="@modelName" data-provider="@providerModels.Key">@modelName</option>
                        }
                    }
                </select>
                <small data-chat-model-hint>Gemini phù hợp mặc định; Groq là lựa chọn tốc độ cao cho sinh câu trả lời RAG.</small>
                <span asp-validation-for="Input.AnswerModel" class="text-danger"></span>
            </label>
            <div class="provider-status @(Model.IsSelectedProviderConfigured ? "is-configured" : "is-missing")" data-provider-status>
                <span class="material-symbols-outlined" aria-hidden="true" data-provider-status-icon>@(Model.IsSelectedProviderConfigured ? "check_circle" : "key_off")</span>
                <span data-provider-status-text>@(Model.IsSelectedProviderConfigured ? "Dịch vụ đã kết nối" : "Dịch vụ chưa có khóa kết nối")</span>
            </div>
        </section>

        <section class="ops-panel ai-settings-card">
            <div class="ops-panel-head">
                <h2>Đọc tài liệu</h2>
                <p>Chọn cách trợ lý ghi nhớ nội dung để tìm đúng đoạn liên quan khi có câu hỏi.</p>
            </div>
            <label class="ops-field">
                <span>Bộ máy đọc tài liệu</span>
                <select asp-for="Input.ReadingModel" class="modern-input">
                    @foreach (var modelName in Model.ReadingModelOptions)
                    {
                        <option value="@modelName">@modelName</option>
                    }
                </select>
                <span asp-validation-for="Input.ReadingModel" class="text-danger"></span>
            </label>

            <label class="ops-field">
                <span>Mức độ chi tiết khi ghi nhớ</span>
                <div class="range-group">
                    <input type="range" id="detailSlider" min="128" max="4096" step="1" value="768" />
                    <input asp-for="Input.ReadingDetail" id="detailNumber" class="modern-input" type="number" min="128" max="4096" />
                </div>
                <small>Mặc định 768. Mức cao hơn giữ nhiều chi tiết nhưng cần thêm dung lượng và thời gian tìm kiếm.</small>
                <span asp-validation-for="Input.ReadingDetail" class="text-danger"></span>
            </label>
        </section>

        <section class="ops-panel ai-settings-card ai-settings-card--wide">
            <div class="ops-panel-head">
                <h2>Chia tài liệu thành đoạn</h2>
                <p>Khi upload file lớn, hệ thống sẽ cắt nhỏ file ra thành nhiều đoạn. Đoạn ngắn giúp tìm kiếm chính xác, đoạn dài giữ được nhiều ngữ cảnh.</p>
            </div>

            <div class="ai-settings-fields" style="display: grid; grid-template-columns: 1fr 1fr; gap: 2rem;">
                <label class="ops-field">
                    <span>Độ dài tối đa mỗi đoạn (Ký tự)</span>
                    <div class="range-group">
                        <input type="range" id="lenSlider" min="300" max="4000" step="50" value="1000" />
                        <input asp-for="Input.SectionLength" id="lenNumber" class="modern-input" type="number" min="300" max="4000" />
                    </div>
                    <small>Khuyến nghị: 800–1.200 ký tự.</small>
                    <span asp-validation-for="Input.SectionLength" class="text-danger"></span>
                </label>

                <label class="ops-field">
                    <span>Phần nội dung lặp lại giữa hai đoạn</span>
                    <div class="range-group">
                        <input type="range" id="overlapSlider" min="0" max="500" step="10" value="100" />
                        <input asp-for="Input.SectionConnection" id="overlapNumber" class="modern-input" type="number" min="0" max="500" />
                    </div>
                    <small>Giúp trợ lý không bỏ sót ý ở điểm cắt. Khuyến nghị khoảng 10% độ dài đoạn.</small>
                    <span asp-validation-for="Input.SectionConnection" class="text-danger"></span>
                </label>
            </div>

            <div style="margin-top: 1.5rem;">
                <span style="color: #6b7280; font-size: 13px; font-weight: 600; display: block; margin-bottom: 4px;">Mô phỏng tài liệu...</span>
                <div class="chunk-visualizer" aria-hidden="true" style="margin-top: 0; margin-bottom: 1.5rem;">
                    <div id="vis-chunk1" class="chunk-box">Đoạn 1</div>
                    <div id="vis-overlap" class="chunk-overlap" title="Phần giao nhau (Overlap)"></div>
                    <div id="vis-chunk2" class="chunk-box">Đoạn 2</div>
                </div>
            </div>

            <div class="rbl-alert is-info">
                <span class="material-symbols-outlined" aria-hidden="true">info</span>
                <strong>Lưu ý:</strong> Khi bạn thay đổi thông số cắt tài liệu, các tài liệu đã được tải lên trước đây sẽ cần phải được xử lý (Embedding) lại để có tác dụng.
            </div>
        </section>

        <div class="ai-settings-actions">
            <button type="submit" class="ops-button ops-button--primary">
                <span class="material-symbols-outlined" aria-hidden="true" style="font-size: 20px;">save</span>
                Lưu cấu hình hệ thống
            </button>
        </div>
    </form>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const providerSelect = document.querySelector('[data-chat-provider]');
            const modelSelect = document.querySelector('[data-chat-model]');
            const modelHint = document.querySelector('[data-chat-model-hint]');
            const providerStatus = document.querySelector('[data-provider-status]');
            const providerStatusIcon = document.querySelector('[data-provider-status-icon]');
            const providerStatusText = document.querySelector('[data-provider-status-text]');

            function syncProviderModels(changeSelection) {
                if (!providerSelect || !modelSelect) return;

                const provider = providerSelect.value;
                const availableOptions = Array.from(modelSelect.options).filter(option => option.dataset.provider === provider);
                Array.from(modelSelect.options).forEach(option => {
                    const matches = option.dataset.provider === provider;
                    option.hidden = !matches;
                    option.disabled = !matches;
                });

                const currentIsAvailable = availableOptions.some(option => option.value === modelSelect.value);
                if ((changeSelection || !currentIsAvailable) && availableOptions.length > 0) {
                    modelSelect.value = availableOptions[0].value;
                }

                if (modelHint) {
                    modelHint.textContent = provider === 'Groq'
                        ? 'Khuyến nghị llama-3.3-70b-versatile cho chất lượng hoặc llama-3.1-8b-instant cho tốc độ.'
                        : 'Khuyến nghị gemini-3.5-flash cho tốc độ và chi phí cân bằng.';
                }

                const selectedProviderOption = providerSelect.selectedOptions[0];
                const isConfigured = selectedProviderOption?.dataset.configured === 'true';
                providerStatus?.classList.toggle('is-configured', isConfigured);
                providerStatus?.classList.toggle('is-missing', !isConfigured);
                if (providerStatusIcon) providerStatusIcon.textContent = isConfigured ? 'check_circle' : 'key_off';
                if (providerStatusText) providerStatusText.textContent = isConfigured ? 'Dịch vụ đã kết nối' : 'Dịch vụ chưa có khóa kết nối';
            }

            providerSelect?.addEventListener('change', () => syncProviderModels(true));
            syncProviderModels(false);

            // Hàm đồng bộ thanh trượt (Range) và ô nhập số (Number)
            function syncInputs(sliderId, numberInputId) {
                const slider = document.getElementById(sliderId);
                const num = document.getElementById(numberInputId);

                if(!slider || !num) return;

                // Nếu backend trả về value, gán vào slider lúc load trang
                if (num.value) slider.value = num.value;

                slider.addEventListener('input', (e) => {
                    num.value = e.target.value;
                    updateVisualizer();
                });

                num.addEventListener('input', (e) => {
                    slider.value = e.target.value;
                    updateVisualizer();
                });
            }

            syncInputs('detailSlider', 'detailNumber');
            syncInputs('lenSlider', 'lenNumber');
            syncInputs('overlapSlider', 'overlapNumber');

            // Logic cập nhật biểu đồ trực quan
            function updateVisualizer() {
                const lenInput = document.getElementById('lenNumber');
                const overlapInput = document.getElementById('overlapNumber');

                if(!lenInput || !overlapInput) return;

                let len = parseInt(lenInput.value) || 1000;
                let overlap = parseInt(overlapInput.value) || 100;

                // Chuẩn hóa tỷ lệ để hiển thị trên div 800px
                const containerWidth = 800; // Chiều rộng giả định của thanh
                const maxLen = 4000;

                // Tính toán chiều rộng % (cho minh họa)
                let widthPercent = (len / maxLen) * 60; // Tối đa chiếm 60% màn hình
                widthPercent = Math.max(15, widthPercent); // Tối thiểu 15%

                let overlapPercent = (overlap / len) * widthPercent;
                overlapPercent = Math.min(overlapPercent, widthPercent / 2); // Đè tối đa nửa cục

                const c1 = document.getElementById('vis-chunk1');
                const c2 = document.getElementById('vis-chunk2');
                const ov = document.getElementById('vis-overlap');

                // Apply CSS
                c1.style.width = widthPercent + '%';
                c1.style.left = '5%';

                ov.style.width = overlapPercent + '%';
                ov.style.left = (5 + widthPercent - overlapPercent) + '%';

                c2.style.width = widthPercent + '%';
                c2.style.left = (5 + widthPercent - overlapPercent) + '%';
            }

            // Gọi lần đầu lúc load
            updateVisualizer();
        });
    </script>
}
