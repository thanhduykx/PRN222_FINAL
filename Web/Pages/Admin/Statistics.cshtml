                </div>
                <div class="ops-table-wrap">
                    <table class="ops-table">
                        <thead><tr><th>Giảng viên phụ trách</th><th>Vai trò</th><th>Môn học (Bộ môn)</th><th>Quyền Upload</th><th>Trạng thái môn</th></tr></thead>
                        <tbody>
                            @foreach (var subject in Model.Dashboard.SubjectUsage)
                            {
                                var owner = string.IsNullOrWhiteSpace(subject.OwnerName) ? subject.OwnerEmail : subject.OwnerName;
                                <tr>
                                    <td data-label="Người dùng">
                                        <div class="ops-user-identity">
                                            <strong>@(string.IsNullOrWhiteSpace(owner) ? "--- Trống ---" : owner)</strong>
                                            @if (!string.IsNullOrWhiteSpace(owner)) { <small>@ShortEmail(subject.OwnerEmail)</small> }
                                        </div>
                                    </td>
                                    <td data-label="Vai trò">@(!string.IsNullOrWhiteSpace(owner) ? "Trưởng bộ môn" : "-")</td>
                                    <td data-label="Môn"><strong>@subject.SubjectCode</strong></td>
                                    <td data-label="Quyền upload">
                                        @if(subject.LecturerCount > 0){ <span class="rbl-status is-default">Có quyền</span> } else { <span class="ops-muted">Không</span> }
                                    </td>
                                    <td data-label="Trạng thái"><span class="rbl-status @(string.IsNullOrWhiteSpace(owner) ? "is-warning" : "is-success")">@(string.IsNullOrWhiteSpace(owner) ? "Cần phân công" : "Active")</span></td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </section>
        }

        @if (Model.Tab == "subscription")
        {
            <section class="ops-kpi-grid ops-stat-kpis">
                <article class="ops-kpi ops-stat-kpi"><span class="material-symbols-outlined ops-kpi-icon is-blue" aria-hidden="true">sell</span><div class="ops-kpi-content"><span>Lượt đăng ký</span><strong>@Model.Dashboard.TotalSubscriptionCount.ToString("N0")</strong></div></article>
                <article class="ops-kpi ops-stat-kpi"><span class="material-symbols-outlined ops-kpi-icon is-green" aria-hidden="true">check_circle</span><div class="ops-kpi-content"><span>Đang hoạt động</span><strong>@Model.Dashboard.ActiveSubscriptionCount.ToString("N0")</strong></div></article>
                <article class="ops-kpi ops-stat-kpi"><span class="material-symbols-outlined ops-kpi-icon is-purple" aria-hidden="true">payments</span><div class="ops-kpi-content"><span>Giao dịch Paid</span><strong>@Model.Dashboard.PaidPaymentCount.ToString("N0")</strong></div></article>
                <article class="ops-kpi ops-stat-kpi"><span class="material-symbols-outlined ops-kpi-icon is-red" aria-hidden="true">cancel</span><div class="ops-kpi-content"><span>Tỷ lệ hủy gói</span><strong>@subscriptionCancelRate.ToString("0.#")%</strong></div></article>
                <article class="ops-kpi ops-stat-kpi"><span class="material-symbols-outlined ops-kpi-icon is-orange" aria-hidden="true">account_balance_wallet</span><div class="ops-kpi-content"><span>Tổng doanh thu</span><strong>@MoneyVnd(Model.Dashboard.PaidRevenueVnd)</strong></div></article>
            </section>

            <div class="ops-stat-two-column">
                <section class="ops-panel">
                    <div class="ops-panel-head">
                        <div><h2>Cơ cấu gói bán ra</h2></div>
                    </div>
                    <div class="ops-subscription-donut-layout">
                        <div class="ops-subscription-donut" style="--subscription-donut:@subscriptionDonut">
                            <span>Tổng Volume</span>
                            <strong>@totalPackageVolume.ToString("N0")</strong>
                        </div>
                        <div class="ops-subscription-mix-table">
                            <div class="ops-subscription-mix-row is-head"><span>Tên Gói</span><span>Số lượng</span><span>Tỷ trọng</span></div>
                            @foreach (var package in Model.Dashboard.PackagePurchases.Select((item, index) => new { item, index }))
                            {
                                var packageVolume = package.item.ActiveSubscriptionCount > 0 ? package.item.ActiveSubscriptionCount : package.item.PaidCount;
                                var packageRate = totalPackageVolume == 0 ? 0 : packageVolume * 100d / totalPackageVolume;
                                <div class="ops-subscription-mix-row">
                                    <span><i style="background:@packageColors[package.index % packageColors.Length]"></i>@package.item.PackageName</span>
                                    <strong>@packageVolume.ToString("N0")</strong>
                                    <span>@packageRate.ToString("0.#")%</span>
                                </div>
                            }
                        </div>
                    </div>
                </section>
                
                <section class="ops-panel">
                    <div class="ops-panel-head">
                        <div><h2>Biểu đồ Tăng trưởng</h2></div>
                    </div>
                    <div class="ops-subscription-chart" style="margin-top: 1.5rem;">
                        <div style="display: flex; gap: 1rem; margin-bottom: 1rem; justify-content: center; font-size: 0.875rem;">
                            <span style="display: flex; align-items: center; gap: 0.5rem;"><i style="width: 12px; height: 12px; background: #4f46e5; border-radius: 2px;"></i> Đăng ký mới</span>
                            <span style="display: flex; align-items: center; gap: 0.5rem;"><i style="width: 12px; height: 12px; background: #10b981; border-radius: 2px;"></i> Thanh toán thành công</span>
                        </div>
                        <div style="display: flex; align-items: flex-end; justify-content: space-between; height: 200px; padding-bottom: 25px; position: relative;">
                            @foreach (var day in Model.Dashboard.DailySubscriptionUsage)
                            {
                                var newHeight = Math.Max(4, day.NewSubscriptionCount * 100 / maxSubscriptionTrend);
                                var paidHeight = Math.Max(4, day.SuccessfulPaymentCount * 100 / maxSubscriptionTrend);
                                <div style="display: flex; flex-direction: column; justify-content: flex-end; align-items: center; height: 100%; flex: 1; position: relative; gap: 2px;">
                                    <span style="width: 30%; max-width: 12px; background: #4f46e5; border-radius: 4px 4px 0 0; height: @newHeight%; transition: height 0.3s;" title="Mới: @day.NewSubscriptionCount"></span>
                                    <span style="width: 30%; max-width: 12px; background: #10b981; border-radius: 4px 4px 0 0; height: @paidHeight%; transition: height 0.3s;" title="Thanh toán: @day.SuccessfulPaymentCount"></span>
                                    <small style="position: absolute; bottom: -20px; font-size: 0.65rem; color: #9ca3af;">@day.DateLabel</small>
                                </div>
                            }
                        </div>
                    </div>
                </section>
            </div>
            
            <section class="ops-panel">
                <div class="ops-panel-head">
                    <div><h2>Lịch sử Giao dịch (Payments)</h2></div>
                </div>
                <div class="ops-table-wrap">
                    <table class="ops-table">
                        <thead><tr><th>Tài khoản Mua</th><th>Tên Gói</th><th>Cổng thanh toán</th><th>Trạng thái</th><th>Thời gian</th></tr></thead>
                        <tbody>
                            @if (Model.Dashboard.RecentPayments.Count == 0)
                            {
                                <tr><td colspan="5"><div class="ops-empty">Chưa có giao dịch nào phát sinh.</div></td></tr>
                            }
                            @foreach (var payment in Model.Dashboard.RecentPayments.Take(8))
                            {
                                <tr>
                                    <td>
                                        <div class="ops-user-identity">
                                            <strong>@payment.UserName</strong>
                                            <small>@ShortEmail(payment.UserEmail)</small>
                                        </div>
                                    </td>
                                    <td><strong>@payment.PackageName</strong></td>
                                    <td>@payment.Provider</td>
                                    <td><span class="rbl-status @StatusClass(payment.Status)">@StatusLabel(payment.Status)</span></td>
                                    <td style="color: var(--text-muted);">@payment.CreatedAt.LocalDateTime.ToString("dd/MM/yyyy HH:mm")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </section>
        }

        @if (Model.Tab == "billing")
        {
            <div class="ops-empty">
                <span class="material-symbols-outlined" style="font-size: 48px; color: #9ca3af; margin-bottom: 1rem;">receipt_long</span>
                <strong>Tab Billing đang được gộp vào Subscription</strong>
                <p>Hãy chuyển sang tab "Gói đăng ký" để xem báo cáo doanh thu nhé.</p>
            </div>
        }

        @if (Model.Tab == "export")
        {
            <section class="ops-panel" style="max-width: 700px; margin: 0 auto;">
                <div class="ops-panel-head">
                    <div>
                        <h2>Công cụ Xuất Báo cáo</h2>
                        <p class="ops-muted mb-0">Thiết lập các tiêu chí trước khi render file Excel/PDF.</p>
                    </div>
                </div>
                <form class="ops-stat-toolbar" style="flex-direction: column; align-items: stretch; gap: 1.5rem;">
                    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem;">
                        <label class="ops-field">
                            <span>Phân hệ báo cáo</span>
                            <select><option>Hiệu suất Chatbot</option><option>Kho Tài liệu</option><option>Báo cáo Doanh thu</option></select>
                        </label>
                        <label class="ops-field">
                            <span>Định dạng File</span>
                            <select><option>Microsoft Excel (.xlsx)</option><option>Tài liệu PDF (.pdf)</option></select>
                        </label>
                    </div>
                    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem;">
                        <label class="ops-field">
                            <span>Phạm vi môn học</span>
                            <select><option>Tất cả các môn</option>@foreach (var subject in Model.Dashboard.SubjectUsage){<option>@subject.SubjectCode</option>}</select>
                        </label>
                        <label class="ops-field">
                            <span>Trạng thái lọc</span>
                            <select><option>Lấy tất cả dữ liệu</option><option>Chỉ lấy Lỗi/Cảnh báo</option></select>
                        </label>
                    </div>
                    
                    <div style="border-top: 1px solid var(--border-color); padding-top: 1.5rem; text-align: right;">
                        <button type="button" class="ops-button ops-button--primary" style="padding: 0.75rem 2rem; font-size: 1rem;">
                            <span class="material-symbols-outlined" aria-hidden="true">cloud_download</span> Generate File Báo Cáo
                        </button>
                    </div>
                </form>
            </section>
        }
    }
</section>