@page
@model PRN222_FINAL.Web.Pages.Admin.StatisticsModel
@{
    ViewData["Title"] = "Báo cáo & Thống kê";
    ViewData["UseRblShell"] = true;
    ViewData["ActiveNav"] = "reports";
    ViewData["ShellTitle"] = "Báo cáo & Thống kê";
    ViewData["ShellTitleI18n"] = "admin.shellTitleStats";
    ViewData["ReportsSection"] = Model.Tab;

    var unansweredQuestions = Math.Max(0, Model.Dashboard.TotalChatQuestions - Model.Dashboard.TotalAssistantAnswers);
    var answerRate = Model.Dashboard.TotalChatQuestions == 0
        ? 0
        : Math.Min(100, (int)Math.Round(Model.Dashboard.TotalAssistantAnswers * 100d / Model.Dashboard.TotalChatQuestions));
    var documentIssueCount = Model.Dashboard.FailedDocuments;
    var subjectsWithoutDocuments = Model.Dashboard.SubjectUsage.Count(subject => subject.DocumentCount == 0);
    var subjectsWithoutOwner = Model.Dashboard.SubjectUsage.Count(subject => !subject.OwnerUserId.HasValue);
    var uploadPermissionCount = Model.Dashboard.SubjectUsage.Count(subject => subject.OwnerUserId.HasValue);
    var topSubjects = Model.Dashboard.SubjectUsage
        .OrderByDescending(subject => subject.ChatCitationCount)
        .ThenByDescending(subject => subject.CourseAccessCount)
        .ThenBy(subject => subject.SubjectCode)
        .Take(6)
        .ToList();
    var maxDailyQuestions = Math.Max(1, Model.Dashboard.DailyChatUsage.Select(day => day.QuestionCount).DefaultIfEmpty(0).Max());
    var hasChatData = Model.Dashboard.DailyChatUsage.Count > 0 || Model.Dashboard.TopChatUsers.Count > 0;
    var semesterReturnRate = Model.SemesterDashboard.ActiveChatUsers == 0
        ? 0
        : Math.Min(100, (int)Math.Round(Model.SemesterDashboard.ReturningChatUsers * 100d / Model.SemesterDashboard.ActiveChatUsers));
    var semesterTopSubjects = Model.SemesterDashboard.SubjectUsage
        .Where(subject => subject.ChatCitationCount > 0)
        .OrderByDescending(subject => subject.ChatCitationCount)
        .ThenByDescending(subject => subject.CourseAccessCount)
        .Take(5)
        .ToList();
    var semesterTopSubject = semesterTopSubjects.FirstOrDefault();
    var semesterTopUser = Model.SemesterDashboard.TopChatUsers.FirstOrDefault();
    var maxSemesterTimeSlotQuestions = Math.Max(1, Model.SemesterDashboard.ChatTimeSlotUsage
        .Select(slot => slot.QuestionCount)
        .DefaultIfEmpty(0)
        .Max());
    var dailyChartPoints = Model.Dashboard.DailyChatUsage
        .Select((day, index) =>
        {
            var x = Model.Dashboard.DailyChatUsage.Count <= 1 ? 50 : 5 + (index * 90d / (Model.Dashboard.DailyChatUsage.Count - 1));
            var y = 88 - (day.QuestionCount * 72d / maxDailyQuestions);
            return new { Day = day, X = x, Y = y };
        })
        .ToList();
    var dailyChartPath = string.Join(" ", dailyChartPoints.Select(point => string.Create(System.Globalization.CultureInfo.InvariantCulture, $"{point.X:0.##},{point.Y:0.##}")));
    var maxSubscriptionTrend = Math.Max(1, Model.Dashboard.DailySubscriptionUsage
        .Select(day => Math.Max(day.NewSubscriptionCount, day.SuccessfulPaymentCount))
        .DefaultIfEmpty(0)
        .Max());
    var totalPackageVolume = Math.Max(1, Model.Dashboard.PackagePurchases
        .Sum(package => package.ActiveSubscriptionCount > 0 ? package.ActiveSubscriptionCount : package.PaidCount));
    var subscriptionCancelRate = Model.Dashboard.TotalSubscriptionCount == 0
        ? 0
        : Math.Round(Model.Dashboard.CanceledSubscriptionCount * 100d / Model.Dashboard.TotalSubscriptionCount, 1);
    var topSubscriptionPackage = Model.Dashboard.PackagePurchases
        .OrderByDescending(package => package.ActiveSubscriptionCount)
        .ThenByDescending(package => package.PaidCount)
        .FirstOrDefault();
    var packageColors = new[] { "#1f7af2", "#48c987", "#7b5fe3", "#ffa447", "#21b6c7", "#ef5c5c" };
    var donutCursor = 0d;
    var donutStops = new List<string>();
    for (var packageIndex = 0; packageIndex < Model.Dashboard.PackagePurchases.Count; packageIndex++)
    {
        var package = Model.Dashboard.PackagePurchases[packageIndex];
        var packageVolume = package.ActiveSubscriptionCount > 0 ? package.ActiveSubscriptionCount : package.PaidCount;
        if (packageVolume <= 0)
        {
            continue;
        }

        var nextCursor = donutCursor + packageVolume * 100d / totalPackageVolume;
        donutStops.Add(string.Create(System.Globalization.CultureInfo.InvariantCulture, $"{packageColors[packageIndex % packageColors.Length]} {donutCursor:0.##}% {nextCursor:0.##}%"));
        donutCursor = nextCursor;
    }

    var subscriptionDonut = donutStops.Count == 0 ? "#e5eef8 0% 100%" : string.Join(", ", donutStops);
    var tabs = new[]
    {
        new { Key = "overview", Label = "Tổng quan" },
        new { Key = "chatbot", Label = "Chatbot" },
        new { Key = "documents", Label = "Tài liệu" },
        new { Key = "users", Label = "Người dùng" },
        new { Key = "permissions", Label = "Phân quyền" },
        new { Key = "subscription", Label = "Gói đăng ký" }
    };



    string TabUrl(string tab) => Url.Page("/Admin/Statistics", new { tab, days = Model.Days }) ?? "#";
    string TabClass(string tab) => $"ops-tab{(Model.Tab == tab ? " is-active" : "")}";
    string ReportDate(DateTimeOffset value) => value.ToLocalTime().ToString("dd/MM/yyyy");
    string ReportTimestamp(DateTimeOffset value) => value.ToLocalTime().ToString("HH:mm, dd/MM/yyyy");
    string ProviderLabel(string provider) => provider.Equals("PayOS", StringComparison.OrdinalIgnoreCase) ? "VietQR" : provider;
    string PercentLabel(int numerator, int denominator) => denominator <= 0 ? "0%" : $"{Math.Min(100, (int)Math.Round(numerator * 100d / denominator))}%";
    string MoneyVnd(decimal value) => value >= 1_000_000 ? $"{value / 1_000_000m:N1}M" : $"{value:N0}đ";
    string UserInitial(string value) => string.IsNullOrWhiteSpace(value) ? "U" : value.Trim()[..1].ToUpperInvariant();
    string ShortEmail(string value)
    {
        if (string.IsNullOrWhiteSpace(value)) return "-";
        var parts = value.Split('@', 2);
        if (parts.Length != 2 || parts[0].Length <= 8) return value;
        return $"{parts[0][..8]}...@{parts[1]}";
    }
    string StatusClass(string status) => status switch
    {
        "Indexed" => "is-success",
        "Processing" => "is-running",
        "Paid" => "is-success",
        "Pending" => "is-running",
        "Active" => "is-success",
        _ => "is-error"
    };
    string StatusLabel(string status) => status switch
    {
        "Indexed" => "Đã index",
        "Processing" => "Đang xử lý",
        "Failed" => "Thất bại",
        "Paid" => "Đã thanh toán",
        "Pending" => "Chờ xử lý",
        "Canceled" => "Đã hủy",
        _ => status
    };
}

<section class="ops-page ops-statistics-page">
    <div class="ops-stat-header">
        <div>
            <h1><span data-i18n="stat.title">Báo cáo &amp; Thống kê</span></h1>
            <p data-i18n="stat.description">Phân tích hoạt động chatbot, tài liệu, người dùng và phân quyền trong hệ thống.</p>
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
    {
        <div class="rbl-alert is-error">@Model.ErrorMessage</div>
    }
    else
    {
        <nav class="ops-tabs" aria-label="Báo cáo và thống kê">
            @foreach (var tab in tabs)
            {
                <a class="@TabClass(tab.Key)" href="@TabUrl(tab.Key)" aria-current="@(Model.Tab == tab.Key ? "page" : null)"><span data-i18n="admin.statTab.@tab.Key">@tab.Label</span></a>
            }
        </nav>

        <form method="get" class="ops-report-scope" aria-label="Chọn phạm vi dữ liệu báo cáo" data-i18n-aria-label="admin.reportScopeAria">
            <input type="hidden" name="tab" value="@Model.Tab" />
            @if (Model.Tab == "chatbot")
            {
                <input type="hidden" name="semester" value="@Model.Semester" />
                <input type="hidden" name="academicYear" value="@Model.AcademicYear" />
            }
            <div class="ops-report-scope__main">
                <span class="material-symbols-outlined" aria-hidden="true">date_range</span>
                <div>
                    <strong><span data-i18n="admin.scopeLabel">Phạm vi:</span> @ReportDate(Model.Dashboard.FromUtc) – @ReportDate(Model.Dashboard.ToUtc)</strong>
                    <span data-i18n="admin.scopeAll">Tất cả môn học · Tất cả người dùng · Múi giờ địa phương</span>
                </div>
            </div>
            <label class="ops-report-period-control">
                <span data-i18n="admin.time">Thời gian</span>
                <select asp-for="Days" onchange="this.form.submit()" aria-label="Chọn khoảng thời gian báo cáo" data-i18n-aria-label="admin.timeSelectAria">
                    <option value="7" data-i18n="admin.days7">7 ngày gần nhất</option>
                    <option value="30" data-i18n="admin.days30">30 ngày gần nhất</option>
                    <option value="90" data-i18n="admin.days90">90 ngày gần nhất</option>
                    <option value="180" data-i18n="admin.days180">180 ngày gần nhất</option>
                </select>
            </label>
            <div class="ops-report-scope__freshness" title="Thời điểm hệ thống tổng hợp dữ liệu báo cáo" data-i18n-title="admin.updatedAtTooltip">
                <span class="ops-data-status" aria-hidden="true"></span>
                <span data-i18n="admin.updatedAt">Cập nhật</span> @ReportTimestamp(Model.Dashboard.GeneratedAt)
            </div>
            @if (Model.Days != 30)
            {
                <a class="ops-report-scope__reset" asp-page="/Admin/Statistics" asp-route-tab="@Model.Tab" asp-route-days="30" data-i18n="admin.reset30">Đặt lại 30 ngày</a>
            }
        </form>

        @if (Model.Tab == "overview")
        {
            <section class="analytics-assistant" aria-labelledby="analyticsAssistantTitle">
                <div class="analytics-assistant__head">
                    <div class="analytics-assistant__title">
                        <span class="material-symbols-outlined" aria-hidden="true">auto_awesome</span>
                        <div>
                            <h2 id="analyticsAssistantTitle" data-i18n="admin.aiAssistantTitle">Trợ lý phân tích</h2>
                            <p data-i18n="admin.aiAssistantDesc">Đọc các chỉ số trong phạm vi đang chọn và đề xuất việc nên ưu tiên.</p>
                        </div>
                    </div>
                    <form method="post" asp-page-handler="GenerateRecommendations">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="Days" value="@Model.Days" />
                        <input type="hidden" name="Tab" value="overview" />
                        <button type="submit" class="ops-button ops-button--primary">
                            <span class="material-symbols-outlined" aria-hidden="true">psychology</span>
                            <span data-i18n="admin.aiAnalyzeBtn">Phân tích và đề xuất</span>
                        </button>
                    </form>
                </div>
                @if (Model.AiRecommendations.Count == 0)
                {
                    <div class="analytics-assistant__empty">
                        <span class="material-symbols-outlined" aria-hidden="true">tips_and_updates</span>
                        <p data-i18n="admin.aiEmptyState">Nhấn nút để nhận tối đa 4 đề xuất dựa trên câu hỏi, học liệu, người dùng và thanh toán.</p>
                    </div>
                }
                else
                {
                    <div class="analytics-recommendation-grid">
                        @foreach (var recommendation in Model.AiRecommendations)
                        {
                            <article class="analytics-recommendation is-@recommendation.Priority">
                                <div>
                                    <span>
                                        @if(recommendation.Priority == "high") { <span data-i18n="admin.priHigh">Ưu tiên cao</span> }
                                        else if(recommendation.Priority == "low") { <span data-i18n="admin.priLow">Theo dõi</span> }
                                        else { <span data-i18n="admin.priNormal">Nên xử lý</span> }
                                    </span>
                                    <small>
                                        @if(recommendation.GeneratedByAi) { <span data-i18n="admin.genAi">AI phân tích</span> }
                                        else { <span data-i18n="admin.genRules">Quy tắc thống kê</span> }
                                    </small>
                                </div>
                                <h3>@recommendation.Title</h3>
                                <p>@recommendation.Reason</p>
                                <strong>@recommendation.Action</strong>
                            </article>
                        }
                    </div>
                }
            </section>

            <section class="ops-kpi-grid ops-stat-kpis" aria-label="Chỉ số tổng quan">
                <article class="ops-kpi ops-stat-kpi">
                    <span class="material-symbols-outlined ops-kpi-icon is-blue" aria-hidden="true">chat_bubble</span>
                    <div class="ops-kpi-content">
                        <span data-i18n="admin.chatQuestions">Câu hỏi chat</span>
                        <strong>@Model.Dashboard.TotalChatQuestions.ToString("N0")</strong>
                        <small>@Model.Days <span data-i18n="stat.lastDays">ngày gần nhất</span></small>
                    </div>
                </article>
                <article class="ops-kpi ops-stat-kpi">
                    <span class="material-symbols-outlined ops-kpi-icon is-blue" aria-hidden="true">person</span>
                    <div class="ops-kpi-content">
                        <span data-i18n="admin.activeStudents">Sinh viên hoạt động</span>
                        <strong>@Model.Dashboard.ActiveChatUsers.ToString("N0")</strong>
                        <small>@Model.StudentUsers.ToString("N0") <span data-i18n="stat.studentsInSystem">sinh viên trong hệ thống</span></small>
                    </div>
                </article>
                <article class="ops-kpi ops-stat-kpi">
                    <span class="material-symbols-outlined ops-kpi-icon is-green" aria-hidden="true">database</span>
                    <div class="ops-kpi-content">
                        <span data-i18n="admin.docsReady">Học liệu sẵn sàng</span>
                        <strong>@PercentLabel(Model.Dashboard.IndexedDocuments, Model.Dashboard.TotalDocuments)</strong>
                        <small>@Model.Dashboard.IndexedDocuments.ToString("N0")/@Model.Dashboard.TotalDocuments.ToString("N0") <span data-i18n="admin.docsIndexed">tài liệu đã index</span></small>
                    </div>
                </article>
                <article class="ops-kpi ops-stat-kpi">
                    <span class="material-symbols-outlined ops-kpi-icon is-green" aria-hidden="true">check_circle</span>
                    <div class="ops-kpi-content">
                        <span><span data-i18n="stat.answerRate">Tỷ lệ trả lời được</span></span>
                        <strong>@answerRate%</strong>
                        <small data-i18n="stat.basedOnAnswers">Dựa trên phản hồi trợ lý</small>
                    </div>
                </article>
            </section>

            <section class="ops-stat-alert-strip" aria-label="Cảnh báo nhanh">
                <article class="ops-stat-alert-card">
                    <span class="material-symbols-outlined ops-kpi-icon is-orange" aria-hidden="true">help</span>
                    <div class="ops-kpi-content">
                        <span><span data-i18n="stat.unanswered">Chưa trả lời</span></span>
                        <strong>@unansweredQuestions.ToString("N0")</strong>
                        <small><span data-i18n="stat.needMoreSources">Cần bổ sung nguồn học liệu</span></small>
                    </div>
                </article>
                <article class="ops-stat-alert-card">
                    <span class="material-symbols-outlined ops-kpi-icon is-red" aria-hidden="true">warning</span>
                    <div class="ops-kpi-content">
                        <span><span data-i18n="stat.docErrors">Lỗi tài liệu</span></span>
                        <strong>@documentIssueCount.ToString("N0")</strong>
                        <small><span data-i18n="stat.indexFailed">Index thất bại</span></small>
                    </div>
                </article>
            </section>

            <div class="ops-stat-two-column">
                <section class="ops-panel ops-stat-chart-panel">
                    <div class="ops-panel-head">
                        <div>
                            <h2 data-i18n="stat.dailyChatUsage">Sử dụng chat theo ngày</h2>
                            <p class="ops-muted mb-0" data-i18n="stat.dailyChatUsageDesc">Admin theo dõi ngày nào sinh viên hỏi nhiều để kịp bổ sung tài liệu.</p>
                        </div>
                        <span class="ops-panel-note" data-i18n="admin.chatQuestionsNote">Câu hỏi chat</span>
                    </div>
                    @if (Model.Dashboard.DailyChatUsage.Count == 0)
                    {
                        <div class="ops-empty ops-stat-empty">
                            <strong data-i18n="stat.noChatData">Chưa có dữ liệu chat</strong>
                            <p data-i18n="stat.noChatDataDesc2">Sinh viên chưa sử dụng chatbot trong khoảng thời gian này. Thử đổi bộ lọc ngày hoặc kiểm tra dữ liệu chat.</p>
                        </div>
                    }
                    else
                    {
                        <div class="ops-line-chart" aria-label="Biểu đồ sử dụng chat theo ngày" data-i18n-aria-label="admin.dailyChartAria">
                            <svg class="ops-line-chart__svg" viewBox="0 0 100 100" preserveAspectRatio="none" aria-hidden="true">
                                <defs>
                                    <linearGradient id="chatUsageFill" x1="0" x2="0" y1="0" y2="1">
                                        <stop offset="0%" stop-color="#0a7cf5" stop-opacity=".22" />
                                        <stop offset="100%" stop-color="#0a7cf5" stop-opacity="0" />
                                    </linearGradient>
                                </defs>
                                <polyline class="ops-line-chart__area" points="5,92 @dailyChartPath 95,92" />
                                <polyline class="ops-line-chart__line" points="@dailyChartPath" />
                            </svg>
                            <div class="ops-line-chart__markers">
                                @foreach (var point in dailyChartPoints)
                                {
                                    <span class="ops-line-chart__marker" style="left:@string.Create(System.Globalization.CultureInfo.InvariantCulture, $"{point.X:0.##}")%; top:@string.Create(System.Globalization.CultureInfo.InvariantCulture, $"{point.Y:0.##}")%;" title="@point.Day.QuestionCount.ToString("N0") câu hỏi"></span>
                                }
                            </div>
                            <div class="ops-line-chart__labels">
                                @foreach (var point in dailyChartPoints)
                                {
                                    <small>@point.Day.DateLabel</small>
                                }
                            </div>
                        </div>
                    }
                </section>

                <section class="ops-panel ops-action-panel">
                    <div class="ops-panel-head">
                        <div>
                            <h2 data-i18n="stat.needsAction">Cần xử lý</h2>
                            <p class="ops-muted mb-0" data-i18n="stat.needsActionDesc">Các tín hiệu cần admin kiểm tra trước.</p>
                        </div>
                    </div>
                    <div class="ops-action-list">
                        <div class="ops-action-item is-orange"><span class="material-symbols-outlined" aria-hidden="true">help</span><strong>@unansweredQuestions</strong> <span data-i18n="stat.unansweredQuestions">câu hỏi chưa được chatbot trả lời</span></div>
                        <div class="ops-action-item is-red"><span class="material-symbols-outlined" aria-hidden="true">error</span><strong>@Model.Dashboard.FailedDocuments</strong> <span data-i18n="stat.docsIndexFailed">tài liệu index thất bại</span></div>
                        <div class="ops-action-item is-orange"><span class="material-symbols-outlined" aria-hidden="true">folder_off</span><strong>@subjectsWithoutDocuments</strong> <span data-i18n="stat.subjectsNoDocs">môn học chưa có tài liệu</span></div>
                        <div class="ops-action-item is-blue"><span class="material-symbols-outlined" aria-hidden="true">manage_accounts</span><strong>@subjectsWithoutOwner</strong> <span data-i18n="stat.subjectsNoLeader">môn học chưa có người phụ trách</span></div>
                    </div>
                    <a class="ops-button ops-button--secondary ms-auto" href="@TabUrl("documents")">
                        <span data-i18n="admin.viewDetails">Xem chi tiết</span>
                        <span class="material-symbols-outlined" aria-hidden="true">arrow_forward</span>
                    </a>
                </section>
            </div>

            <div class="ops-stat-two-column">
                <section class="ops-panel ops-overview-ranking-card">
                    <div class="ops-panel-head ops-overview-ranking-head">
                        <div class="ops-overview-heading">
                            <span class="material-symbols-outlined is-indigo" aria-hidden="true">leaderboard</span>
                            <div>
                                <h2 data-i18n="stat.topSubjects">Môn học được hỏi nhiều</h2>
                                <p class="ops-muted mb-0" data-i18n="stat.topSubjectsDesc">Danh sách các môn học được trợ lý trích dẫn nhiều nhất để trả lời câu hỏi.</p>
                            </div>
                        </div>
                        <a class="ops-panel-note" href="@TabUrl("documents")" data-i18n="admin.viewAll">Xem tất cả</a>
                    </div>
                    <div class="ops-table-wrap ops-overview-subject-table">
                        <table class="ops-table ops-compact-table">
                            <caption class="visually-hidden" data-i18n="admin.topSubjectsCaption">Các môn học có nhiều lượt trích dẫn trong chatbot</caption>
                            <thead>
                                <tr>
                                    <th aria-label="Xếp hạng">#</th>
                                    <th data-i18n="stat.thSubject">Môn học</th>
                                    <th data-i18n="stat.thQuestions">Câu hỏi</th>
                                    <th data-i18n="stat.thDocs">Tài liệu</th>
                                    <th data-i18n="stat.thReadiness">Tỷ lệ sẵn sàng</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (topSubjects.Count == 0)
                                {
                                    <tr>
                                        <td colspan="5">
                                            <div class="ops-empty ops-stat-empty ops-stat-empty--compact">
                                                <span class="material-symbols-outlined" aria-hidden="true">menu_book</span>
                                                <strong data-i18n="admin.noData">Chưa có dữ liệu</strong>
                                                <p data-i18n="admin.noSubjectsQueried">Không có môn học nào được hỏi trong khoảng thời gian này.</p>
                                            </div>
                                        </td>
                                    </tr>
                                }
                                @foreach (var rankedSubject in topSubjects.Select((subject, index) => new { subject, index }))
                                {
                                    var subject = rankedSubject.subject;
                                    var readiness = subject.DocumentCount == 0 ? 0 : Math.Min(100, (int)Math.Round(subject.IndexedDocumentCount * 100d / subject.DocumentCount));
                                    <tr>
                                        <td data-label="#"><span class="ops-overview-rank is-rank-@(rankedSubject.index + 1)">@(rankedSubject.index + 1)</span></td>
                                        <td data-label="Môn học" data-i18n-data-label="stat.thSubject"><div class="ops-stack"><strong>@subject.SubjectCode</strong><small>@subject.SubjectName</small></div></td>
                                        <td data-label="Câu hỏi" data-i18n-data-label="stat.thQuestions">@subject.ChatCitationCount.ToString("N0")</td>
                                        <td data-label="Tài liệu" data-i18n-data-label="stat.thDocs">@subject.DocumentCount.ToString("N0")</td>
                                        <td data-label="Tỷ lệ sẵn sàng" data-i18n-data-label="stat.thReadiness">
                                            <div class="ops-overview-readiness">
                                                <small>@readiness%</small>
                                                <div class="ops-progress" aria-label="Mức sẵn sàng @readiness%">
                                                    <span style="width:@readiness%"></span>
                                                </div>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </section>

                <section class="ops-panel ops-overview-ranking-card">
                    <div class="ops-panel-head ops-overview-ranking-head">
                        <div class="ops-overview-heading">
                            <span class="material-symbols-outlined is-indigo" aria-hidden="true">group</span>
                            <div>
                                <h2 data-i18n="stat.topChatUsers">Người dùng hỏi nhiều nhất</h2>
                                <p class="ops-muted mb-0" data-i18n="stat.topChatUsersDesc">Biết được những sinh viên đang tận dụng trợ lý học tập nhiều nhất.</p>
                            </div>
                        </div>
                        <a class="ops-panel-note" href="@TabUrl("users")" data-i18n="admin.viewAll">Xem tất cả</a>
                    </div>
                    <div class="ops-ranked-list ops-overview-user-list">
                        @foreach (var user in Model.Dashboard.TopChatUsers.Take(5).Select((item, index) => new { item, index }))
                        {
                            <div class="ops-ranked-item ops-overview-user-row">
                                <span class="ops-overview-user-rank">@(user.index + 1)</span>
                                <span class="ops-avatar @(user.index % 2 == 0 ? "is-blue" : "is-violet")">@UserInitial(user.item.UserName)</span>
                                <div class="ops-user-identity">
                                    <strong>@user.item.UserName</strong>
                                    <small>@ShortEmail(user.item.UserEmail)</small>
                                </div>
                                <strong class="ops-overview-question-count">@user.item.QuestionCount.ToString("N0") <span data-i18n="admin.questionsUnit">câu hỏi</span></strong>
                            </div>
                        }
                        @if (Model.Dashboard.TopChatUsers.Count == 0)
                        {
                            <div class="ops-empty ops-stat-empty">
                                <strong data-i18n="stat.noChatData">Chưa có dữ liệu chat</strong>
                                <p data-i18n="stat.noChatDataDesc">Sinh viên chưa sử dụng chatbot trong khoảng thời gian này.</p>
                            </div>
                        }
                    </div>
                </section>
            </div>

            <section class="ops-panel ops-overview-insights">
                <header class="ops-overview-insights__head">
                    <span class="material-symbols-outlined" aria-hidden="true">auto_awesome</span>
                    <strong data-i18n="stat.quickInsight">Insight nhanh</strong>
                </header>
                <div class="ops-overview-insights__grid">
                    <article class="ops-overview-insight is-blue">
                        <span class="material-symbols-outlined" aria-hidden="true">trending_up</span>
                        <div>
                            <strong>@(topSubjects.FirstOrDefault()?.SubjectCode ?? "Môn học")</strong>
                            <small data-i18n="stat.mostCitedSubjectShort">là môn được trích dẫn nhiều nhất</small>
                        </div>
                    </article>
                    <article class="ops-overview-insight is-orange">
                        <span class="material-symbols-outlined" aria-hidden="true">priority_high</span>
                        <div>
                            <strong>@unansweredQuestions.ToString("N0") câu hỏi</strong>
                            <small data-i18n="stat.needsReviewShort">cần xem lại</small>
                        </div>
                    </article>
                    <article class="ops-overview-insight is-green">
                        <span class="material-symbols-outlined" aria-hidden="true">task</span>
                        <div>
                            <strong>@Model.Dashboard.IndexedDocuments.ToString("N0")/@Model.Dashboard.TotalDocuments.ToString("N0") tài liệu</strong>
                            <small data-i18n="stat.readyForChatbotShort">sẵn sàng cho chatbot</small>
                        </div>
                    </article>
                </div>
            </section>
        }

        @if (Model.Tab == "chatbot")
        {
            <section class="ops-kpi-grid ops-stat-kpis">
                <article class="ops-kpi ops-stat-kpi"><span class="material-symbols-outlined ops-kpi-icon is-blue" aria-hidden="true">chat</span><div class="ops-kpi-content"><span data-i18n="admin.totalQuestions">Tổng câu hỏi</span><strong>@Model.Dashboard.TotalChatQuestions.ToString("N0")</strong><small>@Model.Days <span data-i18n="stat.lastDays">ngày gần nhất</span></small></div></article>
                <article class="ops-kpi ops-stat-kpi"><span class="material-symbols-outlined ops-kpi-icon is-indigo" aria-hidden="true">forum</span><div class="ops-kpi-content"><span data-i18n="admin.totalChatSessions">Tổng phiên chat</span><strong>@Model.Dashboard.TotalChatSessions.ToString("N0")</strong><small>@Model.Dashboard.ActiveChatUsers.ToString("N0") <span data-i18n="stat.activeUsersUnit">user hoạt động</span></small></div></article>
                <article class="ops-kpi ops-stat-kpi"><span class="material-symbols-outlined ops-kpi-icon is-green" aria-hidden="true">task_alt</span><div class="ops-kpi-content"><span><span data-i18n="stat.answerRate">Tỷ lệ trả lời được</span></span><strong>@answerRate%</strong><small>@Model.Dashboard.TotalAssistantAnswers.ToString("N0") <span data-i18n="stat.assistantResponsesUnit">phản hồi assistant</span></small></div></article>
                <article class="ops-kpi ops-stat-kpi"><span class="material-symbols-outlined ops-kpi-icon is-orange" aria-hidden="true">help</span><div class="ops-kpi-content"><span data-i18n="stat.unanswered">Câu hỏi chưa trả lời</span><strong>@unansweredQuestions.ToString("N0")</strong><small data-i18n="stat.needMoreData">Cần bổ sung dữ liệu</small></div></article>
            </section>

            <section class="ops-data-note" aria-label="Giới hạn dữ liệu chatbot" data-i18n-aria-label="admin.chatbotLimitsAria">
                <span class="material-symbols-outlined" aria-hidden="true">info</span>
                <div>
                    <strong data-i18n="admin.currentMeasurementScope">Phạm vi đo lường hiện tại</strong>
                    <p data-i18n="admin.measurementScopeDesc">Báo cáo đang tổng hợp số câu hỏi, phiên chat và người dùng hoạt động. Feedback và thời gian phản hồi chưa được thu thập nên không được hiển thị như KPI.</p>
                </div>
            </section>

            <section class="ops-semester-analysis" aria-labelledby="semesterAnalysisTitle">
                <header class="ops-semester-analysis__head">
                    <div>
                        <span class="ops-section-eyebrow">Phân tích theo học kỳ</span>
                        <h2 id="semesterAnalysisTitle">@Model.SemesterLabel</h2>
                        <p>Spring: tháng 1 - 4 · Summer: tháng 5 - 8 · Fall: tháng 9 - 12</p>
                    </div>
                    <form method="get" class="ops-semester-controls">
                        <input type="hidden" name="tab" value="chatbot" />
                        <input type="hidden" name="days" value="@Model.Days" />
                        <div class="ops-semester-field">
                            <label for="semesterSelect">Học kỳ</label>
                            <select id="semesterSelect" asp-for="Semester" onchange="this.form.submit()"><option value="spring">Spring</option><option value="summer">Summer</option><option value="fall">Fall</option></select>
                        </div>
                        <div class="ops-semester-field">
                            <label for="academicYearSelect">Năm</label>
                            <select id="academicYearSelect" asp-for="AcademicYear" onchange="this.form.submit()">@foreach (var year in Model.AcademicYears) { <option value="@year">@year</option> }</select>
                        </div>
                    </form>
                </header>

                <div class="ops-semester-summary">
                    <article><span class="material-symbols-outlined is-blue" aria-hidden="true">groups</span><div><small>Sinh viên truy cập</small><strong>@Model.SemesterDashboard.ActiveChatUsers.ToString("N0")</strong><p>@Model.SemesterDashboard.TotalChatQuestions.ToString("N0") câu hỏi trong kỳ</p></div></article>
                    <article><span class="material-symbols-outlined is-green" aria-hidden="true">replay</span><div><small>Tỷ lệ quay lại dùng</small><strong>@semesterReturnRate%</strong><p>@Model.SemesterDashboard.ReturningChatUsers.ToString("N0") người dùng từ 2 ngày trở lên</p></div></article>
                    <article><span class="material-symbols-outlined is-purple" aria-hidden="true">school</span><div><small>Môn được hỏi nhiều nhất</small><strong>@(semesterTopSubject?.SubjectCode ?? "-")</strong><p>@(semesterTopSubject is null ? "Chưa có dữ liệu" : $"{semesterTopSubject.ChatCitationCount:N0} câu hỏi có nguồn")</p></div></article>
                    <article><span class="material-symbols-outlined is-orange" aria-hidden="true">workspace_premium</span><div><small>Người hỏi nhiều nhất</small><strong>@(semesterTopUser?.UserName ?? "-")</strong><p>@(semesterTopUser is null ? "Chưa có dữ liệu" : $"{semesterTopUser.QuestionCount:N0} câu hỏi · {semesterTopUser.SessionCount:N0} phiên")</p></div></article>
                </div>

                <div class="ops-semester-grid">
                    <article class="ops-semester-card ops-time-analysis">
                        <div class="ops-semester-card__head"><div><h3>Thời điểm sinh viên truy cập</h3><p>Tỷ trọng câu hỏi theo từng khung giờ trong ngày</p></div></div>
                        <div class="ops-time-bars">
                            @foreach (var slot in Model.SemesterDashboard.ChatTimeSlotUsage)
                            {
                                var slotPercent = Model.SemesterDashboard.TotalChatQuestions == 0 ? 0 : Math.Round(slot.QuestionCount * 100d / Model.SemesterDashboard.TotalChatQuestions, 1);
                                var slotWidth = slot.QuestionCount * 100d / maxSemesterTimeSlotQuestions;
                                <div class="ops-time-bar">
                                    <div class="ops-time-bar__label"><strong>@slot.Label</strong><span>@slotPercent% · @slot.ActiveUserCount người</span></div>
                                    <div class="ops-time-bar__track"><span style="width: @string.Create(System.Globalization.CultureInfo.InvariantCulture, $"{slotWidth:0.##}%")"></span></div>
                                    <b>@slot.QuestionCount.ToString("N0")</b>
                                </div>
                            }
                        </div>
                    </article>

                    <article class="ops-semester-card ops-subject-ranking">
                        <div class="ops-semester-card__head"><div><h3>Môn được hỏi nhiều nhất</h3><p>Xếp hạng trong @Model.SemesterLabel</p></div></div>
                        @if (semesterTopSubjects.Count == 0)
                        {
                            <div class="ops-semester-empty"><strong>Chưa có dữ liệu</strong><span>Học kỳ này chưa ghi nhận môn học.</span></div>
                        }
                        else
                        {
                            <div class="ops-table-wrap"><table class="ops-table ops-compact-table">
                                <thead><tr><th>#</th><th>Môn học</th><th>Câu hỏi có nguồn</th><th>Lần gần nhất</th></tr></thead>
                                <tbody>@for (var subjectIndex = 0; subjectIndex < semesterTopSubjects.Count; subjectIndex++) { var subject = semesterTopSubjects[subjectIndex]; <tr><td>@(subjectIndex + 1)</td><td><strong>@subject.SubjectCode</strong><small>@subject.SubjectName</small></td><td>@subject.ChatCitationCount.ToString("N0")</td><td>@(subject.LastChatAt?.LocalDateTime.ToString("dd/MM HH:mm") ?? "-")</td></tr> }</tbody>
                            </table></div>
                        }
                    </article>
                </div>

                <article class="ops-semester-card ops-semester-users">
                    <div class="ops-semester-card__head"><div><h3>Sinh viên hỏi nhiều nhất</h3><p>Các tài khoản hoạt động nổi bật trong @Model.SemesterLabel</p></div></div>
                    @if (Model.SemesterDashboard.TopChatUsers.Count == 0)
                    {
                        <div class="ops-semester-empty"><strong>Chưa có dữ liệu</strong><span>Chưa có sinh viên đặt câu hỏi trong học kỳ này.</span></div>
                    }
                    else
                    {
                        <div class="ops-table-wrap"><table class="ops-table ops-compact-table">
                            <thead><tr><th>Người dùng</th><th>Email</th><th>Câu hỏi</th><th>Phiên chat</th><th>Lần gần nhất</th></tr></thead>
                            <tbody>
                                @for (var userIndex = 0; userIndex < Math.Min(5, Model.SemesterDashboard.TopChatUsers.Count); userIndex++)
                                {
                                    var user = Model.SemesterDashboard.TopChatUsers[userIndex];
                                    <tr><td><strong>@user.UserName</strong></td><td>@ShortEmail(user.UserEmail)</td><td><strong>@user.QuestionCount.ToString("N0")</strong></td><td>@user.SessionCount.ToString("N0")</td><td>@(user.LastQuestionAt?.LocalDateTime.ToString("dd/MM/yyyy HH:mm") ?? "-")</td></tr>
                                }
                            </tbody>
                        </table></div>
                    }
                </article>
            </section>

            <section class="ops-panel">
                <div class="ops-panel-head">
                    <div>
                        <h2 data-i18n="stat.dailyChatUsage">Sử dụng chat theo ngày</h2>
                        <p class="ops-muted mb-0" data-i18n="admin.compactTableDesc">Bảng gọn thay cho nhiều bảng dàn trải trên cùng một màn hình.</p>
                    </div>
                </div>
                @if (!hasChatData)
                {
                    <div class="ops-empty ops-stat-empty"><strong data-i18n="stat.noChatData">Chưa có dữ liệu chat</strong><p data-i18n="stat.noChatDataDesc2">Sinh viên chưa sử dụng chatbot trong khoảng thời gian này. Thử đổi bộ lọc ngày hoặc kiểm tra dữ liệu chat.</p></div>
                }
                else
                {
                    <div class="ops-table-wrap">
                        <table class="ops-table ops-compact-table">
                            <caption class="visually-hidden" data-i18n="admin.chatbotDailyUsageCaption">Sử dụng chatbot theo từng ngày trong phạm vi báo cáo</caption>
                            <thead><tr><th data-i18n="admin.thDate">Ngày</th><th data-i18n="stat.thQuestions">Câu hỏi</th><th data-i18n="admin.thChatSessions">Phiên chat</th><th data-i18n="admin.thActiveUsers">Người dùng hoạt động</th></tr></thead>
                            <tbody>
                                @foreach (var day in Model.Dashboard.DailyChatUsage)
                                {
                                    <tr><td data-label="Ngày" data-i18n-data-label="admin.thDate">@day.DateLabel</td><td data-label="Câu hỏi" data-i18n-data-label="stat.thQuestions">@day.QuestionCount.ToString("N0")</td><td data-label="Phiên chat" data-i18n-data-label="admin.thChatSessions">@day.SessionCount.ToString("N0")</td><td data-label="Người dùng hoạt động" data-i18n-data-label="admin.thActiveUsers">@day.ActiveUserCount.ToString("N0")</td></tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </section>
        }

        @if (Model.Tab == "documents")
        {
            <section class="ops-kpi-grid ops-stat-kpis">
                <article class="ops-kpi ops-stat-kpi"><span class="material-symbols-outlined ops-kpi-icon is-purple" aria-hidden="true">description</span><div class="ops-kpi-content"><span data-i18n="admin.totalDocs">Tổng tài liệu</span><strong>@Model.Dashboard.TotalDocuments.ToString("N0")</strong><small data-i18n="admin.inAllSystem">Trong toàn hệ thống</small></div></article>
                <article class="ops-kpi ops-stat-kpi"><span class="material-symbols-outlined ops-kpi-icon is-green" aria-hidden="true">database</span><div class="ops-kpi-content"><span data-i18n="admin.indexed">Đã index</span><strong>@Model.Dashboard.IndexedDocuments.ToString("N0")</strong><small>@PercentLabel(Model.Dashboard.IndexedDocuments, Model.Dashboard.TotalDocuments)</small></div></article>
                <article class="ops-kpi ops-stat-kpi"><span class="material-symbols-outlined ops-kpi-icon is-orange" aria-hidden="true">pending</span><div class="ops-kpi-content"><span data-i18n="admin.processing">Đang xử lý</span><strong>@Model.Dashboard.ProcessingDocuments.ToString("N0")</strong><small data-i18n="admin.processingDesc">Đang chunk/index</small></div></article>
                <article class="ops-kpi ops-stat-kpi"><span class="material-symbols-outlined ops-kpi-icon is-red" aria-hidden="true">error</span><div class="ops-kpi-content"><span><span data-i18n="stat.indexFailed">Index thất bại</span></span><strong>@Model.Dashboard.FailedDocuments.ToString("N0")</strong><small data-i18n="admin.checkFiles">Cần kiểm tra file</small></div></article>
                <article class="ops-kpi ops-stat-kpi"><span class="material-symbols-outlined ops-kpi-icon is-blue" aria-hidden="true">folder_off</span><div class="ops-kpi-content"><span data-i18n="admin.subjectsNoDocs">Môn chưa có tài liệu</span><strong>@subjectsWithoutDocuments.ToString("N0")</strong><small data-i18n="admin.needMoreDocs">Cần bổ sung học liệu</small></div></article>
            </section>

            <section class="ops-panel">
                <div class="ops-panel-head">
                    <div><h2 data-i18n="stat.documentsReport">Báo cáo tài liệu</h2><p class="ops-muted mb-0" data-i18n="stat.documentsReportDesc">Theo dõi tài liệu mới upload, trạng thái index và số lần được citation.</p></div>
                </div>
                <div class="ops-table-wrap">
                    <table class="ops-table ops-compact-table">
                        <caption class="visually-hidden" data-i18n="admin.recentDocsCaption">Các tài liệu được tải lên gần đây</caption>
                        <thead><tr><th data-i18n="admin.thDocument">Tài liệu</th><th data-i18n="stat.thSubject">Môn học</th><th data-i18n="admin.thUploader">Người upload</th><th data-i18n="admin.thStatus">Trạng thái</th><th data-i18n="admin.thCitation">Citation</th><th data-i18n="admin.thUploadDate">Ngày upload</th></tr></thead>
                        <tbody>
                            @foreach (var document in Model.Dashboard.RecentDocuments)
                            {
                                <tr>
                                    <td data-label="Tài liệu" data-i18n-data-label="admin.thDocument"><strong>@document.FileName</strong></td>
                                    <td data-label="Môn học" data-i18n-data-label="stat.thSubject">@document.Subject</td>
                                    <td data-label="Người upload" data-i18n-data-label="admin.thUploader"><strong>@(string.IsNullOrWhiteSpace(document.UploadedByName) ? Html.Raw("<span data-i18n=\"admin.unknown\">Chưa rõ</span>") : Html.Raw(document.UploadedByName))</strong><small>@ShortEmail(document.UploadedByEmail)</small></td>
                                    <td data-label="Trạng thái" data-i18n-data-label="admin.thStatus"><span class="rbl-status @StatusClass(document.Status)" data-i18n="admin.status.@document.Status.ToLowerInvariant()">@StatusLabel(document.Status)</span></td>
                                    <td data-label="Citation" data-i18n-data-label="admin.thCitation">@document.CitationCount.ToString("N0")</td>
                                    <td data-label="Ngày upload" data-i18n-data-label="admin.thUploadDate">@document.UploadedAt.LocalDateTime.ToString("dd/MM/yyyy")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </section>
        }

        @if (Model.Tab == "users")
        {
            <div class="ops-stat-user-summary">
                <section class="ops-panel"><div class="ops-panel-head"><div><h2 data-i18n="admin.students">Sinh viên</h2><p class="ops-muted mb-0" data-i18n="admin.chatbotUsageLevel">Mức độ sử dụng chatbot.</p></div></div><div class="ops-metric-list"><div><span data-i18n="admin.totalStudents">Tổng sinh viên</span><strong>@Model.StudentUsers.ToString("N0")</strong></div><div><span data-i18n="admin.activeInDays">Hoạt động trong @Model.Days ngày</span><strong>@Model.Dashboard.ActiveChatUsers.ToString("N0")</strong></div><div><span data-i18n="admin.mostQuestions">Hỏi nhiều nhất</span><strong>@(Model.Dashboard.TopChatUsers.FirstOrDefault()?.UserName ?? "-")</strong></div></div></section>
                <section class="ops-panel"><div class="ops-panel-head"><div><h2 data-i18n="admin.lecturers">Giảng viên</h2><p class="ops-muted mb-0" data-i18n="admin.byUploadPerms">Theo quyền upload và tài liệu.</p></div></div><div class="ops-metric-list"><div><span data-i18n="admin.totalLecturers">Tổng giảng viên</span><strong>@Model.LecturerUsers.ToString("N0")</strong></div><div><span data-i18n="admin.activeUploadPerms">Quyền upload đang hoạt động</span><strong>@uploadPermissionCount.ToString("N0")</strong></div><div><span data-i18n="admin.avgDocsPerSubject">TB tài liệu/môn</span><strong>@(Model.Dashboard.TotalSubjects == 0 ? "0" : (Model.Dashboard.TotalDocuments / Math.Max(1, Model.Dashboard.TotalSubjects)).ToString("N0"))</strong></div></div></section>
            </div>

            <section class="ops-panel">
                <div class="ops-panel-head"><div><h2 data-i18n="stat.topChatUsers">Người dùng chat nhiều nhất</h2><p class="ops-muted mb-0" data-i18n="admin.topChatUsersNote">Admin biết nhóm sinh viên đang dùng chatbot tích cực.</p></div></div>
                <div class="ops-table-wrap">
                    <table class="ops-table ops-compact-table">
                        <caption class="visually-hidden" data-i18n="admin.topUsersCaption">Những người dùng sử dụng chatbot nhiều nhất</caption>
                        <thead><tr><th data-i18n="admin.thUser">Người dùng</th><th data-i18n="admin.email">Email</th><th data-i18n="stat.thQuestions">Câu hỏi</th><th data-i18n="admin.thChatSessions">Phiên chat</th><th data-i18n="admin.thLastQuestion">Lần hỏi gần nhất</th></tr></thead>
                        <tbody>
                            @foreach (var user in Model.Dashboard.TopChatUsers)
                            {
                                <tr><td data-label="Người dùng" data-i18n-data-label="admin.thUser"><strong>@user.UserName</strong></td><td data-label="Email" data-i18n-data-label="admin.email">@ShortEmail(user.UserEmail)</td><td data-label="Câu hỏi" data-i18n-data-label="stat.thQuestions">@user.QuestionCount.ToString("N0")</td><td data-label="Phiên chat" data-i18n-data-label="admin.thChatSessions">@user.SessionCount.ToString("N0")</td><td data-label="Lần hỏi gần nhất" data-i18n-data-label="admin.thLastQuestion">@(user.LastQuestionAt?.LocalDateTime.ToString("dd/MM HH:mm") ?? "-")</td></tr>
                            }
                        </tbody>
                    </table>
                </div>
            </section>
        }

        @if (Model.Tab == "permissions")
        {
            <section class="ops-kpi-grid ops-stat-kpis">
                <article class="ops-kpi ops-stat-kpi"><span class="material-symbols-outlined ops-kpi-icon is-blue" aria-hidden="true">supervisor_account</span><div class="ops-kpi-content"><span data-i18n="admin.leaderLecturer">Giảng viên phụ trách</span><strong>@(Model.Dashboard.TotalSubjects - subjectsWithoutOwner)</strong><small data-i18n="admin.assignedSubjects">Môn đã có người phụ trách</small></div></article>
                <article class="ops-kpi ops-stat-kpi"><span class="material-symbols-outlined ops-kpi-icon is-green" aria-hidden="true">upload</span><div class="ops-kpi-content"><span data-i18n="admin.uploadPerms">Quyền upload</span><strong>@uploadPermissionCount</strong><small data-i18n="admin.assignedBySubject">Đang gán theo môn</small></div></article>
                <article class="ops-kpi ops-stat-kpi"><span class="material-symbols-outlined ops-kpi-icon is-orange" aria-hidden="true">person_off</span><div class="ops-kpi-content"><span data-i18n="admin.unassignedSubjects">Môn chưa phụ trách</span><strong>@subjectsWithoutOwner</strong><small data-i18n="admin.needsLeader">Cần gán giảng viên phụ trách</small></div></article>
            </section>
            <section class="ops-panel">
                <div class="ops-panel-head">
                    <div><h2 data-i18n="stat.permissionsReport">Báo cáo phân quyền</h2><p class="ops-muted mb-0" data-i18n="stat.permissionsReportDesc">Theo dõi người phụ trách môn và quyền upload tài liệu.</p></div>
                    <a class="ops-button ops-button--primary" asp-page="/Admin/Index" asp-route-section="lecturer-table" data-i18n="admin.assignLeaderBtn">Gán giảng viên phụ trách</a>
                </div>
                <div class="ops-table-wrap">
                    <table class="ops-table ops-compact-table">
                        <caption class="visually-hidden" data-i18n="admin.leaderStatusCaption">Tình trạng phụ trách môn học của giảng viên</caption>
                        <thead><tr><th data-i18n="admin.thUser">Người dùng</th><th data-i18n="admin.thRole">Vai trò</th><th data-i18n="admin.thLeaderSubject">Môn phụ trách</th><th data-i18n="admin.thUploadPerms">Quyền upload</th><th data-i18n="admin.thStatus">Trạng thái</th></tr></thead>
                        <tbody>
                            @foreach (var subject in Model.Dashboard.SubjectUsage)
                            {
                                var owner = string.IsNullOrWhiteSpace(subject.OwnerName) ? subject.OwnerEmail : subject.OwnerName;
                                var hasUploadPermission = subject.OwnerUserId.HasValue;
                                <tr>
                                    <td data-label="Người dùng" data-i18n-data-label="admin.thUser">
                                        <div class="ops-user-lines">
                                            <strong>@(string.IsNullOrWhiteSpace(owner) ? Html.Raw("<span data-i18n=\"admin.unassigned\">Chưa phân công</span>") : Html.Raw(owner))</strong>
                                            <small>@ShortEmail(subject.OwnerEmail)</small>
                                        </div>
                                    </td>
                                    <td data-label="Vai trò" data-i18n-data-label="admin.thRole" data-i18n="admin.leaderLecturer">Giảng viên phụ trách</td>
                                    <td data-label="Môn phụ trách" data-i18n-data-label="admin.thLeaderSubject">@subject.SubjectCode</td>
                                    <td data-label="Quyền upload" data-i18n-data-label="admin.thUploadPerms">@(hasUploadPermission ? Html.Raw("<span data-i18n=\"admin.yes\">Có</span>") : Html.Raw("<span data-i18n=\"admin.notYet\">Chưa có</span>"))</td>
                                    <td data-label="Trạng thái" data-i18n-data-label="admin.thStatus"><span class="rbl-status @(hasUploadPermission ? "is-success" : "is-running")" data-i18n="admin.status.@(hasUploadPermission ? "active" : "needsAssign")">@(hasUploadPermission ? "Active" : "Cần gán")</span></td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </section>
        }

        @if (Model.Tab == "subscription")
        {
            <section class="ops-subscription-page">
                <section class="ops-kpi-grid ops-subscription-kpis" aria-label="Chỉ số gói đăng ký">
                    <article class="ops-kpi ops-stat-kpi">
                        <span class="material-symbols-outlined ops-kpi-icon is-blue" aria-hidden="true">business_center</span>
                        <div class="ops-kpi-content">
                            <span>Tổng đăng ký</span>
                            <strong>@Model.Dashboard.TotalSubscriptionCount.ToString("N0")</strong>
                            <small>@Model.Days <span data-i18n="stat.lastDays">ngày gần nhất</span></small>
                        </div>
                    </article>
                    <article class="ops-kpi ops-stat-kpi">
                        <span class="material-symbols-outlined ops-kpi-icon is-green" aria-hidden="true">groups</span>
                        <div class="ops-kpi-content">
                            <span>Đang hoạt động</span>
                            <strong>@Model.Dashboard.ActiveSubscriptionCount.ToString("N0")</strong>
                            <small>Subscription active</small>
                        </div>
                    </article>
                    <article class="ops-kpi ops-stat-kpi">
                        <span class="material-symbols-outlined ops-kpi-icon is-blue" aria-hidden="true">person_add</span>
                        <div class="ops-kpi-content">
                            <span>Đăng ký mới</span>
                            <strong>@Model.Dashboard.NewSubscriptionCount.ToString("N0")</strong>
                            <small>Trong khoảng lọc</small>
                        </div>
                    </article>
                    <article class="ops-kpi ops-stat-kpi">
                        <span class="material-symbols-outlined ops-kpi-icon is-purple" aria-hidden="true">sync</span>
                        <div class="ops-kpi-content">
                            <span>Giao dịch thành công</span>
                            <strong>@Model.Dashboard.PaidPaymentCount.ToString("N0")</strong>
                            <small>Payment paid</small>
                        </div>
                    </article>
                    <article class="ops-kpi ops-stat-kpi">
                        <span class="material-symbols-outlined ops-kpi-icon is-red" aria-hidden="true">cancel</span>
                        <div class="ops-kpi-content">
                            <span>Tỷ lệ hủy</span>
                            <strong>@subscriptionCancelRate.ToString("0.#")%</strong>
                            <small>@Model.Dashboard.CanceledSubscriptionCount.ToString("N0") gói đã hủy</small>
                        </div>
                    </article>
                    <article class="ops-kpi ops-stat-kpi">
                        <span class="material-symbols-outlined ops-kpi-icon is-orange" aria-hidden="true">account_balance_wallet</span>
                        <div class="ops-kpi-content">
                            <span>Doanh thu</span>
                            <strong>@MoneyVnd(Model.Dashboard.PaidRevenueVnd)</strong>
                            <small>@Model.Dashboard.PaidPaymentCount.ToString("N0") giao dịch paid</small>
                        </div>
                    </article>
                </section>

                <div class="ops-subscription-grid">
                    <section class="ops-panel ops-subscription-trend">
                        <div class="ops-panel-head">
                            <div>
                                <h2>Xu hướng đăng ký</h2>
                                <p class="ops-muted mb-0">Theo dõi đăng ký mới và giao dịch thanh toán thành công theo ngày.</p>
                            </div>
                            <span class="ops-panel-note">Theo ngày</span>
                        </div>
                        <div class="ops-subscription-chart">
                            <div class="ops-subscription-chart__legend">
                                <span><i class="is-blue"></i>Đăng ký mới</span>
                                <span><i class="is-green"></i>Thanh toán thành công</span>
                            </div>
                            <div class="ops-subscription-chart__plot">
                                @foreach (var day in Model.Dashboard.DailySubscriptionUsage)
                                {
                                    var newHeight = Math.Max(4, day.NewSubscriptionCount * 100 / maxSubscriptionTrend);
                                    var paidHeight = Math.Max(4, day.SuccessfulPaymentCount * 100 / maxSubscriptionTrend);
                                    <div class="ops-subscription-chart__day">
                                        <span class="ops-subscription-chart__bar is-blue" style="height:@newHeight%" title="@day.NewSubscriptionCount.ToString("N0") đăng ký mới"></span>
                                        <span class="ops-subscription-chart__bar is-green" style="height:@paidHeight%" title="@day.SuccessfulPaymentCount.ToString("N0") thanh toán thành công"></span>
                                        <small>@day.DateLabel</small>
                                    </div>
                                }
                            </div>
                        </div>
                    </section>

                    <section class="ops-panel ops-subscription-mix">
                        <div class="ops-panel-head">
                            <div>
                                <h2>Cơ cấu gói đăng ký</h2>
                                <p class="ops-muted mb-0">Tỷ trọng theo gói đang hoạt động hoặc giao dịch paid.</p>
                            </div>
                            <span class="ops-panel-note">Theo số lượng</span>
                        </div>
                        <div class="ops-subscription-donut-layout">
                            <div class="ops-subscription-donut" style="--subscription-donut:@subscriptionDonut">
                                <div class="ops-subscription-donut__label">
                                    <span>Tổng</span>
                                    <strong>@totalPackageVolume.ToString("N0")</strong>
                                </div>
                            </div>
                            <div class="ops-subscription-mix-table">
                                <div class="ops-subscription-mix-row is-head"><span>Gói</span><span>Số lượng</span><span>Tỷ lệ</span></div>
                                @foreach (var package in Model.Dashboard.PackagePurchases.Select((item, index) => new { item, index }))
                                {
                                    var packageVolume = package.item.ActiveSubscriptionCount > 0 ? package.item.ActiveSubscriptionCount : package.item.PaidCount;
                                    var packageRate = totalPackageVolume == 0 ? 0 : packageVolume * 100d / totalPackageVolume;
                                    <div class="ops-subscription-mix-row">
                                        <span><i style="background:@packageColors[package.index % packageColors.Length]"></i>@package.item.PackageName</span>
                                        <span>@packageVolume.ToString("N0")</span>
                                        <span>@packageRate.ToString("0.#")%</span>
                                    </div>
                                }
                            </div>
                        </div>
                    </section>
                </div>

                <div class="ops-subscription-grid">
                    <section class="ops-panel">
                        <div class="ops-panel-head">
                            <div>
                                <h2>Hiệu suất theo gói</h2>
                                <p class="ops-muted mb-0">So sánh active, giao dịch mới, pending/hủy và doanh thu.</p>
                            </div>
                        </div>
                        <div class="ops-table-wrap">
                            <table class="ops-table ops-compact-table ops-subscription-table">
                                <caption class="visually-hidden">Doanh thu và trạng thái giao dịch theo gói</caption>
                                <thead>
                                    <tr>
                                        <th>Gói</th>
                                        <th>Đang hoạt động</th>
                                        <th>Paid</th>
                                        <th>Pending</th>
                                        <th>Hủy/lỗi</th>
                                        <th>Doanh thu</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var package in Model.Dashboard.PackagePurchases.Select((item, index) => new { item, index }))
                                    {
                                        <tr>
                                            <td data-label="Gói"><span class="ops-package-dot" style="background:@packageColors[package.index % packageColors.Length]"></span><strong>@package.item.PackageName</strong></td>
                                            <td data-label="Đang hoạt động">@package.item.ActiveSubscriptionCount.ToString("N0")</td>
                                            <td data-label="Paid">@package.item.PaidCount.ToString("N0")</td>
                                            <td data-label="Pending">@package.item.PendingCount.ToString("N0")</td>
                                            <td data-label="Hủy/lỗi">@package.item.FailedCount.ToString("N0")</td>
                                            <td data-label="Doanh thu">@MoneyVnd(package.item.RevenueVnd)</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </section>

                    <section class="ops-panel">
                        <div class="ops-panel-head">
                            <div>
                                <h2>Giao dịch gần đây</h2>
                                <p class="ops-muted mb-0">Các giao dịch gói mới nhất trong khoảng lọc.</p>
                            </div>
                            <span class="ops-panel-note">Xem tất cả</span>
                        </div>
                        <div class="ops-table-wrap">
                            <table class="ops-table ops-compact-table">
                                <caption class="visually-hidden">Các giao dịch thanh toán gần nhất</caption>
                                <thead>
                                    <tr>
                                        <th>User</th>
                                        <th>Gói</th>
                                        <th>Cổng thanh toán</th>
                                        <th>Trạng thái</th>
                                        <th>Ngày</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var payment in Model.Dashboard.RecentPayments.Take(6))
                                    {
                                        <tr>
                                            <td data-label="User">
                                                <div class="ops-user-lines">
                                                    <strong>@payment.UserName</strong>
                                                    <small>@ShortEmail(payment.UserEmail)</small>
                                                </div>
                                            </td>
                                            <td data-label="Gói">@payment.PackageName</td>
                                            <td data-label="Cổng">@ProviderLabel(payment.Provider)</td>
                                            <td data-label="Trạng thái"><span class="rbl-status @StatusClass(payment.Status)">@StatusLabel(payment.Status)</span></td>
                                            <td data-label="Ngày">@payment.CreatedAt.LocalDateTime.ToString("dd/MM/yyyy HH:mm")</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </section>
                </div>

                <section class="ops-panel ops-subscription-insights">
                    <div class="ops-subscription-insight is-blue">
                        <span class="material-symbols-outlined" aria-hidden="true">stars</span>
                        <div><strong>Gói phổ biến nhất</strong><p>@(topSubscriptionPackage?.PackageName ?? "Chưa có dữ liệu") với @((topSubscriptionPackage?.ActiveSubscriptionCount ?? 0).ToString("N0")) người dùng active.</p></div>
                    </div>
                    <div class="ops-subscription-insight is-green">
                        <span class="material-symbols-outlined" aria-hidden="true">trending_up</span>
                        <div><strong>Thanh toán thành công</strong><p>@Model.Dashboard.PaidPaymentCount.ToString("N0") giao dịch paid trong khoảng lọc.</p></div>
                    </div>
                    <div class="ops-subscription-insight is-red">
                        <span class="material-symbols-outlined" aria-hidden="true">cancel</span>
                        <div><strong>Gói cần theo dõi</strong><p>@subscriptionCancelRate.ToString("0.#")% tỷ lệ hủy trên tổng đăng ký.</p></div>
                    </div>
                </section>
            </section>
        }

        @if (Model.Tab == "billing")
        {
            <section class="ops-kpi-grid ops-stat-kpis">
                <article class="ops-kpi ops-stat-kpi"><span class="material-symbols-outlined ops-kpi-icon is-purple" aria-hidden="true">payments</span><div class="ops-kpi-content"><span>Doanh thu đã thanh toán</span><strong>@Model.Dashboard.PaidRevenueVnd.ToString("N0")</strong><small>VND</small></div></article>
                <article class="ops-kpi ops-stat-kpi"><span class="material-symbols-outlined ops-kpi-icon is-green" aria-hidden="true">verified</span><div class="ops-kpi-content"><span>Giao dịch paid</span><strong>@Model.Dashboard.PaidPaymentCount.ToString("N0")</strong><small>Trong khoảng lọc</small></div></article>
                <article class="ops-kpi ops-stat-kpi"><span class="material-symbols-outlined ops-kpi-icon is-orange" aria-hidden="true">pending_actions</span><div class="ops-kpi-content"><span>Payment pending</span><strong>@Model.Dashboard.PendingPaymentCount.ToString("N0")</strong><small>Cần theo dõi</small></div></article>
                <article class="ops-kpi ops-stat-kpi"><span class="material-symbols-outlined ops-kpi-icon is-blue" aria-hidden="true">workspace_premium</span><div class="ops-kpi-content"><span>Subscription active</span><strong>@Model.Dashboard.ActiveSubscriptionCount.ToString("N0")</strong><small>Gói đang hoạt động</small></div></article>
            </section>
            <div class="ops-stat-two-column">
                <section class="ops-panel"><div class="ops-panel-head"><div><h2>Thống kê mua gói</h2><p class="ops-muted mb-0">Doanh thu và trạng thái theo package.</p></div></div><div class="ops-table-wrap"><table class="ops-table ops-compact-table"><caption class="visually-hidden">Thống kê doanh thu và giao dịch theo gói</caption><thead><tr><th>Gói</th><th>Paid</th><th>Pending</th><th>Failed</th><th>Doanh thu</th></tr></thead><tbody>@foreach (var package in Model.Dashboard.PackagePurchases){<tr><td data-label="Gói"><strong>@package.PackageName</strong><small>@package.PackageCode</small></td><td data-label="Paid">@package.PaidCount</td><td data-label="Pending">@package.PendingCount</td><td data-label="Failed">@package.FailedCount</td><td data-label="Doanh thu">@package.RevenueVnd.ToString("N0") VND</td></tr>}</tbody></table></div></section>
                <section class="ops-panel"><div class="ops-panel-head"><div><h2>Giao dịch gần nhất</h2><p class="ops-muted mb-0">Bảng rút gọn để tránh cuộn ngang.</p></div></div><div class="ops-table-wrap"><table class="ops-table ops-compact-table"><caption class="visually-hidden">Danh sách giao dịch thanh toán gần nhất</caption><thead><tr><th>User</th><th>Gói</th><th>Cổng</th><th>Trạng thái</th><th>Ngày</th></tr></thead><tbody>@foreach (var payment in Model.Dashboard.RecentPayments){<tr><td data-label="User"><strong>@payment.UserName</strong><small>@ShortEmail(payment.UserEmail)</small></td><td data-label="Gói">@payment.PackageName</td><td data-label="Cổng">@ProviderLabel(payment.Provider)</td><td data-label="Trạng thái"><span class="rbl-status @StatusClass(payment.Status)">@StatusLabel(payment.Status)</span></td><td data-label="Ngày">@payment.CreatedAt.LocalDateTime.ToString("dd/MM")</td></tr>}</tbody></table></div></section>
            </div>
        }

    }
</section>
