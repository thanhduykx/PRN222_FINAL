@page
@model PRN222_FINAL.Web.Pages.Subscriptions.CurrentModel
@{
    ViewData["Title"] = "Tài khoản và thanh toán";
    ViewData["UseRblShell"] = true;
    ViewData["ActiveNav"] = "billing";
    ViewData["ShellTitle"] = "Tài khoản và thanh toán";
    ViewData["ShellTitleI18n"] = "subscriptions.shellTitle";

    string StatusLabel(string status) => status switch
    {
        "Paid" => "Paid",
        "Pending" => "Processing",
        "Canceled" => "Canceled",
        "Failed" => "Failed",
        _ => status
    };
    string StatusClass(string status) => status == "Paid" ? "is-success" : status == "Pending" ? "is-pending" : "is-error";
    string ProviderLogo(string provider) => provider.Equals("MoMo", StringComparison.OrdinalIgnoreCase)
        ? "/img/payments/momo.svg" : "/img/payments/payos.svg";
    var premiumCode = Model.Subscription?.PackageCode?.ToUpperInvariant() ?? string.Empty;
    var hasPremiumEffects = premiumCode is "PRO" or "ANNUAL";
    var profileInitial = string.IsNullOrWhiteSpace(Model.Profile.FullName) ? "U" : Model.Profile.FullName.Trim()[..1].ToUpperInvariant();
}

<section class="ops-page account-billing-page">
    <header class="account-billing-hero">
        <div class="account-billing-hero__icon"><span class="material-symbols-outlined" aria-hidden="true">account_balance_wallet</span></div>
        <div><span data-i18n="subscriptions.profileAndBilling">Hồ sơ và thanh toán</span><h1 data-i18n="subscriptions.manageAccount">Quản lý tài khoản của bạn</h1><p data-i18n="subscriptions.manageDesc">Cập nhật tên hiển thị, theo dõi gói học tập và xem lại biên nhận giao dịch.</p></div>
        <a asp-page="/Packages/Index"><span class="material-symbols-outlined" aria-hidden="true">add_shopping_cart</span><span data-i18n="subscriptions.explorePackages">Khám phá các gói</span></a>
    </header>

    @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
    {
        <div class="rbl-alert is-error" role="alert">@Model.ErrorMessage</div>
    }
    @if (TempData["ProfileSuccess"] is string success)
    {
        <div class="rbl-alert is-success" role="status">@success</div>
    }

    <div class="account-billing-grid">
        <section class="current-plan-card @(Model.Subscription is null ? "is-empty" : "") @(hasPremiumEffects ? "is-premium" : "")">
            <div class="current-plan-card__heading"><span>Gói học tập hiện tại</span>@if (Model.Subscription is not null){<span class="current-plan-card__badge">Đang hoạt động</span>}</div>
            @if (Model.Subscription is null)
            {
                <div class="current-plan-card__empty"><span class="material-symbols-outlined" aria-hidden="true">workspace_premium</span><h2 data-i18n="subscriptions.noActivePackage">Chưa có gói hoạt động</h2><p data-i18n="subscriptions.choosePackageDesc">Chọn gói phù hợp để bắt đầu hỏi đáp theo tài liệu.</p><a asp-page="/Packages/Index"><span data-i18n="subscriptions.viewPackagesBtn">Xem các gói</span></a></div>
            }
            else
            {
                <div class="current-plan-card__name"><span class="material-symbols-outlined" aria-hidden="true">workspace_premium</span><div><h2>@Model.Subscription.PackageName</h2><p><span data-i18n="packages.validUntil">Có hiệu lực đến</span> @Model.Subscription.ValidUntilLabel</p></div></div>
                <div class="current-plan-card__facts">
                    <article><span data-i18n="packages.questionsPerMonth">Câu hỏi mỗi tháng</span><strong>@Model.Subscription.MonthlyChatLimit.ToString("N0")</strong></article>
                    <article><span data-i18n="subscriptions.startDate">Bắt đầu</span><strong>@Model.Subscription.StartsAt.LocalDateTime.ToString("dd/MM/yyyy")</strong></article>
                    <article><span data-i18n="subscriptions.status">Trạng thái</span><strong data-i18n="packages.inUseBadge">Đang sử dụng</strong></article>
                </div>
                @if (hasPremiumEffects)
                {
                    <section class="premium-identity" aria-label="Đặc quyền hình ảnh của gói @Model.Subscription.PackageName">
                        <div class="premium-identity__benefits">
                            <div><span class="premium-benefit-icon" aria-hidden="true">☆</span><span>Toàn quyền của gói <strong>@Model.Subscription.PackageName</strong></span></div>
                            <div><span class="premium-benefit-icon" aria-hidden="true">✓</span><span>Sở hữu hiệu ứng tên <strong class="premium-user-name">@Model.Profile.FullName</strong> đặc biệt</span></div>
                            <div><span class="premium-benefit-icon" aria-hidden="true">✓</span><span>Sở hữu hiệu ứng avatar đặc biệt</span></div>
                        </div>
                        <div class="premium-avatar" aria-label="Avatar đặc quyền của @Model.Profile.FullName">
                            <span aria-hidden="true">@profileInitial</span>
                        </div>
                    </section>
                }
            }
        </section>
    </div>

    <details id="transactionHistory" class="transaction-history" @(Model.PaymentHistory.Count == 0 ? "" : null)>
        <summary>
            <span class="transaction-history__summary-icon"><span class="material-symbols-outlined" aria-hidden="true">receipt_long</span></span>
            <span><strong data-i18n="account.history">Lịch sử giao dịch</strong><small><span data-i18n="subscriptions.clickToView">Bấm để xem</span> @Model.PaymentHistory.Count <span data-i18n="subscriptions.recentTransactions">giao dịch gần nhất</span></small></span>
            <span class="transaction-history__count">@Model.PaymentHistory.Count</span>
            <span class="material-symbols-outlined transaction-history__chevron" aria-hidden="true">expand_more</span>
        </summary>
        <div class="transaction-history__body">
            @if (Model.PaymentHistory.Count == 0)
            {
                <div class="transaction-empty"><span class="material-symbols-outlined" aria-hidden="true">receipt</span><strong data-i18n="subscriptions.noTransactions">Chưa có giao dịch</strong><p data-i18n="subscriptions.receiptDesc">Biên nhận sẽ xuất hiện tại đây sau khi bạn thanh toán hoặc kích hoạt gói.</p></div>
            }
            else
            {
                foreach (var payment in Model.PaymentHistory)
                {
                    var receiptId = $"receipt-{payment.PaymentId:N}";
                    <details class="transaction-item @StatusClass(payment.Status)">
                        <summary>
                            <img src="@ProviderLogo(payment.Provider)" alt="" />
                            <span class="transaction-item__identity"><strong>@payment.PackageName</strong><small>@payment.CreatedAt.LocalDateTime.ToString("dd/MM/yyyy · HH:mm")</small></span>
                            <strong class="transaction-item__amount">@payment.AmountVnd.ToString("N0")đ</strong>
                            <span class="transaction-item__status">@StatusLabel(payment.Status)</span>
                            <span class="material-symbols-outlined transaction-item__chevron" aria-hidden="true">expand_more</span>
                        </summary>
                        <div id="@receiptId" class="payment-receipt">
                            <div class="payment-receipt__brand"><span class="material-symbols-outlined" aria-hidden="true">school</span><div><strong>Course Assistant</strong><small data-i18n="subscriptions.receiptTitle">BIÊN NHẬN THANH TOÁN</small></div></div>
                            <div class="payment-receipt__status @StatusClass(payment.Status)"><span class="material-symbols-outlined" aria-hidden="true">@(payment.Status == "Paid" ? "check_circle" : payment.Status == "Pending" ? "schedule" : "cancel")</span><span>@StatusLabel(payment.Status)</span></div>
                            <div class="payment-receipt__customer"><span data-i18n="subscriptions.buyer">Người mua</span><strong>@Model.Profile.FullName</strong><small>@Model.AccountEmail</small></div>
                            <dl>
                                <div><dt>Gói dịch vụ</dt><dd>@payment.PackageName</dd></div>
                                <div><dt>Cổng thanh toán</dt><dd><img src="@ProviderLogo(payment.Provider)" alt="" /> @payment.Provider</dd></div>
                                <div><dt>Mã đơn hàng</dt><dd>@payment.OrderCode</dd></div>
                                <div><dt>Ngày tạo</dt><dd>@payment.CreatedAt.LocalDateTime.ToString("dd/MM/yyyy HH:mm")</dd></div>
                                <div><dt>Ngày thanh toán</dt><dd>@(payment.PaidAt?.LocalDateTime.ToString("dd/MM/yyyy HH:mm") ?? "Chưa xác nhận")</dd></div>
                            </dl>
                            <div class="payment-receipt__total"><span>Tổng thanh toán</span><strong>@payment.AmountVnd.ToString("N0") VND</strong></div>
                            @if (!string.IsNullOrWhiteSpace(payment.FailureReason)){<p class="payment-receipt__failure">@payment.FailureReason</p>}
                            <div class="payment-receipt__footer"><small>Biên nhận được tạo tự động từ dữ liệu giao dịch trong hệ thống.</small><button type="button" data-print-receipt="@receiptId"><span class="material-symbols-outlined" aria-hidden="true">print</span><span data-i18n="subscriptions.printReceipt">In biên nhận</span></button></div>
                        </div>
                    </details>
                }
            }
        </div>
    </details>
</section>

@section Scripts { <partial name="_ValidationScriptsPartial" /> }
