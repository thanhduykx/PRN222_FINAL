@using System.Security.Claims
@inject PRN222_FINAL.BLL.Services.Billing.ISubscriptionService SubscriptionService
@{
    var useRblShell = ViewData["UseRblShell"] as bool? ?? false;
    var activeNav = (ViewData["ActiveNav"] as string ?? string.Empty).ToLowerInvariant();
    var shellTitle = ViewData["ShellTitle"] as string ?? ViewData["Title"] as string ?? "Course Assistant";
    var bodyClass = $"{ViewData["BodyClass"]} {(useRblShell ? "rbl-body" : string.Empty)}".Trim();
    var displayName = User.FindFirstValue(ClaimTypes.Name)
        ?? User.FindFirstValue(ClaimTypes.Email)?.Split('@')[0]
        ?? "Account";
    var userInitial = string.IsNullOrWhiteSpace(displayName) ? "A" : displayName[..1].ToUpperInvariant();
    var accountEmail = User.FindFirstValue(ClaimTypes.Email) ?? "Admin Access";
    var currentUserId = User.FindFirstValue(ClaimTypes.NameIdentifier) ?? string.Empty;
    var currentUserEmail = User.FindFirstValue(ClaimTypes.Email) ?? string.Empty;
    var currentRole = AppRoles.Normalize(User.FindFirstValue(ClaimTypes.Role));
    var isAuthenticated = User.Identity?.IsAuthenticated == true;
    var canChat = isAuthenticated;
    var canViewCourses = currentRole == AppRoles.Lecturer || currentRole == AppRoles.Admin;
    var canManageDocuments = currentRole == AppRoles.Lecturer || currentRole == AppRoles.Admin;
    var canViewDocuments = canManageDocuments;
    var canManageUsers = currentRole == AppRoles.Admin;
    var showLearningFooter = currentRole == AppRoles.Student || currentRole == AppRoles.Lecturer;
    var homePage = currentRole == AppRoles.Student ? "/Home/Chat" : "/Home/Index";
    var hasPremiumIdentity = false;
    if (isAuthenticated && currentRole == AppRoles.Student && Guid.TryParse(currentUserId, out var subscriptionUserId))
    {
        try
        {
            var currentSubscription = await SubscriptionService.GetCurrentSubscriptionAsync(subscriptionUserId, Context.RequestAborted);
            hasPremiumIdentity = currentSubscription?.PackageCode?.ToUpperInvariant() is "PRO" or "ANNUAL";
        }
        catch
        {
            // Account navigation remains available when billing data is temporarily unavailable.
        }
    }
    var accountAvatarClass = hasPremiumIdentity ? "rbl-user-avatar has-premium-effect" : "rbl-user-avatar";
    var accountNameClass = hasPremiumIdentity ? "rbl-account-menu__name has-premium-effect" : "rbl-account-menu__name";
    
    var hideAssistantLauncher = ViewData["HideAssistantLauncher"] as bool? ?? false;
    var hideSidebarOnlineUsers = ViewData["HideSidebarOnlineUsers"] as bool? ?? false;
    var shellTitleI18n = ViewData["ShellTitleI18n"] as string;
    var chatNavClass = activeNav == "chat" ? "rbl-nav-link is-active" : "rbl-nav-link";
    var coursesNavClass = activeNav == "courses" ? "rbl-nav-link is-active" : "rbl-nav-link";
    var documentsNavClass = activeNav == "documents" ? "rbl-nav-link is-active" : "rbl-nav-link";
    var adminNavClass = activeNav == "admin" ? "rbl-nav-link is-active" : "rbl-nav-link";
    var reportsNavClass = activeNav == "reports" ? "rbl-nav-link is-active" : "rbl-nav-link";
    var assistantSettingsNavClass = activeNav == "assistant-settings" ? "rbl-nav-link is-active" : "rbl-nav-link";
    var currentDocumentSection = (ViewData["DocumentSection"] as string ?? Context.Request.Query["section"].ToString() ?? string.Empty).ToLowerInvariant();
    if (string.IsNullOrWhiteSpace(currentDocumentSection))
    {
        currentDocumentSection = "list";
    }

    string DocumentSublinkClass(string sectionName) => currentDocumentSection == sectionName ? "rbl-nav-sublink is-active" : "rbl-nav-sublink";
}
<!DOCTYPE html>
<html lang="vi" class="i18n-pending">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Course Assistant</title>
    <script type="importmap"></script>
    <script>
        (function () {
            var savedLanguage = localStorage.getItem("courseAssistantLanguage");
            document.documentElement.lang = savedLanguage === "en" ? "en" : "vi";
            window.setTimeout(function () {
                document.documentElement.classList.remove("i18n-pending");
                document.documentElement.classList.add("i18n-ready");
            }, 1800);
        })();
    </script>
    <script>
        (function () {
            function markIconsReady() {
                document.documentElement.classList.add("icons-ready");
            }

            if (document.fonts && document.fonts.load) {
                document.fonts.load('24px "Material Symbols Outlined"').then(markIconsReady, markIconsReady);
                window.setTimeout(markIconsReady, 1800);
            } else {
                markIconsReady();
            }
        })();
    </script>
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@300..700,0..1&amp;display=swap" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/design-system.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/Web.styles.css" asp-append-version="true" />
</head>
<body class="@bodyClass">
    <a class="ds-skip-link" href="#mainContent">Bỏ qua tới nội dung chính</a>
    @if (useRblShell)
    {
        <div class="rbl-app-frame">
            <aside class="rbl-sidebar" aria-label="Application navigation">
                <div class="rbl-brand">
                    <span class="rbl-brand-mark">
                        <span class="material-symbols-outlined" aria-hidden="true">school</span>
                    </span>
                    <div>
                        <strong>Course Assistant</strong>
                        <span data-i18n="shell.portal">Cổng học tập</span>
                    </div>
                    <button type="button" class="rbl-mobile-nav-toggle" data-mobile-nav-toggle aria-expanded="false" aria-controls="primaryNavigation">
                        <span class="material-symbols-outlined" aria-hidden="true">menu</span>
                        <span class="visually-hidden">Mở menu chính</span>
                    </button>
                </div>

                <nav class="rbl-nav" id="primaryNavigation" data-primary-navigation>
                    <span class="rbl-nav-section-label">Học tập</span>
                    @if (canChat)
                    {
                    <a class="@chatNavClass" asp-page="/Home/Chat" aria-current="@(activeNav == "chat" ? "page" : null)">
                        <span class="material-symbols-outlined" aria-hidden="true">chat</span>
                        <span data-i18n="shell.chatbot">Chatbot</span>
                    </a>
                    @if (canViewCourses)
                    {
                    <a class="@coursesNavClass" asp-page="/Home/Courses" aria-current="@(activeNav == "courses" ? "page" : null)">
                        <span class="material-symbols-outlined" aria-hidden="true">school</span>
                        <span data-i18n="shell.courses">Môn học</span>
                    </a>
                    }
                    }
                    @if (canViewDocuments)
                    {
                    <details class="rbl-nav-dropdown" @((activeNav == "documents") ? "open" : "")>
                        <summary class="rbl-nav-link-summary @documentsNavClass">
                            <span class="material-symbols-outlined" aria-hidden="true">library_books</span>
                            <span data-i18n="shell.documents">Kho tài liệu</span>
                            <span class="material-symbols-outlined rbl-dropdown-chevron" aria-hidden="true">expand_more</span>
                        </summary>
                        <div class="rbl-nav-sublist">
                            <a class="@(DocumentSublinkClass("list"))" asp-page="/Home/Index" asp-route-section="list">
                                <span class="material-symbols-outlined" aria-hidden="true">description</span>
                                <span data-i18n="documents.navList">Document list</span>
                            </a>
                            @if (currentRole == AppRoles.Lecturer)
                            {
                            <a class="@(DocumentSublinkClass("upload"))" asp-page="/Home/Index" asp-route-section="upload">
                                <span class="material-symbols-outlined" aria-hidden="true">upload_file</span>
                                <span data-i18n="documents.navUpload">Upload & index</span>
                            </a>
                            }
                            @if (canManageDocuments)
                            {
                            <a class="@(DocumentSublinkClass("catalog"))" asp-page="/Home/Index" asp-route-section="catalog">
                                <span class="material-symbols-outlined" aria-hidden="true">topic</span>
                                <span data-i18n="documents.navCatalog">Course catalog</span>
                            </a>
                            }
                        </div>
                    </details>
                    }
                    @if (isAuthenticated && currentRole == AppRoles.Student)
                    {
                    <a class="rbl-nav-link @(activeNav == "billing" ? "is-active" : "")" asp-page="/Packages/Index" aria-current="@(activeNav == "billing" ? "page" : null)">
                        <span class="material-symbols-outlined" aria-hidden="true">payments</span>
                        <span data-i18n="nav.billing">Gói dịch vụ</span>
                    </a>
                    }
                    @if (canManageUsers)
                    {
                    <span class="rbl-nav-section-label">Quản trị</span>
                    <a class="@assistantSettingsNavClass" asp-page="/Admin/AiSettings" aria-current="@(activeNav == "assistant-settings" ? "page" : null)">
                        <span class="material-symbols-outlined" aria-hidden="true">tune</span>
                        <span>Thiết lập trợ lý</span>
                    </a>
                    <a class="@reportsNavClass" asp-page="/Admin/Statistics" asp-route-tab="overview" asp-route-days="30" aria-current="@(activeNav == "reports" ? "page" : null)">
                        <span class="material-symbols-outlined" aria-hidden="true">monitoring</span>
                        <span>Báo cáo &amp; Thống kê</span>
                    </a>
                    <a class="@adminNavClass" asp-page="/Admin/Index" asp-route-section="directory" aria-current="@(activeNav == "admin" ? "page" : null)">
                        <span class="material-symbols-outlined" aria-hidden="true">admin_panel_settings</span>
                        <span data-i18n="shell.users">Người dùng</span>
                    </a>
                    }
                </nav>

                @if (isAuthenticated && !hideSidebarOnlineUsers)
                {
                <section id="onlineUsersWidget" class="online-users-widget online-users-widget--inline rbl-sidebar-online-users" data-current-user-id="@currentUserId" data-current-user-email="@currentUserEmail" data-connection-state="connecting" aria-live="polite">
                    <div class="online-users-widget__header">
                        <div>
                            <h2 data-i18n="onlineUsers.title">Online users</h2>
                            <p data-online-users-summary data-i18n="onlineUsers.connecting">Connecting...</p>
                        </div>
                        <div class="online-users-widget__header-actions">
                            <span class="online-users-widget__status" data-online-users-status aria-hidden="true"></span>
                            <button type="button" class="online-users-widget__toggle" data-online-users-toggle aria-expanded="true" aria-label="Collapse online users">
                                <span class="material-symbols-outlined" aria-hidden="true">expand_more</span>
                            </button>
                        </div>
                    </div>
                    <div class="online-users-widget__body">
                        <ul id="onlineUsersList" class="online-users-widget__list">
                            <li class="online-users-widget__empty" data-i18n="onlineUsers.loading">Loading online users...</li>
                        </ul>
                    </div>
                </section>
                }

                <div class="rbl-sidebar-footer">
                    <a class="rbl-nav-link compact" asp-page="/Home/Privacy">
                        <span class="material-symbols-outlined" aria-hidden="true">help</span>
                        <span data-i18n="shell.help">Help</span>
                    </a>
                </div>
            </aside>

            <div class="rbl-workspace">
                <header class="rbl-topbar">
                    <div class="rbl-topbar-title">
                        @if (!string.IsNullOrWhiteSpace(shellTitleI18n))
                        {
                            <span data-i18n="@shellTitleI18n">@shellTitle</span>
                        }
                        else
                        {
                            <span>@shellTitle</span>
                        }
                    </div>
                    <div class="rbl-topbar-actions">
                        <div class="language-switch rbl-language-switch" role="group" aria-label="Language">
                            <button type="button" class="language-option" data-language-option="en" aria-pressed="true">ENG</button>
                            <button type="button" class="language-option" data-language-option="vi" aria-pressed="false">VN</button>
                        </div>
                        @if (isAuthenticated)
                        {
                            <details class="rbl-account-menu" data-account-menu>
                                <summary aria-label="Mở menu tài khoản">
                                    <span class="@accountAvatarClass">@userInitial</span>
                                    <span class="@accountNameClass">@displayName</span>
                                    <span class="material-symbols-outlined" aria-hidden="true">expand_more</span>
                                </summary>
                                <div class="rbl-account-menu__panel">
                                    <div class="rbl-account-menu__identity">
                                        <span class="@accountAvatarClass is-large">@userInitial</span>
                                        <div><strong class="@(hasPremiumIdentity ? "premium-user-name" : null)">@displayName</strong><span>@accountEmail</span><small>@currentRole</small></div>
                                    </div>
                                    <nav aria-label="Account" data-i18n-aria-label="shell.accountNav">
                                        @if (currentRole == AppRoles.Student)
                                        {
                                            <a asp-page="/Subscriptions/Current"><span class="material-symbols-outlined" aria-hidden="true">manage_accounts</span><span><strong data-i18n="account.profile">Thông tin người dùng</strong><small data-i18n="account.profileDesc">Chỉnh sửa tên hiển thị</small></span></a>
                                            <a asp-page="/Subscriptions/Current" asp-fragment="transactionHistory"><span class="material-symbols-outlined" aria-hidden="true">receipt_long</span><span><strong data-i18n="account.history">Lịch sử giao dịch</strong><small data-i18n="account.historyDesc">Xem và in biên nhận</small></span></a>
                                        }
                                        <a asp-page="/Account/ChangePassword"><span class="material-symbols-outlined" aria-hidden="true">lock_reset</span><span><strong data-i18n="account.changePassword">Đổi mật khẩu</strong><small data-i18n="account.changePasswordDesc">Bảo vệ tài khoản</small></span></a>
                                    </nav>
                                    <form asp-page="/Account/Logout" method="post">
                                        @Html.AntiForgeryToken()
                                        <button type="submit"><span class="material-symbols-outlined" aria-hidden="true">logout</span><span data-i18n="account.logout">Đăng xuất</span></button>
                                    </form>
                                </div>
                            </details>
                        }
                        else
                        {
                            <a class="rbl-account-button" asp-page="/Account/Login">
                                <span class="material-symbols-outlined" aria-hidden="true">person</span>
                                <span data-i18n="nav.login">Login</span>
                            </a>
                        }
                    </div>
                </header>

                <main role="main" class="rbl-main" id="mainContent" tabindex="-1">
                    @RenderBody()
                    @if (isAuthenticated && showLearningFooter)
                    {
                        <footer class="learning-footer" aria-label="Footer">
                            <section class="learning-footer__contact" aria-label="Contact us">
                                <h2>Contact us</h2>
                                <div class="learning-footer__actions">
                                    <a class="learning-footer__icon-button" href="https://daihoc.fpt.edu.vn" target="_blank" rel="noopener noreferrer" aria-label="Website">
                                        <span class="material-symbols-outlined" aria-hidden="true">public</span>
                                    </a>
                                    <a class="learning-footer__icon-button" href="mailto:contact@fpt.edu.vn" aria-label="Email">
                                        <span class="material-symbols-outlined" aria-hidden="true">mail</span>
                                    </a>
                                </div>
                            </section>
                            <section class="learning-footer__session" aria-label="Current session">
                                <div class="learning-footer__session-line"><span data-i18n="shell.loggedInAs">Đang đăng nhập với tên</span> @displayName</div>
                            </section>
                        </footer>
                    }
                </main>
            </div>
        </div>
    }
    else
    {
        <header>
            <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light bg-white border-bottom box-shadow mb-3">
                <div class="container-fluid">
                    <a class="navbar-brand" asp-area="" asp-page="@homePage">Course Assistant</a>
                    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                            aria-expanded="false" aria-label="Toggle navigation">
                        <span class="navbar-toggler-icon"></span>
                    </button>
                    <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                        <ul class="navbar-nav flex-grow-1">
                            @if (canViewDocuments)
                            {
                                <li class="nav-item">
                                    <a class="nav-link text-dark" asp-area="" asp-page="/Home/Index" asp-fragment="documents" data-i18n="nav.documents">Documents</a>
                                </li>
                            }
                            @if (canChat)
                            {
                                <li class="nav-item">
                                    <a class="nav-link text-dark" asp-area="" asp-page="/Home/Chat" data-i18n="nav.chat">Chat</a>
                                </li>
                            }
                            @if (canViewCourses)
                            {
                                <li class="nav-item">
                                    <a class="nav-link text-dark" asp-area="" asp-page="/Home/Courses" data-i18n="shell.courses">Courses</a>
                                </li>
                            }
                            @if (isAuthenticated)
                            {
                                <li class="nav-item">
                                    <a class="nav-link text-dark" asp-area="" asp-page="/Home/OnlineUsers" data-i18n="admin.navOnlineUsers">Online users</a>
                                </li>
                            }
                            @if (isAuthenticated && currentRole == AppRoles.Student)
                            {
                                <li class="nav-item">
                                    <a class="nav-link text-dark" asp-area="" asp-page="/Packages/Index" data-i18n="shell.packages">Gói dịch vụ</a>
                                </li>
                            }
                            @if (canManageUsers)
                            {
                                <li class="nav-item">
                                    <a class="nav-link text-dark" asp-area="" asp-page="/Admin/Index">Users</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link text-dark" asp-area="" asp-page="/Admin/Statistics" data-i18n="shell.statistics">Thống kê</a>
                                </li>
                            }
                        </ul>
                        <ul class="navbar-nav account-nav">
                            <li class="nav-item">
                                <div class="language-switch" role="group" aria-label="Language">
                                    <button type="button" class="language-option" data-language-option="en" aria-pressed="true">ENG</button>
                                    <button type="button" class="language-option" data-language-option="vi" aria-pressed="false">VN</button>
                                </div>
                            </li>
                            @if (isAuthenticated)
                            {
                                <li class="nav-item">
                                    <details class="rbl-account-menu" data-account-menu>
                                        <summary><span class="@accountAvatarClass">@userInitial</span><span class="@accountNameClass">@displayName</span><span class="material-symbols-outlined" aria-hidden="true">expand_more</span></summary>
                                        <div class="rbl-account-menu__panel">
                                            <div class="rbl-account-menu__identity"><span class="@accountAvatarClass is-large">@userInitial</span><div><strong class="@(hasPremiumIdentity ? "premium-user-name" : null)">@displayName</strong><span>@accountEmail</span><small>@currentRole</small></div></div>
                                            <nav aria-label="Tài khoản">
                                                @if (currentRole == AppRoles.Student)
                                                {
                                                    <a asp-page="/Subscriptions/Current"><span class="material-symbols-outlined" aria-hidden="true">manage_accounts</span><span><strong data-i18n="account.profile">Thông tin người dùng</strong><small data-i18n="account.profileDesc">Chỉnh sửa tên hiển thị</small></span></a>
                                                    <a asp-page="/Subscriptions/Current" asp-fragment="transactionHistory"><span class="material-symbols-outlined" aria-hidden="true">receipt_long</span><span><strong data-i18n="account.history">Lịch sử giao dịch</strong><small data-i18n="account.historyDesc">Xem và in biên nhận</small></span></a>
                                                }
                                                <a asp-page="/Account/ChangePassword"><span class="material-symbols-outlined" aria-hidden="true">lock_reset</span><span><strong data-i18n="account.changePassword">Đổi mật khẩu</strong><small data-i18n="account.changePasswordDesc">Bảo vệ tài khoản</small></span></a>
                                            </nav>
                                            <form asp-page="/Account/Logout" method="post">@Html.AntiForgeryToken()<button type="submit"><span class="material-symbols-outlined" aria-hidden="true">logout</span><span data-i18n="account.logout">Đăng xuất</span></button></form>
                                        </div>
                                    </details>
                                </li>
                            }
                            else
                            {
                                <li class="nav-item">
                                    <a class="nav-link text-dark" asp-page="/Account/Login" data-i18n="nav.login">Login</a>
                                </li>
                            }
                        </ul>
                    </div>
                </div>
            </nav>
        </header>
        <div class="container">
            <main role="main" class="pb-3" id="mainContent" tabindex="-1">
                @RenderBody()
                @if (isAuthenticated && showLearningFooter)
                {
                    <footer class="learning-footer" aria-label="Footer">
                        <section class="learning-footer__contact" aria-label="Contact us">
                            <h2>Contact us</h2>
                            <div class="learning-footer__actions">
                                <a class="learning-footer__icon-button" href="https://daihoc.fpt.edu.vn" target="_blank" rel="noopener noreferrer" aria-label="Website">
                                    <span class="material-symbols-outlined" aria-hidden="true">public</span>
                                </a>
                                <a class="learning-footer__icon-button" href="mailto:contact@fpt.edu.vn" aria-label="Email">
                                    <span class="material-symbols-outlined" aria-hidden="true">mail</span>
                                </a>
                            </div>
                        </section>
                        <section class="learning-footer__session" aria-label="Current session">
                            <div class="learning-footer__session-line"><span data-i18n="shell.loggedInAs">Đang đăng nhập với tên</span> @displayName</div>
                        </section>
                    </footer>
                }
            </main>
        </div>
        @if (isAuthenticated && !hideAssistantLauncher)
        {
            <section class="assistant-launcher chatbot-helper" id="chatbotHelper" aria-label="Chatbot helper">
                <a class="assistant-launcher-card chatbot-helper-card" id="chatbotHelperButton" asp-page="/Home/Chat" aria-label="Open chat page" title="Open chat page" data-i18n-aria-label="assistant.open" data-i18n-title="assistant.open" draggable="false">
                    <img src="~/img/dog.gif" asp-append-version="true" alt="Chatbot assistant" class="chatbot-helper-avatar" draggable="false" />
                    <span class="assistant-launcher-bubble chatbot-helper-copy" data-assistant-greeting data-assistant-name="@displayName">Hi @displayName, I can help you find information faster.</span>
                    <span class="visually-hidden" data-i18n="assistant.hidden">Hi @displayName, I am your chatbot assistant for finding information faster.</span>
                </a>
            </section>
        }

        <footer class="border-top footer text-muted">
            <div class="container">
                &copy; 2026 - Course Assistant
            </div>
        </footer>
    }
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/lib/signalr/dist/browser/signalr.min.js" asp-append-version="true"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>

