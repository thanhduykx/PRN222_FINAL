@page
@using PRN222_FINAL.BLL.Models
@model PRN222_FINAL.Web.Pages.Home.IndexModel
@{
    ViewData["Title"] = "Kho tài liệu / Documents";
    ViewData["UseRblShell"] = true;
    ViewData["ActiveNav"] = "documents";
    ViewData["ShellTitle"] = "Kho tài liệu / Documents";
    ViewData["ShellTitleI18n"] = "documents.shellTitle";

    var documents = Model.Documents.OrderByDescending(item => item.UploadedAt).ToList();
    var courseCatalog = Model.CourseCatalog.OrderBy(item => item.Code).ToList();
    var documentTree = Model.DocumentTree.OrderBy(item => item.Code).ThenBy(item => item.Name).ToList();
    var isAdmin = Model.IsAdmin;
    var canManageDocuments = Model.IsAdmin || Model.IsLecturer;
    var isListSection = Model.CurrentSection == "list";
    var isUploadSection = Model.CurrentSection == "upload";
    var isCatalogSection = Model.CurrentSection == "catalog";
    var totalDocuments = Model.TotalDocumentCount;
    var visibleDocuments = documents.Count;
    var totalChunks = Model.TotalChunkCount;
    var averageChunks = Model.AverageChunksPerIndexedDocument <= 0 ? 0 : Model.AverageChunksPerIndexedDocument;
    var subjectOptions = courseCatalog
        .Select(subject => subject.DisplayName)
        .Where(subject => !string.IsNullOrWhiteSpace(subject))
        .Distinct(StringComparer.OrdinalIgnoreCase)
        .OrderBy(subject => subject)
        .ToList();
    var canUploadToSubject = subjectOptions.Count > 0;
    var chapterOptions = courseCatalog.SelectMany(subject => subject.Chapters)
        .Select(chapter => chapter.Title)
        .Concat(Model.DocumentChapterOptions)
        .Where(chapter => !string.IsNullOrWhiteSpace(chapter))
        .Distinct(StringComparer.OrdinalIgnoreCase)
        .OrderBy(chapter => chapter)
        .ToList();
    var statusOptions = new[] { DocumentIndexStatus.Indexed, DocumentIndexStatus.Processing, DocumentIndexStatus.Failed };
    var hasActiveFilters = !string.IsNullOrWhiteSpace(Model.Query)
        || !string.IsNullOrWhiteSpace(Model.SubjectFilter)
        || !string.IsNullOrWhiteSpace(Model.StatusFilter);

    string FormatBytes(long bytes)
    {
        var units = new[] { "B", "KB", "MB", "GB", "TB" };
        var size = Math.Max(0, bytes);
        var unitIndex = 0;
        var value = (double)size;
        while (value >= 1024 && unitIndex < units.Length - 1)
        {
            value /= 1024;
            unitIndex++;
        }

        return unitIndex == 0 ? $"{size} {units[unitIndex]}" : $"{value:0.##} {units[unitIndex]}";
    }

    string PersonLabel(string name, string fallback)
    {
        return string.IsNullOrWhiteSpace(name) ? fallback : name.Trim();
    }

    string StatusClass(IndexedDocument document)
    {
        return document.Status switch
        {
            DocumentIndexStatus.Indexed => "is-success",
            DocumentIndexStatus.Processing => "is-running",
            DocumentIndexStatus.Failed => "is-error",
            _ => "is-muted"
        };
    }

    string StatusLabel(IndexedDocument document)
    {
        return document.Status switch
        {
            DocumentIndexStatus.Indexed => "Indexed",
            DocumentIndexStatus.Processing => "Processing",
            DocumentIndexStatus.Failed => "Failed",
            _ => string.IsNullOrWhiteSpace(document.Status) ? "Unknown" : document.Status
        };
    }

    string StatusTitle(IndexedDocument document)
    {
        if (document.Status == DocumentIndexStatus.Failed && !string.IsNullOrWhiteSpace(document.IndexError))
        {
            return document.IndexError;
        }

        if (document.Status == DocumentIndexStatus.Indexed && document.IndexedAt.HasValue)
        {
            return $"Indexed at {document.IndexedAt.Value.LocalDateTime:yyyy-MM-dd HH:mm}";
        }

        return StatusLabel(document);
    }
}

<section class="ops-page ops-documents-page">
    <header class="ops-page-header">
        <div>
            <span class="ops-eyebrow" data-i18n="documents.eyebrow">Learning content operations</span>
            <h1 data-i18n="documents.shellTitle">Kho tài liệu</h1>
            <p data-i18n="documents.manageSubtitle">Quản lý tài liệu, danh mục môn học và trạng thái index để chatbot trả lời đúng nguồn.</p>
        </div>
        <a class="ops-button ops-button--secondary" asp-page="/Home/Chat">
            <span class="material-symbols-outlined" aria-hidden="true">chat</span>
            <span data-i18n="shell.chatbot">Chatbot</span>
        </a>
    </header>

    @if (TempData["Success"] is string success)
    {
        <div class="rbl-alert is-success">@success</div>
    }
    @if (TempData["Error"] is string error)
    {
        <div class="rbl-alert is-error">@error</div>
    }
    @if (!string.IsNullOrWhiteSpace(Model.LoadErrorMessage))
    {
        <div class="rbl-alert is-error">@Model.LoadErrorMessage</div>
    }

    @if (!isCatalogSection)
    {
        <section class="ops-kpi-grid" aria-label="Document metrics">
            <article class="ops-kpi">
                <span class="ops-kpi-icon is-blue material-symbols-outlined" aria-hidden="true">description</span>
                <div class="ops-kpi-content">
                <span data-i18n="documents.kpiTotal">Total</span>
                <strong data-document-kpi="total">@totalDocuments</strong>
                <small><span data-document-visible-count>@visibleDocuments</span> <span data-i18n="documents.showing">shown</span></small>
                </div>
            </article>
            <article class="ops-kpi">
                <span class="ops-kpi-icon is-green material-symbols-outlined" aria-hidden="true">check_circle</span>
                <div class="ops-kpi-content">
                <span data-i18n="documents.statsIndexed">Indexed</span>
                <strong data-document-kpi="indexed">@Model.IndexedDocumentCount</strong>
                <small>Ready for chat</small>
                </div>
            </article>
            <article class="ops-kpi">
                <span class="ops-kpi-icon is-indigo material-symbols-outlined" aria-hidden="true">schedule</span>
                <div class="ops-kpi-content">
                <span data-i18n="documents.statsProcessing">Processing</span>
                <strong data-document-kpi="processing">@Model.ProcessingDocumentCount</strong>
                <small>Queued or indexing</small>
                </div>
            </article>
            <article class="ops-kpi ops-kpi--danger">
                <span class="ops-kpi-icon is-orange material-symbols-outlined" aria-hidden="true">warning</span>
                <div class="ops-kpi-content">
                <span data-i18n="documents.kpiFailed">Failed</span>
                <strong data-document-kpi="failed">@Model.FailedDocumentCount</strong>
                <small>Needs attention</small>
                </div>
            </article>
            <article class="ops-kpi">
                <span class="ops-kpi-icon is-purple material-symbols-outlined" aria-hidden="true">inventory_2</span>
                <div class="ops-kpi-content">
                <span data-i18n="documents.storage">Storage</span>
                <strong>@FormatBytes(Model.TotalUploadedBytes)</strong>
                <small>@totalChunks chunks, avg @averageChunks.ToString("0.#")</small>
                </div>
            </article>
        </section>
    }

    @if (Model.IsLecturer && isUploadSection)
    {
        <section id="upload-index" class="ops-panel ops-upload-panel">
            <form asp-page-handler="Upload" method="post" enctype="multipart/form-data" class="ops-upload-form">
                @Html.AntiForgeryToken()
                <input type="hidden" name="Language" value="vi" data-language-field />

                <div class="ops-upload-file-card">
                    <h2><span class="material-symbols-outlined" aria-hidden="true">description</span> <span data-i18n="documents.docInfo">Thông tin tài liệu</span></h2>
                <div class="ops-form-row">
                    <label class="ops-field">
                        <span data-i18n="documents.subject">Môn học</span>
                        <select name="Subject" required disabled="@(!canUploadToSubject)">
                            <option value="" data-i18n="documents.selectSubject">Chọn môn học</option>
                            @foreach (var subject in subjectOptions)
                            {
                                <option value="@subject">@subject</option>
                            }
                        </select>
                        @if (!canUploadToSubject)
                        {
                            <small data-i18n="documents.noSubjectAssigned">Chưa có môn nào được gán cho tài khoản này.</small>
                        }
                    </label>
                    <label class="ops-field">
                        <span data-i18n="documents.chapter">Chương</span>
                        <input name="Chapter" list="chapterOptions" placeholder="Chapter 1 hoặc Week 1" data-i18n-placeholder="documents.chapterPlaceholder" />
                    </label>
                </div>

                <datalist id="chapterOptions">
                    @foreach (var chapter in chapterOptions)
                    {
                        <option value="@chapter"></option>
                    }
                </datalist>

                <div class="ops-ingest-grid">
                    <label id="documentDropzone" class="ops-dropzone dropzone" for="documentFileInput">
                        <input id="documentFileInput" name="File" type="file" accept=".pdf,.docx,.pptx,.txt" />
                        <span class="ops-upload-illustration" aria-hidden="true">
                            <span class="material-symbols-outlined ops-upload-document">description</span>
                            <span class="material-symbols-outlined ops-upload-cloud">cloud_upload</span>
                            <i class="ops-upload-spark is-one"></i>
                            <i class="ops-upload-spark is-two"></i>
                            <i class="ops-upload-spark is-three"></i>
                        </span>
                        <strong data-i18n="documents.dropzoneTitle">Kéo &amp; thả file vào đây hoặc bấm để chọn</strong>
                        <small id="documentFileName" data-default-en="PDF, DOCX, PPTX, TXT"
                               data-default-vi="PDF, DOCX, PPTX, TXT">PDF, DOCX, PPTX, TXT</small>
                        <span class="ops-button ops-button--secondary"><span class="material-symbols-outlined" aria-hidden="true">upload</span> <span data-i18n="documents.chooseFileBtn">Chọn file</span></span>
                    </label>
                </div>
                </div>

                    <div class="ops-ingest-actions ops-upload-url-card">
                        <h2><span class="material-symbols-outlined" aria-hidden="true">link</span> <span data-i18n="documents.url">URL trang bài giảng</span></h2>
                        <label class="ops-field ops-url-field">
                            <span data-i18n="documents.enterUrl">Nhập URL trang bài giảng</span>
                            <input name="SourceUrl" type="url" placeholder="https://example.com/lecture" data-i18n-placeholder="documents.urlPlaceholder" />
                            <small data-i18n="documents.urlHint">SPA/React/Vue sẽ được render trước khi trích xuất nội dung.</small>
                        </label>

                        <button type="submit" class="ops-button ops-button--primary ops-upload-submit"
                                disabled="@(!canUploadToSubject)">
                            <span class="material-symbols-outlined" aria-hidden="true">play_arrow</span>
                            <span data-i18n="documents.submit">Index now</span>
                        </button>
                    </div>
            </form>
        </section>
    }

    @if (isListSection)
    {
        <section id="document-list" class="ops-panel">

            <form asp-page="/Home/Index" method="get" class="ops-filter-bar">
                <input type="hidden" name="section" value="list" />
                <label class="ops-field ops-field--search">
                    <span data-i18n="documents.search">Tìm kiếm</span>
                    <input name="q" value="@Model.Query" placeholder="File, subject, chapter, uploader..." data-i18n-placeholder="documents.searchPlaceholder" />
                </label>
                <label class="ops-field">
                    <span data-i18n="documents.subject">Subject</span>
                    <select name="subjectFilter">
                        @if (string.IsNullOrWhiteSpace(Model.SubjectFilter))
                        {
                            <option value="" selected data-i18n="documents.allSubjects">All subjects</option>
                        }
                        else
                        {
                            <option value="" data-i18n="documents.allSubjects">All subjects</option>
                        }
                        @foreach (var subject in subjectOptions)
                        {
                            if (subject.Equals(Model.SubjectFilter, StringComparison.OrdinalIgnoreCase))
                            {
                                <option value="@subject" selected>@subject</option>
                            }
                            else
                            {
                                <option value="@subject">@subject</option>
                            }
                        }
                    </select>
                </label>
                <label class="ops-field">
                    <span data-i18n="documents.status">Status</span>
                    <select name="statusFilter">
                        @if (string.IsNullOrWhiteSpace(Model.StatusFilter))
                        {
                            <option value="" selected data-i18n="documents.allStatus">All status</option>
                        }
                        else
                        {
                            <option value="" data-i18n="documents.allStatus">All status</option>
                        }
                        @foreach (var status in statusOptions)
                        {
                            if (status.Equals(Model.StatusFilter, StringComparison.OrdinalIgnoreCase))
                            {
                                <option value="@status" selected>@status</option>
                            }
                            else
                            {
                                <option value="@status">@status</option>
                            }
                        }
                    </select>
                </label>
                <button type="submit" class="ops-button ops-button--secondary"><span class="material-symbols-outlined" aria-hidden="true">filter_alt</span><span data-i18n="documents.filter">Filter</span></button>
                @if (hasActiveFilters)
                {
                    <a class="ops-button ops-button--ghost" asp-page="/Home/Index" asp-route-section="list" data-i18n="documents.clear">Clear</a>
                }
            </form>

            @if (documents.Count == 0)
            {
                <div class="ops-empty ops-documents-empty">
                    <span class="ops-empty-icon material-symbols-outlined" aria-hidden="true">note_add</span>
                    <strong data-i18n="documents.emptyTitle">Chưa có tài liệu</strong>
                    <p data-i18n="documents.emptyHint">Điều chỉnh bộ lọc hoặc upload tài liệu mới để bắt đầu hỏi đáp theo nguồn.</p>
                    @if (Model.IsLecturer)
                    {
                        <a class="ops-button ops-button--primary" asp-page="/Home/Index" asp-route-section="upload">
                            <span class="material-symbols-outlined" aria-hidden="true">upload</span> <span data-i18n="documents.uploadTitle">Tải tài liệu</span>
                        </a>
                    }
                </div>
            }
            else
            {
                <div class="ops-table-wrap">
                    <table class="ops-table ops-document-table">
                        <caption class="visually-hidden">Danh sách tài liệu theo bộ lọc hiện tại</caption>
                        <thead>
                            <tr>
                                <th scope="col" data-i18n="documents.fileName">File</th>
                                <th scope="col" data-i18n="documents.subjectChapter">Subject / Chapter</th>
                                <th scope="col" data-i18n="documents.status">Status</th>
                                <th scope="col" data-i18n="documents.chunksSize">Chunks / Size</th>
                                <th scope="col" data-i18n="documents.uploadDate">Uploaded</th>
                                <th scope="col" class="ops-actions-col" data-i18n="documents.actions">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var document in documents)
                            {
                                <tr data-document-id="@document.Id" data-document-status-value="@document.Status">
                                    <td data-label="File">
                                        <div class="ops-file-cell">
                                            <span class="material-symbols-outlined" aria-hidden="true">description</span>
                                            <div>
                                                <strong title="@document.FileName">@document.FileName</strong>
                                                <small>@document.ContentType</small>
                                            </div>
                                        </div>
                                    </td>
                                    <td data-label="Subject / Chapter">
                                        <div class="ops-stack">
                                            <strong title="@document.Subject">@document.Subject</strong>
                                            <small title="@document.Chapter">@document.Chapter</small>
                                        </div>
                                    </td>
                                    <td data-label="Status">
                                        <div class="ops-stack">
                                            <span class="rbl-status @StatusClass(document)" title="@StatusTitle(document)"
                                                  data-document-status>@StatusLabel(document)</span>
                                        </div>
                                    </td>
                                    <td data-label="Chunks / Size">
                                        <div class="ops-stack">
                                            <strong data-document-chunks>@document.ChunkCount <span data-i18n="documents.chunksUnit">chunks</span></strong>
                                            <small>@FormatBytes(document.FileSizeBytes)</small>
                                        </div>
                                    </td>
                                    <td data-label="Uploaded">
                                        <div class="ops-stack">
                                            <strong title="@document.UploadedByEmail">@(string.IsNullOrWhiteSpace(document.UploadedByName) ? Html.Raw("<span data-i18n=\"documents.unknown\">Unknown</span>") : document.UploadedByName.Trim())</strong>
                                            <small>@document.UploadedAt.LocalDateTime.ToString("yyyy-MM-dd HH:mm")</small>
                                        </div>
                                    </td>
                                    <td data-label="Actions">
                                        <div class="ops-row-actions" data-document-actions>
                                            @if (document.Status == DocumentIndexStatus.Indexed)
                                            {
                                                <button type="button" class="ops-mini-button" data-document-preview-action
                                                        data-document-preview-label="Xem"
                                                        data-document-preview-url="/Home/DocumentPreview/@document.Id"><span data-i18n="documents.view">Xem</span></button>
                                            }
                                            else
                                            {
                                                <button type="button" class="ops-mini-button" data-document-preview-action
                                                        data-document-preview-label="Xem" disabled
                                                        title="@StatusTitle(document)"><span data-i18n="documents.view">Xem</span></button>
                                            }
                                            @if (canManageDocuments && Model.CanEditDocumentMetadata(document, courseCatalog))
                                            {
                                                <a class="ops-mini-button" asp-page="/Home/EditDocument" asp-route-id="@document.Id"><span data-i18n="documents.edit">Sửa</span></a>
                                                    <form asp-page-handler="ReindexDocument" method="post"
                                                          data-confirm="Re-index tài liệu này?">
                                                        @Html.AntiForgeryToken()
                                                        <input type="hidden" name="id" value="@document.Id" />
                                                        <button type="submit" class="ops-mini-button"><span data-i18n="documents.reindex">Re-index</span></button>
                                                    </form>
                                                    <form asp-page-handler="DeleteDocument" method="post"
                                                          data-confirm="Xóa tài liệu này khỏi kho index? Thao tác này không thể hoàn tác.">
                                                        @Html.AntiForgeryToken()
                                                        <input type="hidden" name="id" value="@document.Id" />
                                                        <button type="submit" class="ops-mini-button ops-mini-button--danger"><span data-i18n="documents.delete">Xóa</span></button>
                                                    </form>
                                                }
                                            </div>
                                        </td>
                                </tr>
                                <tr class="ops-document-progress-row" data-document-progress-row="@document.Id" hidden>
                                    <td colspan="6">
                                        <div class="ops-document-progress" data-document-progress></div>
                                    </td>
                                </tr>
                            }
                            </tbody>
                        </table>
                    </div>
                }
            </section>
        }

        @if (canManageDocuments && isCatalogSection)
        {
            <section id="course-catalog" class="ops-panel ops-catalog-panel"
                     style="margin-top: 0 !important; padding-top: 1rem;">
                <div class="ops-catalog-body">

                    @if (documentTree.Count == 0)
                    {
                        <div class="ops-empty ops-catalog-empty">
                            <div class="ops-catalog-empty-heading">
                                <span class="material-symbols-outlined" aria-hidden="true">list_alt</span>
                                <div><h2 data-i18n="documents.navCatalog">Danh mục môn học</h2><p data-i18n="documents.catalogEmptyDesc">Danh sách các chương đã tạo</p></div>
                            </div>
                            <span class="ops-empty-icon material-symbols-outlined" aria-hidden="true">playlist_add</span>
                            <strong data-i18n="documents.emptyCatalogTitle">Chưa có danh mục môn học.</strong>
                            <p data-i18n="documents.emptyCatalogHint">Tạo môn học trước, sau đó thêm chương để upload tài liệu theo danh mục chuẩn.</p>
                            <a href="#course-catalog" class="ops-button ops-button--secondary"><span class="material-symbols-outlined" aria-hidden="true">add_circle</span> <span data-i18n="documents.createFirstChapterBtn">Tạo chương đầu tiên</span></a>
                        </div>
                    }
                    else
                    {
                        <div class="ops-folder-tree"
                             style="display: grid; grid-template-columns: repeat(auto-fill, minmax(220px, 1fr)); gap: 16px;">
                            @foreach (var subject in documentTree)
                            {
                                <details class="ops-folder-subject ops-subject-card-shell"
                                         data-subject-detail-url='@Url.Page("/Home/SubjectDocuments", new { id = subject.SubjectId })'
                                         role="link" tabindex="0" style="margin: 0;">
                                    <summary class="ops-folder-summary">
                                        <span class="material-symbols-outlined" aria-hidden="true">folder</span>
                                        <span class="ops-folder-main">
                                            <strong>@subject.DisplayName</strong>
                                            <small>@(string.IsNullOrWhiteSpace(subject.Description) ? "Chưa có mô tả." :
                                                                                                                                                                                subject.Description)</small>
                                            </span>
                                            <span class="ops-chip">Owner: @PersonLabel(subject.OwnerName, "Unassigned")</span>
                                            <span class="ops-chip">@subject.Chapters.Count chương</span>
                                            <span class="ops-chip">@subject.DocumentCount tài liệu</span>
                                        </summary>
                                        <div class="ops-folder-subject-body">
                                            @if (isAdmin)
                                            {
                                                <form asp-page-handler="SaveSubject" method="post" class="ops-inline-edit ops-subject-edit">
                                                    @Html.AntiForgeryToken()
                                                    <input type="hidden" name="Id" value="@subject.SubjectId" />
                                                    <input name="Code" value="@subject.Code" />
                                                    <input name="Description" value="@subject.Description" />
                                                    <button type="submit" class="ops-mini-button">Update</button>
                                                </form>
                                                <form asp-page-handler="DeleteSubject" method="post" class="ops-danger-form"
                                                      data-confirm="Xóa môn này và toàn bộ chương bên trong? Thao tác này không thể hoàn tác.">
                                                    @Html.AntiForgeryToken()
                                                    <input type="hidden" name="id" value="@subject.SubjectId" />
                                                    <button type="submit" class="ops-mini-button ops-mini-button--danger">Delete
                                                        subject</button>
                                                    </form>
                                                }

                                                @if (Model.IsLecturer)
                                                {
                                                    <form asp-page-handler="SaveChapter" method="post" class="ops-folder-add-chapter">
                                                        @Html.AntiForgeryToken()
                                                        <input type="hidden" name="SubjectId" value="@subject.SubjectId" />
                                                        <label class="ops-field">
                                                            <span>Thêm chương/mục trong @subject.Code</span>
                                                            <input name="Title" placeholder="VD: Chapter 1 / Mục 1.1" />
                                                        </label>
                                                        <label class="ops-field">
                                                            <span>Thứ tự</span>
                                                            <input name="SortOrder" type="number" value="@(subject.Chapters.Count + 1)" />
                                                        </label>
                                                        <button type="submit" class="ops-mini-button">
                                                            <span class="material-symbols-outlined" aria-hidden="true">create_new_folder</span>
                                                            Thêm mục
                                                        </button>
                                                    </form>
                                                }

                                                @if (Model.IsLecturer)
                                                {
                                                    <form asp-page-handler="Upload" method="post" enctype="multipart/form-data"
                                                          class="ops-tree-subject-upload">
                                                        @Html.AntiForgeryToken()
                                                        <input type="hidden" name="Language" value="vi" data-language-field />
                                                        <input type="hidden" name="Subject" value="@subject.DisplayName" />

                                                        <label class="ops-field">
                                                            <span>Chương/mục</span>
                                                            <input name="Chapter" placeholder="VD: Chapter 1 / Mục 1.1" required />
                                                        </label>
                                                        <label class="ops-field">
                                                            <span>File tài liệu</span>
                                                            <input name="File" type="file" accept=".pdf,.docx,.pptx,.txt" />
                                                        </label>
                                                        <label class="ops-field">
                                                            <span>Hoặc URL bài giảng</span>
                                                            <input name="SourceUrl" type="url" placeholder="https://example.com/lecture" />
                                                        </label>
                                                        <button type="submit" class="ops-button ops-button--primary">
                                                            <span class="material-symbols-outlined" aria-hidden="true">upload_file</span>
                                                            Thêm tài liệu vào môn
                                                        </button>
                                                    </form>
                                                }

                                                <div class="ops-folder-chapter-list">
                                                    @if (subject.Chapters.Count == 0)
                                                    {
                                                        <p class="ops-muted">Môn này chưa có chương/mục.</p>
                                                    }
                                                    @foreach (var chapter in subject.Chapters.OrderBy(item => item.SortOrder).ThenBy(item =>
                                        item.Title))
                                                    {
                                                        <details class="ops-folder-chapter" open>
                                                            <summary class="ops-folder-chapter-summary">
                                                                <span class="material-symbols-outlined" aria-hidden="true">folder_open</span>
                                                                <span class="ops-folder-main">
                                                                    <strong>@chapter.Title</strong>
                                                                    <small>@chapter.Documents.Count tài liệu</small>
                                                                </span>
                                                            </summary>

                                                            <div class="ops-folder-chapter-body">
                                                                @if (Model.IsLecturer)
                                                                {
                                                                    <div class="ops-folder-toolbar">
                                                                        <form asp-page-handler="SaveChapter" method="post"
                                                                              class="ops-inline-edit ops-folder-chapter-edit">
                                                                            @Html.AntiForgeryToken()
                                                                            @if (chapter.ChapterId.HasValue)
                                                                            {
                                                                                <input type="hidden" name="Id" value="@chapter.ChapterId" />
                                                                            }
                                                                            <input type="hidden" name="SubjectId" value="@subject.SubjectId" />
                                                                            <input name="Title" value="@chapter.Title" />
                                                                            <input name="SortOrder" type="number" value="@chapter.SortOrder" />
                                                                            <button type="submit" class="ops-mini-button">Update</button>
                                                                        </form>
                                                                        @if (chapter.ChapterId.HasValue)
                                                                        {
                                                                            <form asp-page-handler="DeleteChapter" method="post"
                                                                                  data-confirm="Xóa chương/mục này? Thao tác này không thể hoàn tác.">
                                                                                @Html.AntiForgeryToken()
                                                                                <input type="hidden" name="id" value="@chapter.ChapterId" />
                                                                                <button type="submit"
                                                                                        class="ops-mini-button ops-mini-button--danger">Delete</button>
                                                                            </form>
                                                                        }
                                                                    </div>
                                                                }

                                                                @if (Model.IsLecturer)
                                                                {
                                                                    <form asp-page-handler="Upload" method="post" enctype="multipart/form-data"
                                                                          class="ops-tree-upload">
                                                                        @Html.AntiForgeryToken()
                                                                        <input type="hidden" name="Language" value="vi" data-language-field />
                                                                        <input type="hidden" name="Subject" value="@chapter.SubjectDisplayName" />
                                                                        <input type="hidden" name="Chapter" value="@chapter.Title" />

                                                                        <label class="ops-field">
                                                                            <span>Thêm file vào @chapter.Title</span>
                                                                            <input name="File" type="file" accept=".pdf,.docx,.pptx,.txt" />
                                                                        </label>
                                                                        <label class="ops-field">
                                                                            <span>Hoặc URL bài giảng</span>
                                                                            <input name="SourceUrl" type="url"
                                                                                   placeholder="https://example.com/lecture" />
                                                                        </label>
                                                                        <button type="submit" class="ops-button ops-button--primary">
                                                                            <span class="material-symbols-outlined"
                                                                                  aria-hidden="true">upload_file</span>
                                                                            Thêm tài liệu
                                                                        </button>
                                                                    </form>
                                                                }

                                                                @if (chapter.Documents.Count == 0)
                                                                {
                                                                    <p class="ops-muted">Chưa có tài liệu trong chương/mục này.</p>
                                                                }
                                                                else
                                                                {
                                                                    <div class="ops-tree-document-list">
                                                                        @foreach (var document in chapter.Documents.OrderByDescending(item =>
                                                    item.UploadedAt))
                                                                        {
                                                                            <div class="ops-tree-document-row" data-document-id="@document.Id"
                                                                                 data-document-status-value="@document.Status"
                                                                                 data-document-size-label="@FormatBytes(document.FileSizeBytes)">
                                                                                <span class="material-symbols-outlined"
                                                                                      aria-hidden="true">description</span>
                                                                                <div class="ops-tree-document-main">
                                                                                    <strong title="@document.FileName">@document.FileName</strong>
                                                                                    <small data-document-tree-meta>@StatusLabel(document) ·
                                                                                        @document.ChunkCount chunks ·
                                                                                        @FormatBytes(document.FileSizeBytes)</small>
                                                                                </div>
                                                                                <div class="ops-document-progress" data-document-progress hidden></div>
                                                                                <div class="ops-row-actions" data-document-actions>
                                                                                        @if (document.Status == DocumentIndexStatus.Indexed)
                                                                                        {
                                                                                            <button type="button" class="ops-mini-button"
                                                                                                    data-document-preview-action data-document-preview-label="Xem"
                                                                                                    data-document-preview-url="/Home/DocumentPreview/@document.Id">Xem</button>
                                                                                        }
                                                                                        else
                                                                                        {
                                                                                            <button type="button" class="ops-mini-button"
                                                                                                    data-document-preview-action data-document-preview-label="Xem"
                                                                                                    disabled title="@StatusTitle(document)">Xem</button>
                                                                                        }
                                                                                        @if (Model.CanEditDocumentMetadata(document, courseCatalog))
                                                                                        {
                                                                                            <a class="ops-mini-button" asp-page="/Home/EditDocument"
                                                                                               asp-route-id="@document.Id">Sửa</a>
                                                                                            <form asp-page-handler="ReindexDocument" method="post"
                                                                                                  data-confirm="Re-index tài liệu này?">
                                                                                                @Html.AntiForgeryToken()
                                                                                                <input type="hidden" name="id" value="@document.Id" />
                                                                                                <button type="submit" class="ops-mini-button">Re-index</button>
                                                                                            </form>
                                                                                            <form asp-page-handler="DeleteDocument" method="post"
                                                                                                  data-confirm="Xóa tài liệu này khỏi kho index? Thao tác này không thể hoàn tác.">
                                                                                                @Html.AntiForgeryToken()
                                                                                                <input type="hidden" name="id" value="@document.Id" />
                                                                                                <button type="submit"
                                                                                                        class="ops-mini-button ops-mini-button--danger">Xóa</button>
                                                                                            </form>
                                                                                        }
                                                                                    </div>
                                                                                </div>
                                                                            }
                                                                        </div>
                                                                    }
                                                                </div>
                                                            </details>
                                                        }
                                                    </div>
                                                </div>
                                            </details>
                                        }
                                    </div>
                                }
                            </div>
                        </section>
                    }

                    <div id="documentPreviewModal" class="rbl-document-preview-modal" aria-hidden="true">
                        <div class="rbl-document-preview-backdrop" data-document-preview-close></div>
                        <section class="rbl-document-preview-dialog" role="dialog" aria-modal="true"
                                 aria-labelledby="documentPreviewTitle">
                            <header class="rbl-document-preview-header">
                                <div>
                                    <span class="rbl-section-label">Indexed content</span>
                                    <h2 id="documentPreviewTitle">Tài liệu</h2>
                                    <p id="documentPreviewMeta"></p>
                                </div>
                                <button type="button" class="rbl-icon-button" aria-label="Close preview" data-document-preview-close>
                                    <span class="material-symbols-outlined" aria-hidden="true">close</span>
                                </button>
                            </header>
                            <div id="documentPreviewBody" class="rbl-document-preview-body">
                                <p class="rbl-catalog-muted">Đang tải nội dung đã index...</p>
                            </div>
                        </section>
                    </div>
                </section>

