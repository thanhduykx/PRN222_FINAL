@page "{id:guid}"
@using PRN222_FINAL.BLL.Models
@model PRN222_FINAL.Web.Pages.Home.CourseWorkspaceModel
@{
    ViewData["Title"] = Model.Subject.DisplayName;
    ViewData["UseRblShell"] = true;
    ViewData["ActiveNav"] = "courses";
    ViewData["ShellTitle"] = "Course workspace";
    ViewData["ShellTitleI18n"] = "home.shellTitleWorkspace";

    string FormatBytes(long bytes)
    {
        var units = new[] { "B", "KB", "MB", "GB", "TB" };
        var size = Math.Max(0, bytes);
        var unitIndex = 0;
        var value = (double)size;
        while (value >= 1024 && unitIndex < units.Length - 1)
        {
            value /= 1024;
            unitIndex++;
        }

        return unitIndex == 0 ? $"{size} {units[unitIndex]}" : $"{value:0.##} {units[unitIndex]}";
    }

    string StatusLabel(IndexedDocument document) => document.Status switch
    {
        DocumentIndexStatus.Indexed => "Đã index",
        DocumentIndexStatus.Processing => "Đang xử lý",
        DocumentIndexStatus.Failed => "Lỗi",
        _ => string.IsNullOrWhiteSpace(document.Status) ? "Chưa index" : document.Status
    };
}

<section class="ops-page course-workspace-page">
    <a class="ops-back-link" asp-page="/Home/Courses">
        <span class="material-symbols-outlined" aria-hidden="true">arrow_back</span>
        <span data-i18n="courseWorkspace.backToCourses">Back to courses</span>
    </a>

    @if (!string.IsNullOrWhiteSpace(Model.LoadErrorMessage))
    {
        <div class="rbl-alert is-error">@Model.LoadErrorMessage</div>
    }

    <section class="course-workspace-grid">
        <section class="ops-panel course-workspace-main-panel">
            <div class="ops-panel-head">
                <h1 data-i18n="courseWorkspace.chaptersAndDocs">Chương và tài liệu</h1>
            </div>
            @if (Model.Chapters.Count == 0)
            {
                <div class="ops-empty">
                    <strong data-i18n="courseWorkspace.emptyChaptersTitle">No chapter has indexed content yet.</strong>
                    <p data-i18n="courseWorkspace.emptyChaptersHint">Upload documents or ask the lecturer to add course material.</p>
                </div>
            }
            else
            {
                <div class="course-chapter-list">
                    @foreach (var chapter in Model.Chapters)
                    {
                        var chapterDocuments = Model.Documents
                            .Where(document => string.Equals(document.Chapter, chapter.Title, StringComparison.OrdinalIgnoreCase))
                            .OrderByDescending(document => document.UploadedAt)
                            .ToList();

                        <article class="course-chapter-section">
                            <header class="course-chapter-heading">
                                <div>
                                <strong>@chapter.Title</strong>
                                <p>@chapter.Summary</p>
                                </div>
                                <span>@chapter.DocumentCount <span data-i18n="courseWorkspace.docsUnit">tài liệu</span> · @chapter.ChunkCount <span data-i18n="courseWorkspace.chunksUnit">chunks</span></span>
                            </header>

                            @if (chapterDocuments.Count == 0)
                            {
                                <p class="course-chapter-empty" data-i18n="documents.emptyChapter">Chưa có tài liệu trong chương/mục này.</p>
                            }
                            else
                            {
                                <div class="course-document-list">
                                    @foreach (var document in chapterDocuments)
                                    {
                                        <div class="course-document-row" data-document-id="@document.Id" data-document-status-value="@document.Status" data-document-size-label="@FormatBytes(document.FileSizeBytes)">
                                            <span class="material-symbols-outlined course-document-icon" aria-hidden="true">description</span>
                                            <div class="course-document-main">
                                                <strong title="@document.FileName">@document.FileName</strong>
                                                <small data-document-tree-meta>@StatusLabel(document) · @document.ChunkCount chunks · @FormatBytes(document.FileSizeBytes)</small>
                                            </div>
                                            <div class="ops-row-actions course-document-actions" data-document-actions>
                                                <button type="button"
                                                        class="ops-mini-button"
                                                        data-document-preview-action
                                                        data-document-preview-url="/Home/DocumentPreview/@document.Id"
                                                        disabled="@(document.Status != DocumentIndexStatus.Indexed ? "disabled" : null)"
                                                        aria-label="Xem @document.FileName">
                                                    Xem
                                                </button>
                                                @if (Model.CanManageCourse)
                                                {
                                                    <a class="ops-mini-button" asp-page="/Home/EditDocument" asp-route-id="@document.Id">Sửa</a>
                                                    <form asp-page-handler="ReindexDocument" method="post" data-confirm="Re-index tài liệu này?">
                                                        @Html.AntiForgeryToken()
                                                        <input type="hidden" name="documentId" value="@document.Id" />
                                                        <button type="submit" class="ops-mini-button">Re-index</button>
                                                    </form>
                                                    <form asp-page-handler="DeleteDocument" method="post" data-confirm="Xóa tài liệu này? Thao tác không thể hoàn tác.">
                                                        @Html.AntiForgeryToken()
                                                        <input type="hidden" name="documentId" value="@document.Id" />
                                                        <button type="submit" class="ops-mini-button ops-mini-button--danger">Xóa</button>
                                                    </form>
                                                }
                                            </div>
                                        </div>
                                    }
                                </div>
                            }
                        </article>
                    }
                </div>
            }
        </section>
    </section>

    <div id="documentPreviewModal" class="rbl-document-preview-modal" aria-hidden="true">
        <div class="rbl-document-preview-backdrop" data-document-preview-close></div>
        <section class="rbl-document-preview-dialog" role="dialog" aria-modal="true" aria-labelledby="documentPreviewTitle">
            <header class="rbl-document-preview-header">
                <div>
                    <span class="rbl-section-label">Nội dung đã index</span>
                    <h2 id="documentPreviewTitle">Tài liệu</h2>
                    <p id="documentPreviewMeta"></p>
                </div>
                <button type="button" class="rbl-icon-button" aria-label="Đóng" data-document-preview-close>
                    <span class="material-symbols-outlined" aria-hidden="true">close</span>
                </button>
            </header>
            <div id="documentPreviewBody" class="rbl-document-preview-body">
                <p class="rbl-catalog-muted">Đang tải nội dung đã index...</p>
            </div>
        </section>
    </div>
</section>

