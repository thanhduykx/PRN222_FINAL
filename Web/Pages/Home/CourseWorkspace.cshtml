@page "{id:guid}"
@using PRN222_FINAL.BLL.Models
@model PRN222_FINAL.Web.Pages.Home.CourseWorkspaceModel
@{
    ViewData["Title"] = Model.Subject.DisplayName;
    ViewData["UseRblShell"] = true;
    ViewData["ActiveNav"] = "courses";
    ViewData["ShellTitle"] = "Course workspace";
}

<section class="ops-page course-workspace-page">
    <a class="ops-back-link" asp-page="/Home/Courses">
        <span class="material-symbols-outlined" aria-hidden="true">arrow_back</span>
        <span data-i18n="courseWorkspace.backToCourses">Back to courses</span>
    </a>

    @if (!string.IsNullOrWhiteSpace(Model.LoadErrorMessage))
    {
        <div class="rbl-alert is-error">@Model.LoadErrorMessage</div>
    }

    <header class="ops-page-header course-workspace-hero">
        <div>
            <span class="ops-eyebrow" data-i18n="courses.eyebrow">Course workspace</span>
            <h1>@Model.Subject.DisplayName</h1>
            @if (string.IsNullOrWhiteSpace(Model.Subject.Description))
            {
                <p data-i18n="courseWorkspace.defaultDescription">Course workspace for documents, chapters, and subject chat.</p>
            }
            else
            {
                <p>@Model.Subject.Description</p>
            }
        </div>
        <div class="ops-subject-header-actions">
            <a class="ops-button ops-button--primary" asp-page="/Home/Chat" asp-route-subject="@Model.Subject.DisplayName">
                <span class="material-symbols-outlined" aria-hidden="true">chat</span>
                <span data-i18n="courseWorkspace.chatCourse">Chat this course</span>
            </a>
            @if (Model.CanManageCourse)
            {
                <a class="ops-button ops-button--secondary" asp-page="/Home/SubjectDocuments" asp-route-id="@Model.Subject.Id">
                    <span class="material-symbols-outlined" aria-hidden="true">folder_managed</span>
                    <span data-i18n="courseWorkspace.manageDocuments">Manage documents</span>
                </a>
            }
        </div>
    </header>

    <section class="ops-kpi-grid course-workspace-kpis" aria-label="Course metrics">
        <article class="ops-kpi">
            <span data-i18n="courseWorkspace.documents">Documents</span>
            <strong>@Model.Documents.Count</strong>
            <small>@Model.Documents.Count(document => document.Status == DocumentIndexStatus.Indexed) <span data-i18n="documents.indexedStatus">indexed</span></small>
        </article>
        <article class="ops-kpi">
            <span data-i18n="courseWorkspace.chapters">Chapters</span>
            <strong>@Model.Chapters.Count</strong>
            <small>@Model.Chapters.Sum(chapter => chapter.ChunkCount) <span data-i18n="courseWorkspace.chunksUnit">chunks</span></small>
        </article>
        <article class="ops-kpi">
            <span data-i18n="courseWorkspace.lecturer">Lecturer</span>
            @if (string.IsNullOrWhiteSpace(Model.Subject.OwnerName))
            {
                <strong data-i18n="courses.unassigned">Unassigned</strong>
            }
            else
            {
                <strong>@Model.Subject.OwnerName</strong>
            }
            @if (string.IsNullOrWhiteSpace(Model.Subject.OwnerEmail))
            {
                <small data-i18n="courseWorkspace.noEmail">No owner email</small>
            }
            else
            {
                <small>@Model.Subject.OwnerEmail</small>
            }
        </article>
    </section>

    <section class="course-workspace-grid">
        <section class="ops-panel course-workspace-main-panel">
            <div class="ops-panel-head">
                <div>
                    <span class="ops-eyebrow" data-i18n="courseWorkspace.courseMap">Course map</span>
                    <h2 data-i18n="courseWorkspace.chaptersAndDocs">Chapters and documents</h2>
                </div>
            </div>
            @if (Model.Chapters.Count == 0)
            {
                <div class="ops-empty">
                    <strong data-i18n="courseWorkspace.emptyChaptersTitle">No chapter has indexed content yet.</strong>
                    <p data-i18n="courseWorkspace.emptyChaptersHint">Upload documents or ask the lecturer to add course material.</p>
                </div>
            }
            else
            {
                <div class="course-chapter-list">
                    @foreach (var chapter in Model.Chapters)
                    {
                        <article class="course-chapter-row">
                            <div>
                                <strong>@chapter.Title</strong>
                                <p>@chapter.Summary</p>
                            </div>
                            <span>@chapter.DocumentCount <span data-i18n="courseWorkspace.docsUnit">docs</span></span>
                            <span>@chapter.ChunkCount <span data-i18n="courseWorkspace.chunksUnit">chunks</span></span>
                        </article>
                    }
                </div>
            }
        </section>
    </section>
</section>

