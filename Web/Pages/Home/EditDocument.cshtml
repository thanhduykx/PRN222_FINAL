@page "{id:guid?}"
@model PRN222_FINAL.Web.Pages.Home.EditDocumentModel
@{
    ViewData["Title"] = "Edit document";
    var subjectOptions = Model.CourseCatalog.Count > 0
        ? Model.CourseCatalog.Select(subject => subject.DisplayName).ToList()
        : new List<string> { Model.Subject };
    var chapterOptions = Model.CourseCatalog.SelectMany(subject => subject.Chapters)
        .OrderBy(chapter => chapter.SubjectCode)
        .ThenBy(chapter => chapter.SortOrder)
        .ThenBy(chapter => chapter.Title)
        .Select(chapter => chapter.Title)
        .Distinct(StringComparer.OrdinalIgnoreCase)
        .ToList();

    string FormatBytes(long bytes)
    {
        string[] units = ["B", "KB", "MB", "GB"];
        var size = (double)Math.Max(0, bytes);
        var unit = 0;
        while (size >= 1024 && unit < units.Length - 1)
        {
            size /= 1024;
            unit++;
        }

        return $"{size:0.##} {units[unit]}";
    }
}

<section class="rbl-detail-page">
    <a class="rbl-back-link" asp-page="/Home/Index">
        <span class="material-symbols-outlined">arrow_back</span>
        <span data-i18n="documents.backToRepo">Quay lại kho tài liệu</span>
    </a>

    @if (TempData["Error"] is string error)
    {
        <div class="rbl-alert is-error">@error</div>
    }

    <section class="rbl-panel rbl-document-edit-panel">
        <div class="rbl-panel-header">
            <div>
                <span class="rbl-section-label">Document CRUD</span>
                <h2 data-i18n="documents.editInfoTitle">Sửa thông tin tài liệu</h2>
            </div>
            <span class="rbl-table-meta">@Model.ChunkCount chunks</span>
        </div>

        <div class="rbl-document-edit-summary">
            <article>
                <span data-i18n="documents.fileType">Loại file</span>
                <strong>@Model.ContentType</strong>
            </article>
            <article>
                <span data-i18n="documents.fileSize">Dung lượng</span>
                <strong>@FormatBytes(Model.FileSizeBytes)</strong>
            </article>
            <article>
                <span data-i18n="documents.uploadDate">Ngày upload</span>
                <strong>@Model.UploadedAt.LocalDateTime.ToString("yyyy-MM-dd HH:mm")</strong>
            </article>
            <article>
                <span data-i18n="documents.uploader">Người upload</span>
                <strong title="@Model.UploadedByEmail">@(string.IsNullOrWhiteSpace(Model.UploadedByName) ? "Unknown" : Model.UploadedByName)</strong>
            </article>
        </div>

        <form asp-page="/Home/EditDocument" method="post" class="rbl-document-edit-form">
            @Html.AntiForgeryToken()
            <input asp-for="Id" type="hidden" />

            <label class="rbl-field">
                <span data-i18n="documents.displayName">Tên hiển thị</span>
                <input asp-for="FileName" />
                <small data-i18n="documents.displayNameDesc">Không đổi file vật lý; chỉ đổi tên hiển thị và citation về sau.</small>
            </label>

            <div class="rbl-form-grid">
                <label class="rbl-field">
                    <span>Subject</span>
                    <input asp-for="Subject" list="editSubjectOptions" />
                </label>
                <label class="rbl-field">
                    <span>Chapter</span>
                    <input asp-for="Chapter" list="editChapterOptions" />
                </label>
            </div>

            <datalist id="editSubjectOptions">
                @foreach (var subject in subjectOptions)
                {
                    <option value="@subject"></option>
                }
            </datalist>
            <datalist id="editChapterOptions">
                @foreach (var chapter in chapterOptions)
                {
                    <option value="@chapter"></option>
                }
            </datalist>

            <div class="rbl-form-actions">
                <button type="submit" class="rbl-submit-button"><span data-i18n="documents.saveChanges">Lưu thay đổi</span></button>
                <button type="button" class="rbl-secondary-button" data-document-preview-url="/Home/DocumentPreview/@Model.Id"><span data-i18n="documents.viewDocument">Xem tài liệu</span></button>
            </div>
        </form>
    </section>

    <div id="documentPreviewModal" class="rbl-document-preview-modal" aria-hidden="true">
        <div class="rbl-document-preview-backdrop" data-document-preview-close></div>
        <section class="rbl-document-preview-dialog" role="dialog" aria-modal="true" aria-labelledby="documentPreviewTitle">
            <header class="rbl-document-preview-header">
                <div>
                    <span class="rbl-section-label">Indexed content</span>
                    <h2 id="documentPreviewTitle" data-i18n="documents.previewTitle">Tài liệu</h2>
                    <p id="documentPreviewMeta"></p>
                </div>
                <button type="button" class="rbl-icon-button" aria-label="Close preview" data-document-preview-close>
                    <span class="material-symbols-outlined" aria-hidden="true">close</span>
                </button>
            </header>
            <div id="documentPreviewBody" class="rbl-document-preview-body">
                <p class="rbl-catalog-muted" data-i18n="documents.loadingIndex">Đang tải nội dung đã index...</p>
            </div>
        </section>
    </div>
</section>

