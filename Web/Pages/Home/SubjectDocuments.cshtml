@page "{id:guid}"
@using PRN222_FINAL.BLL.Models
@model PRN222_FINAL.Web.Pages.Home.SubjectDocumentsModel
@{
    ViewData["Title"] = Model.Subject.DisplayName;
    ViewData["UseRblShell"] = true;
    ViewData["ActiveNav"] = "documents";
    ViewData["ShellTitle"] = "Chi ti&#7871;t m&#244;n h&#7885;c";
    ViewData["ShellTitleI18n"] = "home.shellTitleSubjectDocs";
    ViewData["ShellTitleI18n"] = "documents.shellTitle";

    string FormatBytes(long bytes)
    {
        var units = new[] { "B", "KB", "MB", "GB", "TB" };
        var size = Math.Max(0, bytes);
        var unitIndex = 0;
        var value = (double)size;
        while (value >= 1024 && unitIndex < units.Length - 1)
        {
            value /= 1024;
            unitIndex++;
        }

        return unitIndex == 0 ? $"{size} {units[unitIndex]}" : $"{value:0.##} {units[unitIndex]}";
    }

    string PersonLabel(string name, string fallback)
    {
        return string.IsNullOrWhiteSpace(name) ? fallback : name.Trim();
    }

    string StatusLabel(IndexedDocument document)
    {
        return document.Status switch
        {
            DocumentIndexStatus.Indexed => "Indexed",
            DocumentIndexStatus.Processing => "Processing",
            DocumentIndexStatus.Failed => "Failed",
            _ => string.IsNullOrWhiteSpace(document.Status) ? "Unknown" : document.Status
        };
    }

    string StatusTitle(IndexedDocument document)
    {
        if (document.Status == DocumentIndexStatus.Failed && !string.IsNullOrWhiteSpace(document.IndexError))
        {
            return "System error while processing document. Please check the file or try again.";
        }

        if (document.Status == DocumentIndexStatus.Indexed && document.IndexedAt.HasValue)
        {
            return $"Indexed at {document.IndexedAt.Value.LocalDateTime:yyyy-MM-dd HH:mm}";
        }

        return StatusLabel(document);
    }
}

<section class="ops-page ops-documents-page ops-subject-detail-page">
    <a class="ops-back-link" asp-page="/Home/Index">
        <span class="material-symbols-outlined" aria-hidden="true">arrow_back</span>
        <span data-i18n="documents.backToCatalog">Quay lại danh sách môn</span>
    </a>

    <header class="ops-page-header">
        <div>
            <span class="ops-eyebrow" data-i18n="documents.eyebrow">Course documents</span>
            <h1>@Model.Subject.DisplayName</h1>
            <p>@(string.IsNullOrWhiteSpace(Model.Subject.Description) ? Html.Raw("<span data-i18n=\"documents.defaultDescription\">Quản lý chương, file và link bài giảng của môn này.</span>") : Html.Raw(Model.Subject.Description))</p>
        </div>
        <div class="ops-subject-header-actions">
            <span class="ops-chip">@Model.Subject.DocumentCount <span data-i18n="documents.documentsUnit">tài liệu</span></span>
            <span class="ops-chip">@Model.Subject.Chapters.Count <span data-i18n="documents.chaptersUnit">chương</span></span>
            @if (!string.IsNullOrWhiteSpace(Model.Subject.OwnerName))
            {
                <span class="ops-chip">Owner: @PersonLabel(Model.Subject.OwnerName, "Unassigned")</span>
            }
        </div>
    </header>

    @if (TempData["Success"] is string success)
    {
        <div class="rbl-alert is-success">@success</div>
    }
    @if (TempData["Error"] is string error)
    {
        <div class="rbl-alert is-error">@error</div>
    }
    @if (!string.IsNullOrWhiteSpace(Model.LoadErrorMessage))
    {
        <div class="rbl-alert is-error">@Model.LoadErrorMessage</div>
    }

    <section class="ops-subject-detail-grid">
        @if (Model.IsAdmin && Model.IsRealCatalogSubject)
        {
            <section class="ops-panel ops-subject-manage-panel" style="display: flex; flex-direction: column; gap: 12px;">
                <form asp-page-handler="SaveSubject" method="post" id="editSubjectForm" style="display:none;">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="Id" value="@Model.Subject.SubjectId" />
                </form>
                <form asp-page-handler="DeleteSubject" method="post" id="deleteSubjectForm" data-confirm-i18n="documents.deleteSubjectConfirm" data-confirm="Delete this subject and all its chapters? This cannot be undone." style="display:none;">
                    @Html.AntiForgeryToken()
                </form>

                <div class="ops-panel-head">
                    <div>
                        <span class="ops-eyebrow">Subject</span>
                        <h2 data-i18n="documents.editSubjectInfo">Sửa thông tin môn</h2>
                    </div>
                </div>
                
                <label class="ops-field" style="width: 100%;">
                    <span data-i18n="documents.subjectCode">Mã môn</span>
                    <input form="editSubjectForm" name="Code" value="@Model.Subject.Code" style="width: 100%;" />
                </label>
                <label class="ops-field" style="width: 100%;">
                    <span data-i18n="documents.subjectDesc">Mô tả</span>
                    <input form="editSubjectForm" name="Description" value="@Model.Subject.Description" style="width: 100%;" />
                </label>

                <div class="ops-subject-actions" style="margin-top: auto; display: flex; gap: 8px; justify-content: flex-end; width: 100%;">
                    <button type="submit" form="deleteSubjectForm" class="ops-button ops-button--secondary" data-i18n="documents.deleteSubject">Xóa môn</button>
                    <button type="submit" form="editSubjectForm" class="ops-button ops-button--primary" data-i18n="documents.saveSubject">Lưu môn</button>
                </div>
            </section>
        }

        <form asp-page-handler="SaveChapter" method="post" class="ops-panel ops-subject-manage-panel" style="display: flex; flex-direction: column; gap: 12px;">
            @Html.AntiForgeryToken()
            <input type="hidden" name="SubjectId" value="@Model.Subject.SubjectId" />
            <div class="ops-panel-head">
                <div>
                    <span class="ops-eyebrow">Chapter</span>
                    <h2 data-i18n="documents.addChapter">Thêm chương/mục</h2>
                </div>
            </div>
            <label class="ops-field" style="width: 100%;">
                <span data-i18n="documents.chapterTitle">Tên chương/mục</span>
                <input name="Title" placeholder="VD: Chapter 1 / Muc 1.1" data-i18n-placeholder="documents.chapterTitlePlaceholder" required style="width: 100%;" />
            </label>
            <label class="ops-field" style="width: 100%;">
                <span data-i18n="documents.sortOrder">Thứ tự</span>
                <input name="SortOrder" type="number" value="@(Model.Subject.Chapters.Count + 1)" style="width: 100%;" />
            </label>
            <div style="margin-top: auto; display: flex; justify-content: flex-end; width: 100%;">
                <button type="submit" class="ops-button ops-button--primary" data-i18n="documents.addChapterBtn">Thêm chương</button>
            </div>
        </form>

        @if (Model.IsLecturer)
        {
            <form asp-page-handler="Upload" method="post" enctype="multipart/form-data" class="ops-panel ops-subject-manage-panel ops-subject-upload-panel">
                @Html.AntiForgeryToken()
                <input type="hidden" name="Language" value="vi" data-language-field />
                <input type="hidden" name="Subject" value="@Model.Subject.DisplayName" />
                <div class="ops-panel-head">
                    <div>
                        <span class="ops-eyebrow">Upload</span>
                        <h2 data-i18n="documents.addDocument">Thêm tài liệu</h2>
                    </div>
                </div>
                <label class="ops-field">
                    <span data-i18n="documents.chapterLabel">Chương/mục</span>
                    <input name="Chapter" placeholder="VD: Chapter 1 / Muc 1.1" data-i18n-placeholder="documents.chapterTitlePlaceholder" required />
                </label>
                <label class="ops-field">
                    <span data-i18n="documents.documentFile">File tài liệu</span>
                    <input name="File" type="file" accept=".pdf,.docx,.pptx,.txt" />
                </label>
                <label class="ops-field">
                    <span data-i18n="documents.orLectureUrl">Hoặc URL bài giảng</span>
                    <input name="SourceUrl" type="url" placeholder="https://example.com/lecture" />
                </label>
                <button type="submit" class="ops-button ops-button--primary">
                    <span class="material-symbols-outlined" aria-hidden="true">upload_file</span>
                    <span data-i18n="documents.indexDocumentBtn">Index tài liệu</span>
                </button>
            </form>
        }
    </section>

    <section class="ops-panel">
        <div class="ops-panel-head">
            <div>
                <span class="ops-eyebrow">Documents</span>
                <h2 data-i18n="documents.chaptersAndDocuments">Chương và tài liệu</h2>
            </div>
        </div>

        @if (Model.Subject.Chapters.Count == 0)
        {
            <div class="ops-empty">
                <strong data-i18n="documents.noChapters">Môn này chưa có chương/mục.</strong>
                <p data-i18n="documents.noChaptersHint">Thêm chương trước, sau đó upload tài liệu vào đúng mục.</p>
            </div>
        }
        else
        {
            <div class="ops-folder-chapter-list">
                @foreach (var chapter in Model.Subject.Chapters.OrderBy(item => item.SortOrder).ThenBy(item => item.Title))
                {
                    <details class="ops-folder-chapter" open>
                        <summary class="ops-folder-chapter-summary">
                            <span class="material-symbols-outlined" aria-hidden="true">folder_open</span>
                            <span class="ops-folder-main">
                                <strong>@chapter.Title</strong>
                                <small>@chapter.Documents.Count <span data-i18n="documents.documentsUnit">tài liệu</span></small>
                            </span>
                        </summary>

                        <div class="ops-folder-chapter-body">
                            <div class="ops-folder-toolbar">
                                <form asp-page-handler="SaveChapter" method="post" class="ops-inline-edit ops-folder-chapter-edit">
                                    @Html.AntiForgeryToken()
                                    @if (chapter.ChapterId.HasValue)
                                    {
                                        <input type="hidden" name="Id" value="@chapter.ChapterId" />
                                    }
                                    <input type="hidden" name="SubjectId" value="@Model.Subject.SubjectId" />
                                    <input name="Title" value="@chapter.Title" required />
                                    <input name="SortOrder" type="number" value="@chapter.SortOrder" />
                                    <button type="submit" class="ops-mini-button" data-i18n="documents.updateBtn">Update</button>
                                </form>
                                @if (chapter.ChapterId.HasValue)
                                {
                                    <form asp-page-handler="DeleteChapter" method="post" data-confirm-i18n="documents.deleteChapterConfirm" data-confirm="Delete this chapter? This cannot be undone.">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="chapterId" value="@chapter.ChapterId" />
                                        <button type="submit" class="ops-mini-button ops-mini-button--danger" data-i18n="documents.deleteBtn">Delete</button>
                                    </form>
                                }
                            </div>

                            @if (Model.IsLecturer)
                            {
                                <form asp-page-handler="Upload" method="post" enctype="multipart/form-data" class="ops-tree-upload">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="Language" value="vi" data-language-field />
                                    <input type="hidden" name="Subject" value="@Model.Subject.DisplayName" />
                                    <input type="hidden" name="Chapter" value="@chapter.Title" />

                                    <label class="ops-field">
                                        <span><span data-i18n="documents.addFileTo">Thêm file vào</span> @chapter.Title</span>
                                        <input name="File" type="file" accept=".pdf,.docx,.pptx,.txt" />
                                    </label>
                                    <label class="ops-field">
                                        <span data-i18n="documents.orLectureUrl">Hoặc URL bài giảng</span>
                                        <input name="SourceUrl" type="url" placeholder="https://example.com/lecture" />
                                    </label>
                                    <button type="submit" class="ops-button ops-button--primary">
                                        <span class="material-symbols-outlined" aria-hidden="true">upload_file</span>
                                        Th&#234;m t&#224;i li&#7879;u
                                    </button>
                                </form>
                            }

                            @if (chapter.Documents.Count == 0)
                            {
                                <p class="ops-muted"><span data-i18n="documents.emptyChapter">Chưa có tài liệu trong chương/mục này.</span></p>
                            }
                            else
                            {
                                <div class="ops-tree-document-list">
                                    @foreach (var document in chapter.Documents.OrderByDescending(item => item.UploadedAt))
                                    {
                                        <div class="ops-tree-document-row" data-document-id="@document.Id" data-document-status-value="@document.Status" data-document-size-label="@FormatBytes(document.FileSizeBytes)">
                                            <span class="material-symbols-outlined" aria-hidden="true">description</span>
                                            <div class="ops-tree-document-main">
                                                <strong title="@document.FileName">@document.FileName</strong>
                                                <small data-document-tree-meta><span data-i18n="documents.status.@(document.Status?.ToLowerInvariant() ?? "unknown")">@StatusLabel(document)</span> - @document.ChunkCount chunks - @FormatBytes(document.FileSizeBytes)</small>
                                            </div>
                                            <div class="ops-row-actions" data-document-actions>
                                                @if (document.Status == DocumentIndexStatus.Indexed)
                                                {
                                                    <button type="button" class="ops-mini-button" data-document-preview-action data-document-preview-label="documents.previewBtn" data-document-preview-url="/Home/DocumentPreview/@document.Id" data-i18n="documents.previewBtn">Xem</button>
                                                }
                                                else
                                                {
                                                    <button type="button" class="ops-mini-button" data-document-preview-action data-document-preview-label="documents.previewBtn" disabled title="Unable to view" data-i18n="documents.previewBtn">Xem</button>
                                                }
                                                @if (Model.CanManageDocumentAction(document, Model.Subject))
                                                {
                                                    <a class="ops-mini-button" asp-page="/Home/EditDocument" asp-route-id="@document.Id" data-i18n="documents.editBtn">Sửa</a>
                                                    <form asp-page-handler="ReindexDocument" method="post" data-confirm-i18n="documents.reindexConfirm" data-confirm="Re-index this document?">
                                                    @Html.AntiForgeryToken()
                                                    <input type="hidden" name="documentId" value="@document.Id" />
                                                    <button type="submit" class="ops-mini-button" data-i18n="documents.reindexBtn">Re-index</button>
                                                </form>
                                                <form asp-page-handler="DeleteDocument" method="post" data-confirm-i18n="documents.deleteConfirm" data-confirm="Delete this document from index? This cannot be undone.">
                                                    @Html.AntiForgeryToken()
                                                    <input type="hidden" name="documentId" value="@document.Id" />
                                                    <button type="submit" class="ops-mini-button ops-mini-button--danger" data-i18n="documents.deleteDocBtn">Xóa</button>
                                                </form>
                                                }
                                            </div>
                                        </div>
                                    }
                                </div>
                            }
                        </div>
                    </details>
                }
            </div>
        }
    </section>

    <div id="documentPreviewModal" class="rbl-document-preview-modal" aria-hidden="true">
        <div class="rbl-document-preview-backdrop" data-document-preview-close></div>
        <section class="rbl-document-preview-dialog" role="dialog" aria-modal="true" aria-labelledby="documentPreviewTitle">
            <header class="rbl-document-preview-header">
                <div>
                    <span class="rbl-section-label" data-i18n="documents.indexedContent">Indexed content</span>
                    <h2 id="documentPreviewTitle" data-i18n="documents.previewTitle">Tài liệu</h2>
                    <p id="documentPreviewMeta"></p>
                </div>
                <button type="button" class="rbl-icon-button" aria-label="Close preview" data-document-preview-close>
                    <span class="material-symbols-outlined" aria-hidden="true">close</span>
                </button>
            </header>
            <div id="documentPreviewBody" class="rbl-document-preview-body">
                <p class="rbl-catalog-muted"><span data-i18n="documents.loadingContent">Đang tải nội dung đã index...</span></p>
            </div>
        </section>
    </div>
</section>

