@page
@model PRN222_FINAL.Web.Pages.Home.ChatModel
@{
    ViewData["Title"] = "Chatbot";
    ViewData["UseRblShell"] = true;
    ViewData["ActiveNav"] = "chat";
    ViewData["ShellTitle"] = "Chatbot tài liệu";
    ViewData["ShellTitleI18n"] = "home.shellTitleChat";
    ViewData["ShellTitleI18n"] = "chat.title";
    ViewData["HideAssistantLauncher"] = true;

    var subjectOptions = Model.SubjectOptions
        .Where(subject => !string.IsNullOrWhiteSpace(subject))
        .Distinct(StringComparer.OrdinalIgnoreCase)
        .OrderBy(subject => subject)
        .ToList();
    var suggestedQuestions = subjectOptions.Count == 0
        ? new (string En, string Vi, string Subject)[]
        {
            ("Which subjects have ready documents?", "Which subjects have ready documents?", string.Empty),
            ("Summarize the available documents.", "Summarize the available documents.", string.Empty),
            ("What can I ask from the document repository?", "What can I ask from the document repository?", string.Empty)
        }
        : subjectOptions
            .Take(6)
            .Select(subject => new
            {
                En = $"What is {subject} about?",
                Vi = $"{subject} là môn gì?",
                Subject = subject
            })
            .Select(item => (item.En, item.Vi, item.Subject))
            .ToArray();
    var relatedQuestions = subjectOptions.Count == 0
        ? Array.Empty<(string En, string Vi, string Subject)>()
        : subjectOptions
            .Take(12)
            .SelectMany(subject => new[]
            {
                ($"How many credits does {subject} have?", $"{subject} có bao nhiêu tín chỉ?", subject),
                ($"What is {subject} about?", $"{subject} là môn gì?", subject),
                ($"What are the main contents of {subject}?", $"Nội dung chính của {subject} gồm những gì?", subject),
                ($"How is {subject} assessed?", $"{subject} được đánh giá như thế nào?", subject),
                ($"What learning outcomes does {subject} mention?", $"{subject} có chuẩn đầu ra nào?", subject),
                ($"What materials or resources are used in {subject}?", $"{subject} dùng tài liệu hoặc nguồn học nào?", subject),
                ($"What does the syllabus say students need to do in {subject}?", $"Sinh viên cần làm gì trong {subject}?", subject)
            })
            .ToArray();
    var suggestionsEn = suggestedQuestions.Select(item => item.En).ToArray();
    var suggestionsVi = suggestedQuestions.Select(item => item.Vi).ToArray();
    var subjectPayload = subjectOptions
        .Select((subject, index) => new { id = $"subject-option-{index}", subject, en = subject, vi = subject })
        .ToArray();
    var relatedPayload = relatedQuestions
        .Select((item, index) => new { id = $"subject-{index}", subject = item.Item3, en = item.Item1, vi = item.Item2 })
        .ToArray();
    var initialRelatedQuestions = relatedQuestions.Take(8).ToArray();
}

<section class="rbl-chat-page"
         data-chat-suggestions-en='@System.Text.Json.JsonSerializer.Serialize(suggestionsEn)'
         data-chat-suggestions-vi='@System.Text.Json.JsonSerializer.Serialize(suggestionsVi)'
         data-chat-subject-suggestions='@System.Text.Json.JsonSerializer.Serialize(subjectPayload)'
         data-chat-related-questions='@System.Text.Json.JsonSerializer.Serialize(relatedPayload)'>
    @if (!string.IsNullOrWhiteSpace(Model.LoadErrorMessage))
    {
        <div class="rbl-alert is-error">@Model.LoadErrorMessage</div>
    }
    <section class="chat-source-scope" aria-label="Phạm vi nguồn trả lời" data-i18n-aria-label="chat.scopeAria" data-chat-subject-count="@subjectOptions.Count">
        <span class="material-symbols-outlined" aria-hidden="true">verified_user</span>
        <div>
            <strong data-i18n="chat.scopeTitle">Trả lời dựa trên tài liệu đã index</strong>
            <span data-chat-scope-label>
                @if (subjectOptions.Count == 0)
                {
                    <span data-i18n="chat.scopeEmpty">Chưa có môn học sẵn sàng</span>
                }
                else
                {
                    <span data-i18n="chat.scopeCountPrefix">Đang tìm trong</span> @subjectOptions.Count <span data-i18n="chat.scopeCountSuffix">môn học có quyền truy cập</span>
                }
            </span>
        </div>
        <a asp-page="/Home/Courses" class="chat-source-scope__link" hidden="@(!User.IsInRole(PRN222_FINAL.BLL.Security.AppRoles.Lecturer) && !User.IsInRole(PRN222_FINAL.BLL.Security.AppRoles.Admin))" data-i18n="chat.viewCourses">Xem môn học</a>
    </section>
    <main class="rbl-chat-main" aria-label="Document chat" data-i18n-aria-label="chat.mainAria">
        <div id="chatMessages" class="chat-messages codex-chat-messages rbl-chat-messages" role="log" aria-live="polite" aria-relevant="additions text" aria-label="Nội dung hội thoại" data-i18n-aria-label="chat.messagesAria">
            <div class="chat-empty-state rbl-chat-empty">
                <span class="rbl-bot-mark">AI</span>
                <h3 data-i18n="chat.emptyTitle">Bắt đầu bằng một câu hỏi cụ thể</h3>
                <p data-i18n="chat.emptyText">Chọn gợi ý bên dưới hoặc nhập câu hỏi về tài liệu môn học.</p>
                <div class="suggestion-grid rbl-suggestion-grid" aria-label="Question suggestions" data-i18n-aria-label="chat.suggestionsAria">
                    @foreach (var question in suggestedQuestions)
                    {
                        <button type="button" class="suggestion-chip" data-question="@question.En" data-question-en="@question.En" data-question-vi="@question.Vi">@question.En</button>
                    }
                </div>
            </div>
            <div class="message assistant">
                <div class="bubble" data-i18n="chat.welcome">Bạn có thể hỏi về nội dung tài liệu môn học. Câu trả lời sẽ rõ ràng và có nguồn tham khảo.</div>
            </div>
        </div>

        <form id="chatForm" class="chat-form codex-chat-form rbl-chat-form">
            @Html.AntiForgeryToken()
            @if (subjectOptions.Count > 0)
            {
                <div class="chat-subject-filter" aria-label="Subject filter">
                    <button type="button" class="chat-subject-chip is-active" data-subject-filter="" data-i18n="chat.allSubjects">All subjects</button>
                    @foreach (var subject in subjectOptions)
                    {
                        <button type="button" class="chat-subject-chip" data-subject-filter="@subject">@subject</button>
                    }
                </div>
            }
            @if (relatedQuestions.Length > 0)
            {
                <div class="chat-related-strip rbl-related-strip" aria-label="Related questions" data-i18n-aria-label="chat.relatedAria">
                    <span data-i18n="chat.relatedLabel">Related questions</span>
                    <div class="chat-related-list">
                        @foreach (var question in initialRelatedQuestions)
                        {
                            <button type="button" class="related-question-chip" data-question="@question.Item1" data-question-en="@question.Item1" data-question-vi="@question.Item2">@question.Item1</button>
                        }
                    </div>
                </div>
            }
            <textarea id="questionInput" rows="2" maxlength="4000" aria-label="Nhập câu hỏi" data-i18n-aria-label="chat.inputAria" placeholder="Hỏi về môn học, chương hoặc tài liệu..." data-i18n-placeholder="chat.placeholder"></textarea>
            <button type="submit" class="rbl-submit-button" data-i18n="chat.send">
                <span class="material-symbols-outlined" aria-hidden="true">send</span>
                Send
            </button>
        </form>
        @if (User.IsInRole(PRN222_FINAL.BLL.Security.AppRoles.Student))
        {
            <section class="chat-preferences" aria-label="Reply preferences" data-i18n-aria-label="chat.replyPrefsAria">
                <label class="chat-preference-control">
                    <span class="material-symbols-outlined chat-preference-control__icon" aria-hidden="true">speed</span>
                    <span class="chat-preference-control__copy">
                        <strong data-i18n="chat.speed">Tốc độ hiển thị</strong>
                        <small data-i18n="chat.speedHelp">Hiệu ứng trả chữ</small>
                    </span>
                    <select id="responsePace" aria-label="Tốc độ hiển thị câu trả lời" data-i18n-aria-label="chat.responsePaceAria">
                        <option value="fast" data-i18n="chat.paceFast">Nhanh</option>
                        <option value="comfortable" selected data-i18n="chat.paceComfortable">Dễ theo dõi</option>
                    </select>
                </label>
                <label class="chat-preference-control">
                    <span class="material-symbols-outlined chat-preference-control__icon" aria-hidden="true">format_align_left</span>
                    <span class="chat-preference-control__copy">
                        <strong data-i18n="chat.replyMode">Độ chi tiết</strong>
                        <small data-i18n="chat.depthHelp">Điều chỉnh nội dung</small>
                    </span>
                    <select id="answerDepth" aria-label="Mức độ hỗ trợ" data-i18n-aria-label="chat.answerDepthAria">
                        <option value="concise" data-i18n="chat.depthConcise">Tóm tắt</option>
                        <option value="balanced" selected data-i18n="chat.depthBalanced">Cân bằng</option>
                        <option value="deep" data-i18n="chat.depthDeep">Phân tích kỹ</option>
                    </select>
                </label>
                <div class="chat-usage" aria-live="polite">
                    <span data-i18n="chat.remaining">Còn lại</span>
                    @if (Model.Usage.Remaining.HasValue)
                    {
                        <strong id="questionsRemaining">@Model.Usage.Remaining.Value.ToString("N0")</strong>
                    }
                    else
                    {
                        <strong id="questionsRemaining" data-i18n="chat.unlimited">Không giới hạn</strong>
                    }
                    @{
                        var planKey = Model.Usage.PlanName switch {
                            "Free" => "packages.name.free",
                            "Student" => "packages.name.student",
                            "Pro" => "packages.name.pro",
                            "12 tháng" => "packages.name.annual",
                            _ => "packages.name.none"
                        };
                    }
                    <small data-i18n="@planKey">@Model.Usage.PlanName</small>
                </div>
            </section>
        }
    </main>

    <aside class="rbl-session-panel" aria-label="Chat session history" data-i18n-aria-label="chat.sessionsAria">
        <div class="rbl-session-actions">
            <button id="newSessionButton" type="button" class="rbl-submit-button" data-i18n="chat.newSession">
                <span class="material-symbols-outlined" aria-hidden="true">add</span>
                New session
            </button>
        </div>

        <div class="rbl-session-header">
            <strong data-i18n="chat.history">Lịch sử hội thoại</strong>
            <span><span id="sessionCount">@Model.ChatSessions.Count</span> <span data-i18n="chat.sessionsUnit">sessions</span></span>
        </div>

        <div id="chatSessionList" class="chat-session-list rbl-session-list">
            @if (Model.ChatSessions.Count == 0)
            {
                <p class="session-empty" data-i18n="chat.noSessions">No sessions yet.</p>
            }
            else
            {
                foreach (var session in Model.ChatSessions)
                {
                    var firstQuestion = session.FirstUserMessagePreview?.Trim();
                    var title = !string.IsNullOrWhiteSpace(session.Title)
                        ? session.Title.Trim()
                        : string.IsNullOrWhiteSpace(firstQuestion)
                        ? "Session without a question"
                        : firstQuestion.Length <= 56 ? firstQuestion : $"{firstQuestion[..56]}...";

                    <div class="chat-session-entry @(session.IsStarred ? "is-starred" : string.Empty)" data-session-entry data-session-id="@session.Id">
                        <button type="button" class="chat-session-item" data-session-id="@session.Id">
                            <span>
                                @if (session.IsStarred)
                                {
                                    <span class="material-symbols-outlined session-star" aria-hidden="true">star</span>
                                }
                                @title
                            </span>
                            <small>@session.UpdatedAt.ToLocalTime().ToString("dd/MM HH:mm") / @session.MessageCount messages</small>
                        </button>
                        <button type="button" class="chat-session-menu-button" data-session-menu-toggle data-session-id="@session.Id" aria-label="Session actions">
                            <span class="material-symbols-outlined" aria-hidden="true">more_vert</span>
                        </button>
                        <div class="chat-session-menu" data-session-menu>
                            <button type="button" data-session-action="star" data-session-id="@session.Id" data-session-starred="@session.IsStarred.ToString().ToLowerInvariant()">
                                <span class="material-symbols-outlined" aria-hidden="true">star</span>
                                <span>@(session.IsStarred ? "Unstar" : "Star")</span>
                            </button>
                            <button type="button" data-session-action="rename" data-session-id="@session.Id">
                                <span class="material-symbols-outlined" aria-hidden="true">edit</span>
                                <span>Rename</span>
                            </button>
                            <button type="button" class="danger" data-session-action="delete" data-session-id="@session.Id">
                                <span class="material-symbols-outlined" aria-hidden="true">delete</span>
                                <span>Delete</span>
                            </button>
                        </div>
                    </div>
                }
            }
        </div>

    </aside>
</section>

