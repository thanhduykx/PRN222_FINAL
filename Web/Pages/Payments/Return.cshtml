@page
@using PRN222_FINAL.BLL.Models
@model PRN222_FINAL.Web.Pages.Payments.ReturnModel
@{
    ViewData["Title"] = "Kết quả thanh toán";
    ViewData["UseRblShell"] = true;
    ViewData["ActiveNav"] = "billing";
    ViewData["ShellTitle"] = "Kết quả thanh toán";

    var status = Model.Status?.Status == PaymentStatus.Paid
        ? PaymentStatus.Paid
        : Model.ReturnStatusHint is PaymentStatus.Failed or PaymentStatus.Canceled
            ? Model.ReturnStatusHint
            : Model.Status?.Status;
    var isSuccess = status == PaymentStatus.Paid;
    var isFailure = status is PaymentStatus.Failed or PaymentStatus.Canceled;
    var stateClass = isSuccess ? "is-success" : isFailure ? "is-error" : "is-pending";
    var stateIcon = isSuccess ? "check_circle" : isFailure ? "cancel" : "hourglass_top";
    var stateTitle = isSuccess
        ? "Thanh toán thành công"
        : isFailure
            ? "Thanh toán chưa thành công"
            : "Đang xác nhận thanh toán";
    var stateMessage = isSuccess
        ? "Gói trợ lý học tập đã được kích hoạt và sẵn sàng sử dụng."
        : isFailure
            ? "Giao dịch chưa hoàn tất nên gói hiện tại của bạn không thay đổi."
            : "Hệ thống đang chờ xác nhận từ cổng thanh toán. Bạn có thể kiểm tra lại sau ít phút.";
    var statusLabel = isSuccess ? "Đã thanh toán" : isFailure ? "Chưa hoàn tất" : "Đang xử lý";
    var providerName = Model.Status?.Provider.ToString() ?? string.Empty;
    var providerLogo = providerName.Equals("MoMo", StringComparison.OrdinalIgnoreCase)
        ? "/img/payments/momo.svg"
        : "/img/payments/payos.svg";
    var customerName = string.IsNullOrWhiteSpace(Model.Status?.CustomerName)
        ? User.Identity?.Name ?? "bạn"
        : Model.Status.CustomerName;
    var packageName = string.IsNullOrWhiteSpace(Model.Status?.PackageName)
        ? Model.Status?.PackageCode ?? "Gói trợ lý học tập"
        : Model.Status.PackageName;
    var effectiveUntil = Model.Status?.IsLifetime == true
        ? "Trọn đời"
        : Model.Status?.SubscriptionEndsAt?.LocalDateTime.ToString("dd/MM/yyyy HH:mm") ?? "Đang cập nhật";
}

<section class="ops-page payment-result-page">
    <header class="payment-result-hero">
        <div class="payment-result-hero__mark @stateClass">
            <span class="material-symbols-outlined" aria-hidden="true">@stateIcon</span>
        </div>
        <span class="payment-result-hero__eyebrow">Kết quả giao dịch</span>
        <h1>@(string.IsNullOrWhiteSpace(Model.ErrorMessage) ? stateTitle : "Không tìm thấy giao dịch")</h1>
        <p>@(string.IsNullOrWhiteSpace(Model.ErrorMessage) ? stateMessage : "Chưa đủ thông tin để xác định giao dịch của bạn.")</p>
    </header>

    @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
    {
        <section class="payment-result-card is-error" role="alert">
            <div class="payment-result-card__message">
                <span class="material-symbols-outlined" aria-hidden="true">info</span>
                <div><strong>Cần kiểm tra lại thông tin</strong><p>@Model.ErrorMessage</p></div>
            </div>
            <a class="payment-result-action is-primary" asp-page="/Packages/Index">
                <span class="material-symbols-outlined" aria-hidden="true">arrow_back</span>
                <span>Quay lại chọn gói</span>
            </a>
        </section>
    }
    else if (Model.Status is not null)
    {
        <section class="payment-result-card @stateClass" aria-live="polite" aria-atomic="true">
            <div class="payment-result-card__heading">
                <div>
                    <span>Trạng thái giao dịch</span>
                    <h2>@stateTitle</h2>
                </div>
                <span class="payment-result-status">@statusLabel</span>
            </div>

            @if (isSuccess)
            {
                <p class="payment-result-thanks">Cảm ơn <strong>@customerName</strong>. Quyền lợi của gói đã được cập nhật vào tài khoản của bạn.</p>
            }

            <div class="payment-result-summary">
                <section class="payment-result-order">
                    <div class="payment-result-order__title">
                        <div><span>Đơn thanh toán</span><strong>#@Model.Status.OrderCode</strong></div>
                        <a asp-page="/Subscriptions/Current">Quản lý gói</a>
                    </div>
                    <dl class="payment-result-order__facts">
                        <div><dt>Gói dịch vụ</dt><dd>@packageName</dd></div>
                        <div><dt>Cổng thanh toán</dt><dd><img src="@providerLogo" alt="" /> @providerName</dd></div>
                        <div><dt>Mã giao dịch</dt><dd>@(string.IsNullOrWhiteSpace(Model.Status.ProviderTransactionId) ? "Đang cập nhật" : Model.Status.ProviderTransactionId)</dd></div>
                        <div><dt>Thời gian thanh toán</dt><dd>@(Model.Status.PaidAt?.LocalDateTime.ToString("dd/MM/yyyy HH:mm") ?? "Chưa xác nhận")</dd></div>
                    </dl>
                    <div class="payment-result-order__total"><span>Tổng thanh toán</span><strong>@Model.Status.AmountVnd.ToString("N0") @Model.Status.Currency</strong></div>
                </section>

                @if (isSuccess)
                {
                    <aside class="payment-result-membership">
                        <span class="material-symbols-outlined" aria-hidden="true">workspace_premium</span>
                        <div><span>Gói đang hoạt động</span><h3>@packageName</h3></div>
                        <dl>
                            <div><dt>Có hiệu lực đến</dt><dd>@effectiveUntil</dd></div>
                            @if (Model.Status.MonthlyDocumentUploadLimit > 0)
                            {
                                <div><dt>Tài liệu mỗi tháng</dt><dd>@Model.Status.MonthlyDocumentUploadLimit.ToString("N0") tệp</dd></div>
                            }
                            @if (Model.Status.StorageLimitMb > 0)
                            {
                                <div><dt>Dung lượng lưu trữ</dt><dd>@Model.Status.StorageLimitMb.ToString("N0") MB</dd></div>
                            }
                        </dl>
                    </aside>
                }
            </div>

            @if (!string.IsNullOrWhiteSpace(Model.Status.Message))
            {
                <div class="payment-result-note"><span class="material-symbols-outlined" aria-hidden="true">info</span><span>@Model.Status.Message</span></div>
            }

            @if (isSuccess)
            {
                <div class="payment-result-paid"><span class="material-symbols-outlined" aria-hidden="true">verified</span><span>Giao dịch đã thanh toán <strong>@Model.Status.AmountVnd.ToString("N0") @Model.Status.Currency</strong></span></div>
                <button class="payment-refund-link" type="button" data-refund-policy-open>Xem chính sách hoàn tiền online</button>
            }

            <div class="payment-result-actions">
                @if (isSuccess)
                {
                    <a class="payment-result-action is-primary" asp-page="/Home/Chat">
                        <span class="material-symbols-outlined" aria-hidden="true">smart_toy</span>
                        <span>Bắt đầu sử dụng trợ lý</span>
                    </a>
                    <a class="payment-result-action" asp-page="/Subscriptions/Current">
                        <span class="material-symbols-outlined" aria-hidden="true">receipt_long</span>
                        <span>Xem gói và biên nhận</span>
                    </a>
                }
                else
                {
                    <a class="payment-result-action is-primary" asp-page="/Packages/Index">
                        <span class="material-symbols-outlined" aria-hidden="true">refresh</span>
                        <span>Chọn lại phương thức</span>
                    </a>
                    <a class="payment-result-action" asp-page="/Subscriptions/Current">
                        <span class="material-symbols-outlined" aria-hidden="true">receipt_long</span>
                        <span>Kiểm tra gói hiện tại</span>
                    </a>
                }
            </div>
        </section>
    }
</section>

<dialog id="refundPolicyDialog" class="refund-policy-dialog" aria-labelledby="refundPolicyTitle">
    <div class="refund-policy-dialog__header">
        <h2 id="refundPolicyTitle">Chính sách hoàn tiền khi thanh toán online</h2>
        <button type="button" data-refund-policy-close aria-label="Đóng chính sách hoàn tiền">
            <span class="material-symbols-outlined" aria-hidden="true">close</span><span>Đóng</span>
        </button>
    </div>
    <div class="refund-policy-dialog__body">
        <p>Chính sách này áp dụng cho các gói trợ lý học tập được thanh toán trực tuyến trên hệ thống.</p>
        <section>
            <h3>Trường hợp được xem xét hoàn tiền</h3>
            <ul>
                <li>Giao dịch bị trừ tiền nhiều lần cho cùng một đơn thanh toán.</li>
                <li>Cổng thanh toán xác nhận thành công nhưng gói không được kích hoạt do lỗi hệ thống.</li>
                <li>Giao dịch hiển thị thất bại hoặc đã hủy nhưng tài khoản thanh toán vẫn bị ghi nợ.</li>
            </ul>
        </section>
        <section>
            <h3>Trường hợp không áp dụng</h3>
            <p>Yêu cầu đổi ý sau khi gói đã được kích hoạt và quyền lợi đã được sử dụng sẽ không thuộc phạm vi hoàn tiền, trừ trường hợp pháp luật có quy định khác.</p>
        </section>
        <section>
            <h3>Thời gian xử lý dự kiến</h3>
            <ul>
                <li><strong>Ví MoMo:</strong> 3–5 ngày làm việc kể từ khi yêu cầu được chấp thuận.</li>
                <li><strong>PayOS/chuyển khoản ngân hàng:</strong> 5–10 ngày làm việc, tùy thời gian đối soát của ngân hàng.</li>
            </ul>
            <p>Thời gian trên không bao gồm thứ Bảy, Chủ nhật và ngày lễ.</p>
        </section>
        <section>
            <h3>Cách gửi yêu cầu</h3>
            <p>Gửi email đến <a href="mailto:contact@fpt.edu.vn">contact@fpt.edu.vn</a> kèm mã đơn hàng, email tài khoản và ảnh xác nhận giao dịch. Hệ thống không yêu cầu mật khẩu hoặc mã OTP.</p>
        </section>
    </div>
</dialog>

@section Scripts {
    <script>
        (() => {
            const dialog = document.getElementById("refundPolicyDialog");
            const openButton = document.querySelector("[data-refund-policy-open]");
            const closeButton = dialog?.querySelector("[data-refund-policy-close]");
            if (!dialog || !openButton || !closeButton) return;

            openButton.addEventListener("click", () => dialog.showModal());
            closeButton.addEventListener("click", () => dialog.close());
            dialog.addEventListener("click", event => {
                if (event.target === dialog) dialog.close();
            });
        })();
    </script>
}
