@page
@model PRN222_FINAL.Web.Pages.Account.LoginModel
@{
    ViewData["Title"] = "Đăng nhập";
    ViewData["BodyClass"] = "auth-body";
}

<section class="auth-page">
    <partial name="_AuthStars" />
    <div class="auth-panel">
        <p class="eyebrow" data-i18n="shell.title">Course Assistant</p>
        <h1 data-i18n="account.loginTitle">Đăng nhập</h1>
        <p class="subtitle" data-i18n="account.loginDesc">Truy cập kho tài liệu, quản lý nội dung đã index và tiếp tục phiên hỏi đáp theo nguồn.</p>

        @if (TempData["AuthError"] is string error)
        {
            <div class="alert alert-danger">@error</div>
        }
        @if (TempData["AuthSuccess"] is string success)
        {
            <div class="alert alert-success">@success</div>
        }

        <form asp-page="/Account/Login" method="post" class="auth-form">
            @Html.AntiForgeryToken()
            <input asp-for="ReturnUrl" type="hidden" />
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <label>
                Email
                <input asp-for="Email" class="form-control" autocomplete="email" />
                <span asp-validation-for="Email" class="text-danger"></span>
            </label>
            <label>
                <span data-i18n="account.password">Mật khẩu</span>
                <input asp-for="Password" class="form-control" autocomplete="current-password" />
                <span asp-validation-for="Password" class="text-danger"></span>
            </label>
            <button type="submit" class="btn btn-primary"><span data-i18n="account.loginTitle">Đăng nhập</span></button>
        </form>

        <p class="auth-switch"><a asp-page="/Account/ForgotPassword" data-i18n="account.forgotPasswordLink">Quên mật khẩu?</a></p>

        @if (Model.IsGoogleLoginEnabled)
        {
            <form asp-page-handler="GoogleLogin" method="post" class="google-form">
                @Html.AntiForgeryToken()
                <input name="returnUrl" value="@Model.ReturnUrl" type="hidden" />
                <button type="submit" class="btn btn-outline-dark google-button">
                    <img src="~/img/google-g.svg" alt="" class="google-icon" />
                    <span data-i18n="account.loginGoogle">Đăng nhập với Google</span>
                </button>
            </form>
        }

        <p class="auth-switch" data-i18n="account.noAccountContact">Chưa có tài khoản? Vui lòng liên hệ Nhà trường để xin cấp tài khoản.</p>
        @if (!Model.IsGoogleLoginEnabled && !string.IsNullOrWhiteSpace(Model.GoogleLoginUnavailableMessage))
        {
            <div class="alert alert-warning">@Model.GoogleLoginUnavailableMessage</div>
        }
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

