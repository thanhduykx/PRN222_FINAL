@page
@model PRN222_FINAL.Web.Pages.Account.ForgotPasswordModel
@{
    ViewData["Title"] = "Quên mật khẩu";
    ViewData["BodyClass"] = "auth-body";
}

<section class="auth-page">
    <partial name="_AuthStars" />
    <div class="auth-panel">
        <p class="eyebrow" data-i18n="account.recovery">Account recovery</p>
        <h1 data-i18n="account.forgotPassword">Quên mật khẩu</h1>
        <p class="subtitle" data-i18n="account.forgotPasswordDesc">Nhập email tài khoản để nhận liên kết đặt lại mật khẩu.</p>

        @if (TempData["AuthError"] is string error)
        {
            <div class="alert alert-danger">@error</div>
        }

        <form asp-page="/Account/ForgotPassword" method="post" class="auth-form">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <label>
                Email
                <input asp-for="Input.Email" class="form-control" autocomplete="email" />
                <span asp-validation-for="Input.Email" class="text-danger"></span>
            </label>
            <button type="submit" class="btn btn-primary"><span data-i18n="account.sendLink">Gửi liên kết</span></button>
        </form>

        <p class="auth-switch"><span data-i18n="account.rememberedPassword">Đã nhớ mật khẩu?</span> <a asp-page="/Account/Login" data-i18n="account.login">Đăng nhập</a></p>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

