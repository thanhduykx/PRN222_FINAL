@page
@model PRN222_FINAL.Web.Pages.Account.ResetPasswordModel
@{
    ViewData["Title"] = "Đặt lại mật khẩu";
    ViewData["BodyClass"] = "auth-body";
}

<section class="auth-page">
    <partial name="_AuthStars" />
    <div class="auth-panel">
        <p class="eyebrow" data-i18n="account.passwordResetEyebrow">Password reset</p>
        <h1 data-i18n="account.resetPassword">Đặt lại mật khẩu</h1>
        <p class="subtitle" data-i18n="account.resetPasswordDesc">Tạo mật khẩu mới cho tài khoản của bạn.</p>

        <form asp-page="/Account/ResetPassword" method="post" class="auth-form">
            @Html.AntiForgeryToken()
            <input asp-for="Input.Token" type="hidden" />
            <input asp-for="Input.Email" type="hidden" />
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <label>
                <span data-i18n="account.newPassword">Mật khẩu mới</span>
                <input asp-for="Input.Password" class="form-control" autocomplete="new-password" />
                <span asp-validation-for="Input.Password" class="text-danger"></span>
            </label>
            <label>
                <span data-i18n="account.confirmNewPassword">Nhập lại mật khẩu mới</span>
                <input asp-for="Input.ConfirmPassword" class="form-control" autocomplete="new-password" />
                <span asp-validation-for="Input.ConfirmPassword" class="text-danger"></span>
            </label>
            <button type="submit" class="btn btn-primary"><span data-i18n="account.resetPassword">Đặt lại mật khẩu</span></button>
        </form>

        <p class="auth-switch"><a asp-page="/Account/Login" data-i18n="account.backToLogin">Quay lại đăng nhập</a></p>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

