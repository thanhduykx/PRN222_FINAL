@page
@model PRN222_FINAL.Web.Pages.Account.ChangePasswordModel
@{
    ViewData["Title"] = "Đổi mật khẩu";
    ViewData["UseRblShell"] = true;
    ViewData["ShellTitle"] = "Đổi mật khẩu";
}

<section class="auth-page">
    <partial name="_AuthStars" />
    <div class="auth-panel">
        <p class="eyebrow">Account security</p>
        <h1>Đổi mật khẩu</h1>
        <p class="subtitle">Cập nhật mật khẩu đăng nhập nội bộ của bạn.</p>

        @if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
        {
            <div class="alert alert-success">@Model.StatusMessage</div>
        }

        <form asp-page="/Account/ChangePassword" method="post" class="auth-form">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <label>
                Mật khẩu hiện tại
                <input asp-for="Input.CurrentPassword" class="form-control" autocomplete="current-password" />
                <span asp-validation-for="Input.CurrentPassword" class="text-danger"></span>
            </label>
            <label>
                Mật khẩu mới
                <input asp-for="Input.NewPassword" class="form-control" autocomplete="new-password" />
                <span asp-validation-for="Input.NewPassword" class="text-danger"></span>
            </label>
            <label>
                Nhập lại mật khẩu mới
                <input asp-for="Input.ConfirmPassword" class="form-control" autocomplete="new-password" />
                <span asp-validation-for="Input.ConfirmPassword" class="text-danger"></span>
            </label>
            <button type="submit" class="btn btn-primary">Đổi mật khẩu</button>
        </form>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

