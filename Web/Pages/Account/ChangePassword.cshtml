@page
@model PRN222_FINAL.Web.Pages.Account.ChangePasswordModel
@{
    ViewData["Title"] = "Đổi mật khẩu";
    ViewData["TitleI18n"] = "account.changePasswordTitle";
    ViewData["UseRblShell"] = true;
    ViewData["ShellTitle"] = "Đổi mật khẩu";
    ViewData["ShellTitleI18n"] = "account.changePasswordTitle";
}

<style>
    /* ==========================================================================
           GIAO DIỆN CHANGE PASSWORD (EXACT MATCH VỚI ẢNH THIẾT KẾ)
           ========================================================================== */
    .cp-wrapper {
        display: flex;
        align-items: flex-start;
        justify-content: center;
        padding: 4rem 1rem;
        font-family: 'Inter', system-ui, sans-serif;
        background-color: #f8fafc;
        min-height: 100vh;
    }

    .cp-card {
        background: #ffffff;
        width: 100%;
        max-width: 440px;
        padding: 3rem 2.5rem;
        border-radius: 8px;
        box-shadow: 0 10px 40px -10px rgba(0, 0, 0, 0.08);
        border: 1px solid #f1f5f9;
    }

    /* HEADER */
    .cp-header {
        text-align: left;
        margin-bottom: 2rem;
    }

    .cp-eyebrow {
        font-size: 0.75rem;
        font-weight: 800;
        text-transform: uppercase;
        color: #0d9488; /* Màu xanh lá/xanh ngọc y hệt ảnh */
        letter-spacing: 0.05em;
        margin-bottom: 0.25rem;
    }

    .cp-header h1 {
        font-size: 2.75rem;
        font-weight: 900; /* In đậm tối đa */
        color: #0f172a; /* Đen tuyền/xanh đen tối */
        margin: 0 0 0.5rem 0;
        letter-spacing: -0.025em;
        line-height: 1.1;
    }

    .cp-header p {
        color: #64748b; /* Xám nhạt */
        font-size: 1rem;
        margin: 0;
    }

    /* FORM & INPUTS */
    .cp-form {
        display: flex;
        flex-direction: column;
        gap: 1.5rem;
    }

    .cp-field {
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
    }

        .cp-field span.field-label {
            font-size: 0.9rem;
            font-weight: 700; /* Label in đậm */
            color: #334155;
        }

    .cp-input {
        width: 100%;
        padding: 0.75rem 1rem;
        border: 1px solid #cbd5e1;
        border-radius: 6px;
        font-size: 1rem;
        color: #0f172a;
        transition: border-color 0.2s ease, box-shadow 0.2s ease;
        outline: none;
        box-sizing: border-box;
    }

        .cp-input:focus {
            border-color: #2563eb;
            box-shadow: 0 0 0 3px rgba(37, 99, 235, 0.1);
        }

    /* BUTTON */
    .cp-btn {
        width: 100%;
        background-color: #1a73e8; /* Xanh dương đậm y hệt ảnh */
        color: white;
        font-weight: 800;
        font-size: 1.05rem;
        padding: 0.875rem 1rem;
        border: none;
        border-radius: 6px;
        cursor: pointer;
        transition: background-color 0.2s ease;
        margin-top: 0.5rem;
    }

        .cp-btn:hover {
            background-color: #1557b0;
        }

    /* ALERTS & VALIDATION */
    .cp-alert-success {
        background-color: #f0fdf4;
        border: 1px solid #bbf7d0;
        color: #166534;
        padding: 1rem;
        border-radius: 6px;
        margin-bottom: 1.5rem;
        font-size: 0.875rem;
        font-weight: 600;
    }

    .text-danger {
        color: #ef4444;
        font-size: 0.8rem;
        margin-top: 0.25rem;
        font-weight: 500;
    }
</style>

<section class="cp-wrapper">
    <div class="cp-card">
        <div class="cp-header">
            <p class="cp-eyebrow" data-i18n="account.security">ACCOUNT SECURITY</p>
            <h1 data-i18n="account.changePasswordTitle">Đổi mật khẩu</h1>
            <p data-i18n="account.changePasswordDesc">Bảo vệ tài khoản</p>
        </div>

        @if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
        {
            <div class="cp-alert-success">
                @Model.StatusMessage
            </div>
        }

        <form asp-page="/Account/ChangePassword" method="post" class="cp-form">
            @Html.AntiForgeryToken()

            <div asp-validation-summary="ModelOnly" class="text-danger" style="background: #fef2f2; padding: 0.75rem; border-radius: 6px; border: 1px solid #fecaca; margin-bottom: 0.5rem; display: none;"></div>

            <label class="cp-field">
                <span class="field-label" data-i18n="account.currentPassword">Mật khẩu hiện tại</span>
                <input asp-for="Input.CurrentPassword" class="cp-input" autocomplete="current-password" />
                <span asp-validation-for="Input.CurrentPassword" class="text-danger"></span>
            </label>

            <label class="cp-field">
                <span class="field-label" data-i18n="account.newPassword">Mật khẩu mới</span>
                <input asp-for="Input.NewPassword" class="cp-input" autocomplete="new-password" />
                <span asp-validation-for="Input.NewPassword" class="text-danger"></span>
            </label>

            <label class="cp-field">
                <span class="field-label" data-i18n="account.confirmNewPassword">Nhập lại mật khẩu mới</span>
                <input asp-for="Input.ConfirmPassword" class="cp-input" autocomplete="new-password" />
                <span asp-validation-for="Input.ConfirmPassword" class="text-danger"></span>
            </label>

            <button type="submit" class="cp-btn">
                <span data-i18n="account.changePasswordTitle">Đổi mật khẩu</span>
            </button>
        </form>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        // Hiển thị div lỗi nếu có lỗi model chung
        document.addEventListener("DOMContentLoaded", function() {
            var summary = document.querySelector('[data-valmsg-summary="true"]');
            if (summary && summary.classList.contains('validation-summary-errors')) {
                summary.style.display = 'block';
            }
        });
    </script>
}