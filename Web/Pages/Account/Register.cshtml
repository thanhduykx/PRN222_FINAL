@page
@model PRN222_FINAL.Web.Pages.Account.RegisterModel
@{
    ViewData["Title"] = "Tạo tài khoản";
    ViewData["BodyClass"] = "auth-body";
}

<section class="auth-page">
    <partial name="_AuthStars" />
    <div class="auth-panel">
        <p class="eyebrow" data-i18n="account.newAccountEyebrow">Tài khoản mới</p>
        <h1 data-i18n="account.createAccountTitle">Tạo tài khoản</h1>
        <p class="subtitle" data-i18n="account.createAccountDesc">Tạo tài khoản nội bộ để quản lý tài liệu và sử dụng phiên hỏi đáp.</p>

        <form asp-page="/Account/Register" method="post" class="auth-form">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <label>
                <span data-i18n="account.fullName">Họ tên</span>
                <input asp-for="FullName" class="form-control" autocomplete="name" />
                <span asp-validation-for="FullName" class="text-danger"></span>
            </label>
            <label>
                Email
                <input asp-for="Email" class="form-control" autocomplete="email" />
                <span asp-validation-for="Email" class="text-danger"></span>
            </label>
            <label>
                <span data-i18n="account.password">Mật khẩu</span>
                <input asp-for="Password" class="form-control" autocomplete="new-password" />
                <span asp-validation-for="Password" class="text-danger"></span>
            </label>
            <label>
                <span data-i18n="account.confirmPassword">Nhập lại mật khẩu</span>
                <input asp-for="ConfirmPassword" class="form-control" autocomplete="new-password" />
                <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
            </label>
            <button type="submit" class="btn btn-primary"><span data-i18n="account.createAccountTitle">Tạo tài khoản</span></button>
        </form>

        <p class="auth-switch"><span data-i18n="account.alreadyHaveAccount">Đã có tài khoản?</span> <a asp-page="/Account/Login" data-i18n="account.login">Đăng nhập</a></p>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

